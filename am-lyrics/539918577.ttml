<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Chuck Comeau</songwriter><songwriter>Pierre Bouvier</songwriter><songwriter>Toby Gad</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="This Song Saved My Life"/><amll:meta key="artists" value="Simple Plan"/><amll:meta key="artists" value="Brian Howes"/><amll:meta key="album" value="Get Your Heart On! (Deluxe Edition)"/><amll:meta key="appleMusicId" value="539918577"/><amll:meta key="ncmMusicId" value="1890347701"/><amll:meta key="ttmlAuthorGithub" value="42886855"/><amll:meta key="ttmlAuthorGithubLogin" value="ArSrNa"/></metadata></head><body dur="3:02.716"><div begin="7.012" end="3:02.716"><p begin="7.012" end="10.089" itunes:key="L1" ttm:agent="v1"><span begin="7.012" end="7.207">I</span> <span begin="7.207" end="7.430">wan</span><span begin="7.430" end="7.597">na</span> <span begin="7.597" end="8.154">start</span> <span begin="8.359" end="8.515">by</span> <span begin="8.515" end="8.695">let</span><span begin="8.695" end="8.928">ting</span> <span begin="8.928" end="9.141">you</span> <span begin="9.141" end="9.494">know</span> <span begin="9.494" end="10.089">this</span><span ttm:role="x-translation" xml:lang="zh-CN">我想先让你知道这件事</span></p><p begin="10.391" end="11.400" itunes:key="L2" ttm:agent="v1"><span begin="10.391" end="10.732">Because</span> <span begin="10.732" end="10.914">of</span> <span begin="10.914" end="11.400">you</span><span ttm:role="x-translation" xml:lang="zh-CN">因为你</span></p><p begin="11.651" end="13.788" itunes:key="L3" ttm:agent="v1"><span begin="11.651" end="11.808">My</span> <span begin="11.808" end="11.964">life</span> <span begin="11.964" end="12.183">has</span> <span begin="12.183" end="12.532">a</span> <span begin="12.532" end="12.933">pur</span><span begin="12.933" end="13.788">pose</span><span ttm:role="x-translation" xml:lang="zh-CN">我的人生才有了意义</span></p><p begin="13.788" end="16.571" itunes:key="L4" ttm:agent="v1"><span begin="13.788" end="13.931">You</span> <span begin="13.931" end="14.162">helped</span> <span begin="14.162" end="14.402">me</span> <span begin="14.402" end="14.848">be</span> <span begin="14.848" end="14.995">who</span> <span begin="14.995" end="15.297">I</span> <span begin="15.297" end="15.650">am</span> <span begin="15.650" end="15.871">to</span><span begin="15.871" end="16.571">day</span><span ttm:role="x-translation" xml:lang="zh-CN">你帮我成就今天的自己</span></p><p begin="17.106" end="19.951" itunes:key="L5" ttm:agent="v1"><span begin="17.106" end="17.251">I</span> <span begin="17.251" end="17.541">see</span> <span begin="17.541" end="17.697">my</span><span begin="17.697" end="18.010">self</span> <span begin="18.010" end="18.157">in</span> <span begin="18.157" end="18.555">every</span> <span begin="18.555" end="18.939">word</span> <span begin="18.939" end="19.138">you</span> <span begin="19.138" end="19.951">say</span><span ttm:role="x-translation" xml:lang="zh-CN">我活在你的每句话语中</span></p><p begin="20.541" end="21.746" itunes:key="L6" ttm:agent="v1"><span begin="20.541" end="20.600">Some</span><span begin="20.600" end="20.673">times</span> <span begin="20.673" end="20.929">it</span> <span begin="20.929" end="21.746">feels</span><span ttm:role="x-translation" xml:lang="zh-CN">有时候觉得</span></p><p begin="21.746" end="23.563" itunes:key="L7" ttm:agent="v1"><span begin="21.746" end="21.963">Like</span> <span begin="21.963" end="22.172">no</span><span begin="22.172" end="22.589">body</span> <span begin="22.589" end="22.961">gets</span> <span begin="22.961" end="23.563">me</span><span ttm:role="x-translation" xml:lang="zh-CN">这世上没人理解我</span></p><p begin="23.563" end="25.010" itunes:key="L8" ttm:agent="v1"><span begin="23.563" end="24.062">Trapped</span> <span begin="24.062" end="24.262">in</span> <span begin="24.262" end="24.511">a</span> <span begin="24.511" end="25.010">world</span><span ttm:role="x-translation" xml:lang="zh-CN">被困在一个</span></p><p begin="25.095" end="26.695" itunes:key="L9" ttm:agent="v1"><span begin="25.095" end="25.379">Where</span> <span begin="25.379" end="25.707">every</span><span begin="25.707" end="25.917">one</span> <span begin="25.917" end="26.313">hates</span> <span begin="26.313" end="26.695">me</span><span ttm:role="x-translation" xml:lang="zh-CN">所有人都讨厌我的世界里</span></p><p begin="27.245" end="29.857" itunes:key="L10" ttm:agent="v1"><span begin="27.245" end="27.422">There&apos;s</span> <span begin="27.422" end="27.808">so</span> <span begin="27.808" end="28.221">much</span> <span begin="28.221" end="28.372">that</span> <span begin="28.372" end="28.695">I&apos;m</span> <span begin="28.695" end="29.274">going</span> <span begin="29.274" end="29.857">through</span><span ttm:role="x-translation" xml:lang="zh-CN">我正经历着太多的痛苦</span></p><p begin="30.148" end="31.573" itunes:key="L11" ttm:agent="v1"><span begin="30.148" end="30.332">I</span> <span begin="30.332" end="30.762">wouldn&apos;t</span> <span begin="30.762" end="31.190">be</span> <span begin="31.190" end="31.573">here</span><span ttm:role="x-translation" xml:lang="zh-CN">如果不是因为有你</span></p><p begin="31.573" end="33.555" itunes:key="L12" ttm:agent="v1"><span begin="31.573" end="31.733">If</span> <span begin="31.733" end="32.011">it</span> <span begin="32.011" end="32.463">wasn&apos;t</span> <span begin="32.463" end="32.627">for</span> <span begin="32.627" end="33.555">you</span><span ttm:role="x-translation" xml:lang="zh-CN">我根本撑不到现在</span></p><p begin="33.988" end="35.677" itunes:key="L13" ttm:agent="v1"><span begin="33.988" end="34.130">I</span> <span begin="34.130" end="34.413">was</span> <span begin="34.413" end="35.677">broken</span><span ttm:role="x-translation" xml:lang="zh-CN">我曾支离破碎</span></p><p begin="35.677" end="37.329" itunes:key="L14" ttm:agent="v1"><span begin="35.677" end="35.831">I</span> <span begin="35.831" end="36.115">was</span> <span begin="36.115" end="37.329">choking</span><span ttm:role="x-translation" xml:lang="zh-CN">难以呼吸</span></p><p begin="37.329" end="38.263" itunes:key="L15" ttm:agent="v1"><span begin="37.329" end="37.483">I</span> <span begin="37.483" end="37.700">was</span> <span begin="37.700" end="38.263">lost</span><span ttm:role="x-translation" xml:lang="zh-CN">迷失方向</span></p><p begin="38.263" end="40.579" itunes:key="L16" ttm:agent="v1"><span begin="38.263" end="38.738">This</span> <span begin="38.738" end="39.412">song</span> <span begin="39.412" end="39.729">saved</span> <span begin="39.729" end="40.177">my</span> <span begin="40.177" end="40.579">life</span><span ttm:role="x-translation" xml:lang="zh-CN">这首歌拯救了我</span></p><p begin="40.579" end="42.269" itunes:key="L17" ttm:agent="v1"><span begin="40.579" end="40.742">I</span> <span begin="40.742" end="41.009">was</span> <span begin="41.009" end="42.269">bleeding</span><span ttm:role="x-translation" xml:lang="zh-CN">我曾受伤流血</span></p><p begin="42.269" end="43.970" itunes:key="L18" ttm:agent="v1"><span begin="42.269" end="42.425">Stopped</span> <span begin="42.425" end="43.970">believing</span><span ttm:role="x-translation" xml:lang="zh-CN">心灰意冷</span></p><p begin="43.970" end="44.961" itunes:key="L19" ttm:agent="v1"><span begin="43.970" end="44.126">Could</span> <span begin="44.126" end="44.446">have</span> <span begin="44.446" end="44.961">died</span><span ttm:role="x-translation" xml:lang="zh-CN">几乎丧命</span></p><p begin="44.961" end="47.300" itunes:key="L20" ttm:agent="v1"><span begin="44.961" end="45.427">This</span> <span begin="45.427" end="46.042">song</span> <span begin="46.042" end="46.429">saved</span> <span begin="46.429" end="46.808">my</span> <span begin="46.808" end="47.300">life</span><span ttm:role="x-translation" xml:lang="zh-CN">这首歌拯救了我</span></p><p begin="47.300" end="48.698" itunes:key="L21" ttm:agent="v1"><span begin="47.300" end="47.445">I</span> <span begin="47.445" end="47.772">was</span> <span begin="47.772" end="48.698">down</span><span ttm:role="x-translation" xml:lang="zh-CN">我曾郁郁寡欢</span></p><p begin="49.061" end="50.480" itunes:key="L22" ttm:agent="v1"><span begin="49.061" end="49.222">I</span> <span begin="49.222" end="49.513">was</span> <span begin="49.513" end="50.480">drowning</span><span ttm:role="x-translation" xml:lang="zh-CN">如堕烟海</span></p><p begin="50.924" end="55.010" itunes:key="L23" ttm:agent="v1"><span begin="50.924" end="51.066">But</span> <span begin="51.066" end="51.496">it</span> <span begin="51.496" end="52.160">came</span> <span begin="52.160" end="52.832">on</span> <span begin="52.832" end="53.232">just</span> <span begin="53.232" end="53.622">in</span> <span begin="53.622" end="55.010">time</span><span ttm:role="x-translation" xml:lang="zh-CN">好在它及时出现</span></p><p begin="55.010" end="58.083" itunes:key="L24" ttm:agent="v1"><span begin="55.010" end="55.445">This</span> <span begin="55.445" end="56.172">song</span> <span begin="56.172" end="56.611">saved</span> <span begin="56.611" end="56.955">my</span> <span begin="56.955" end="58.083">life</span><span ttm:role="x-translation" xml:lang="zh-CN">这首歌拯救了我</span></p><p begin="1:00.713" end="1:01.820" itunes:key="L25" ttm:agent="v1"><span begin="1:00.713" end="1:00.933">Some</span><span begin="1:00.933" end="1:01.170">times</span> <span begin="1:01.170" end="1:01.398">I</span> <span begin="1:01.398" end="1:01.820">feel</span><span ttm:role="x-translation" xml:lang="zh-CN">有时候我觉得</span></p><p begin="1:01.820" end="1:04.138" itunes:key="L26" ttm:agent="v1"><span begin="1:01.820" end="1:01.990">Like</span> <span begin="1:01.990" end="1:02.172">you&apos;ve</span> <span begin="1:02.172" end="1:02.439">known</span> <span begin="1:02.439" end="1:02.757">me</span> <span begin="1:02.757" end="1:04.138">forever</span><span ttm:role="x-translation" xml:lang="zh-CN">你我似是前世旧识</span></p><p begin="1:04.138" end="1:07.477" itunes:key="L27" ttm:agent="v1"><span begin="1:04.138" end="1:04.297">You</span> <span begin="1:04.297" end="1:04.684">always</span> <span begin="1:04.684" end="1:05.155">know</span> <span begin="1:05.155" end="1:05.318">how</span> <span begin="1:05.318" end="1:05.556">to</span> <span begin="1:05.556" end="1:05.748">make</span> <span begin="1:05.748" end="1:05.974">me</span> <span begin="1:05.974" end="1:06.299">feel</span> <span begin="1:06.299" end="1:07.477">better</span><span ttm:role="x-translation" xml:lang="zh-CN">你总是最懂如何宽慰我</span></p><p begin="1:07.477" end="1:08.523" itunes:key="L28" ttm:agent="v1"><span begin="1:07.477" end="1:07.681">Because</span> <span begin="1:07.681" end="1:07.918">of</span> <span begin="1:07.918" end="1:08.523">you</span><span ttm:role="x-translation" xml:lang="zh-CN">多亏有你</span></p><p begin="1:08.523" end="1:10.868" itunes:key="L29" ttm:agent="v1"><span begin="1:08.523" end="1:08.955">My</span> <span begin="1:08.955" end="1:09.353">dad</span> <span begin="1:09.353" end="1:09.498">and</span> <span begin="1:09.498" end="1:10.868">me</span><span ttm:role="x-translation" xml:lang="zh-CN">拉近我和父亲的距离</span></p><p begin="1:10.868" end="1:13.738" itunes:key="L30" ttm:agent="v1"><span begin="1:10.868" end="1:10.987">Are</span> <span begin="1:10.987" end="1:11.154">so</span> <span begin="1:11.154" end="1:11.415">much</span> <span begin="1:11.415" end="1:11.922">closer</span> <span begin="1:11.922" end="1:12.100">than</span> <span begin="1:12.100" end="1:12.358">we</span> <span begin="1:12.358" end="1:12.741">used</span> <span begin="1:12.741" end="1:12.921">to</span> <span begin="1:12.921" end="1:13.738">be</span><span ttm:role="x-translation" xml:lang="zh-CN">我们从未如此亲近</span></p><p begin="1:14.159" end="1:15.271" itunes:key="L31" ttm:agent="v1"><span begin="1:14.159" end="1:14.344">You&apos;re</span> <span begin="1:14.344" end="1:14.605">my</span> <span begin="1:14.605" end="1:15.271">escape</span><span ttm:role="x-translation" xml:lang="zh-CN">每当我被困住时</span></p><p begin="1:15.271" end="1:17.621" itunes:key="L32" ttm:agent="v1"><span begin="1:15.271" end="1:15.426">When</span> <span begin="1:15.426" end="1:15.624">I&apos;m</span> <span begin="1:15.624" end="1:15.864">stuck</span> <span begin="1:15.864" end="1:16.119">in</span> <span begin="1:16.119" end="1:16.397">this</span> <span begin="1:16.397" end="1:16.700">small</span> <span begin="1:16.700" end="1:17.621">town</span><span ttm:role="x-translation" xml:lang="zh-CN">是你帮助我逃离</span></p><p begin="1:17.621" end="1:18.856" itunes:key="L33" ttm:agent="v1"><span begin="1:17.621" end="1:17.766">I</span> <span begin="1:17.766" end="1:17.965">turn</span> <span begin="1:17.965" end="1:18.167">you</span> <span begin="1:18.167" end="1:18.856">up</span><span ttm:role="x-translation" xml:lang="zh-CN">每当我心情低落</span></p><p begin="1:18.856" end="1:20.970" itunes:key="L34" ttm:agent="v1"><span begin="1:18.856" end="1:19.470">Whenever</span> <span begin="1:19.470" end="1:19.664">I</span> <span begin="1:19.664" end="1:20.071">feel</span> <span begin="1:20.071" end="1:20.970">down</span><span ttm:role="x-translation" xml:lang="zh-CN">就回想你的声音</span></p><p begin="1:20.970" end="1:23.889" itunes:key="L35" ttm:agent="v1"><span begin="1:20.970" end="1:21.138">You</span> <span begin="1:21.138" end="1:21.307">let</span> <span begin="1:21.307" end="1:21.574">me</span> <span begin="1:21.574" end="1:21.992">know</span> <span begin="1:21.992" end="1:22.404">like</span> <span begin="1:22.404" end="1:22.805">no</span> <span begin="1:22.805" end="1:23.002">one</span> <span begin="1:23.002" end="1:23.889">else</span><span ttm:role="x-translation" xml:lang="zh-CN">是你告诉我不必像别人一样</span></p><p begin="1:23.889" end="1:27.266" itunes:key="L36" ttm:agent="v1"><span begin="1:23.889" end="1:24.110">That</span> <span begin="1:24.110" end="1:24.599">it&apos;s</span> <span begin="1:24.599" end="1:2