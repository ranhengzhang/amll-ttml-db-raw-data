<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Jez Ashurst</songwriter><songwriter>Emma Rohan</songwriter><songwriter>Rachel Furner</songwriter><songwriter>Jason Desrouleaux</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="Secret Love Song (feat. Jason Derulo)"/><amll:meta key="artists" value="Little Mix"/><amll:meta key="artists" value="Jason Derulo"/><amll:meta key="album" value="Get Weird (Expanded Edition)"/><amll:meta key="album" value="Get Weird"/><amll:meta key="isrc" value="GBHMU1500073"/><amll:meta key="ncmMusicId" value="36308293"/><amll:meta key="spotifyId" value="6KHL1En9v6iNWjcs44mcmU"/><amll:meta key="spotifyId" value="03tn7cFXXqIB6WEqRQJUnK"/><amll:meta key="ttmlAuthorGithub" value="181228823"/><amll:meta key="ttmlAuthorGithubLogin" value="watercooling480"/></metadata></head><body dur="4:03.061"><div begin="0.870" end="4:03.061"><p begin="0.870" end="4.595" itunes:key="L1" ttm:agent="v1"><span begin="0.870" end="1.227">When</span> <span begin="1.227" end="1.521">you</span> <span begin="1.521" end="2.300">hold</span> <span begin="2.300" end="2.877">me</span> <span begin="2.877" end="3.224">in</span> <span begin="3.224" end="3.702">the</span> <span begin="3.702" end="4.406">street</span><span ttm:role="x-translation" xml:lang="zh-CN">当你在大街上拥我入怀</span></p><p begin="4.595" end="10.220" itunes:key="L2" ttm:agent="v1"><span begin="4.595" end="5.015">And</span> <span begin="5.015" end="5.330">you</span> <span begin="5.330" end="5.652">kiss</span> <span begin="5.652" end="5.982">me</span> <span begin="5.982" end="6.305">on</span> <span begin="6.305" end="6.657">the</span> <span begin="6.657" end="7.677">dance</span> <span begin="7.677" end="9.710">floor</span><span ttm:role="x-translation" xml:lang="zh-CN">当你在舞池中亲吻我</span></p><p begin="10.220" end="13.490" itunes:key="L3" ttm:agent="v1"><span begin="10.220" end="10.505">I</span> <span begin="10.505" end="10.903">wish</span> <span begin="10.903" end="11.225">that</span> <span begin="11.225" end="11.532">it</span> <span begin="11.532" end="11.855">could</span> <span begin="11.855" end="12.155">be</span> <span begin="12.155" end="12.867">like</span> <span begin="12.867" end="13.175">that</span><span ttm:role="x-translation" xml:lang="zh-CN">我多希望一切能永远如此</span></p><p begin="13.490" end="16.025" itunes:key="L4" ttm:agent="v1"><span begin="13.490" end="13.767">Why</span> <span begin="13.767" end="14.059">can&apos;t</span> <span begin="14.059" end="14.412">it</span> <span begin="14.412" end="14.735">be</span> <span begin="14.735" end="15.410">like</span> <span begin="15.410" end="15.772">that?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何现实不能如此</span></p><p begin="16.025" end="21.859" itunes:key="L5" ttm:agent="v1"><span begin="16.025" end="16.347">&apos;Cause</span> <span begin="16.347" end="16.947">I&apos;m</span> <span begin="16.947" end="21.050">yours</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我属于你</span></p><p begin="21.859" end="25.395" itunes:key="L6" ttm:agent="v1"><span begin="21.859" end="22.242">We</span> <span begin="22.242" end="22.801">keep</span> <span begin="22.801" end="23.787">behind</span> <span begin="23.787" end="24.472">closed</span> <span begin="24.472" end="25.109">doors</span><span ttm:role="x-translation" xml:lang="zh-CN">我们只能藏身门后</span></p><p begin="25.395" end="30.564" itunes:key="L7" ttm:agent="v1"><span begin="25.395" end="25.994">Every</span> <span begin="25.994" end="26.315">time</span> <span begin="26.315" end="26.682">I</span> <span begin="26.682" end="27.005">see</span> <span begin="27.005" end="27.349">you,</span> <span begin="27.349" end="27.992">I</span> <span begin="27.992" end="28.321">die</span> <span begin="28.321" end="28.684">a</span> <span begin="28.684" end="29.634">little</span> <span begin="29.634" end="30.325">more</span><span ttm:role="x-translation" xml:lang="zh-CN">每次见到你 我的心就死去一点</span></p><p begin="30.564" end="35.982" itunes:key="L8" ttm:agent="v1"><span begin="30.564" end="31.215">Stolen</span> <span begin="31.215" end="31.845">moments</span> <span begin="31.845" end="32.142">that</span> <span begin="32.142" end="32.506">we</span> <span begin="32.506" end="33.189">steal</span> <span begin="33.189" end="33.513">as</span> <span begin="33.513" end="33.828">the</span> <span begin="33.828" end="34.782">curtain</span> <span begin="34.782" end="35.657">falls</span><span ttm:role="x-translation" xml:lang="zh-CN">在帷幕落下时偷来的片刻温存</span></p><p begin="35.982" end="41.679" itunes:key="L9" ttm:agent="v1"><span begin="35.982" end="36.347">It&apos;ll</span> <span begin="36.347" end="36.784">never</span> <span begin="36.784" end="37.318">be</span> <span begin="37.318" end="41.187">enough</span><span ttm:role="x-translation" xml:lang="zh-CN">这永远不够</span></p><p begin="41.679" end="46.022" itunes:key="L10" ttm:agent="v1"><span begin="41.679" end="42.118">It&apos;s</span> <span begin="42.118" end="43.410">obvious</span> <span begin="43.410" end="44.134">you&apos;re</span> <span begin="44.134" end="44.430">meant</span> <span begin="44.430" end="45.079">for</span> <span begin="45.079" end="45.575">me</span><span ttm:role="x-translation" xml:lang="zh-CN">你显然注定属于我</span></p><p begin="46.022" end="51.159" itunes:key="L11" ttm:agent="v1"><span begin="46.022" end="46.657">Every</span> <span begin="46.657" end="46.990">piece</span> <span begin="46.990" end="47.360">of</span> <span begin="47.360" end="47.668">you,</span> <span begin="47.668" end="47.941">it</span> <span begin="47.941" end="48.596">just</span> <span begin="48.596" end="49.227">fits</span> <span begin="49.227" end="50.809">perfectly</span><span ttm:role="x-translation" xml:lang="zh-CN">你的每一部分 都与我完美契合</span></p><p begin="51.159" end="56.722" itunes:key="L12" ttm:agent="v1"><span begin="51.159" end="51.759">Every</span> <span begin="51.759" end="52.458">second,</span> <span begin="52.458" end="53.149">every</span> <span begin="53.149" end="53.826">thought,</span> <span begin="53.826" end="54.454">I&apos;m</span> <span begin="54.454" end="54.746">in</span> <span begin="54.746" end="55.365">so</span> <span begin="55.365" end="55.931">deep</span><span ttm:role="x-translation" xml:lang="zh-CN">每一秒 每一念 我都深陷其中</span></p><p begin="56.722" end="1:02.630" itunes:key="L13" ttm:agent="v1"><span begin="56.722" end="56.934">But</span> <span begin="56.934" end="57.084">I&apos;ll</span> <span begin="57.084" end="57.699">never</span> <span begin="57.699" end="58.037">show</span> <span begin="58.037" end="58.374">it</span> <span begin="58.374" end="59.885">on</span> <span begin="59.885" end="1:00.530">my</span> <span begin="1:00.530" end="1:02.630">face</span><span ttm:role="x-translation" xml:lang="zh-CN">但我永远不会在脸上显露</span></p><p begin="1:02.488" end="1:06.077" itunes:key="L14" ttm:agent="v1"><span begin="1:02.488" end="1:02.800">But</span> <span begin="1:02.800" end="1:03.084">we</span> <span begin="1:03.084" end="1:04.517">know</span> <span begin="1:04.517" end="1:05.904">this</span><span ttm:role="x-translation" xml:lang="zh-CN">但我们都明白</span></p><p begin="1:06.077" end="1:12.819" itunes:key="L15" ttm:agent="v1"><span begin="1:06.077" end="1:06.377">We</span> <span begin="1:06.377" end="1:06.722">got</span> <span begin="1:06.722" end="1:07.052">a</span> <span begin="1:07.052" end="1:07.629">love</span> <span begin="1:07.629" end="1:07.967">that</span> <span begin="1:07.967" end="1:08.297">is</span> <span begin="1:08.297" end="1:09.609">hope</span><span begin="1:09.609" end="1:11.994">less</span><span ttm:role="x-translation" xml:lang="zh-CN">我们拥有的是一份无望的爱</span></p><p begin="1:12.819" end="1:16.671" itunes:key="L16" ttm:agent="v1"><span begin="1:12.819" end="1:13.202">Why</span> <span begin="1:13.202" end="1:13.487">can&apos;t</span> <span begin="1:13.487" end="1:13.832">you</span> <span begin="1:13.832" end="1:14.394">hold</span> <span begin="1:14.394" end="1:14.770">me</span> <span begin="1:15.122" end="1:15.400">in</span> <span begin="1:15.400" end="1:15.955">the</span> <span begin="1:15.955" end="1:16.555">street?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何你不能在大街上拥抱我</span></p><p begin="1:16.671" end="1:22.440" itunes:key="L17" ttm:agent="v1"><span begin="1:16.671" end="1:17.022">Why</span> <span begin="1:17.022" end="1:17.369">can&apos;t</span> <span begin="1:17.369" end="1:17.690">I</span> <span begin="1:17.690" end="1:17.976">kiss</span> <span begin="1:17.976" end="1:18.321">you</span> <span begin="1:18.321" end="1:18.720">on</span> <span begin="1:18.720" end="1:18.855">the</span> <span begin="1:18.855" end="1:19.879">dance</span> <span begin="1:19.879" end="1:21.711">floor?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何我不能在舞池中亲吻你</span></p><p begin="1:22.440" end="1:25.706" itunes:key="L18" ttm:agent="v1"><span begin="1:22.440" end="1:22.814">I</span> <span begin="1:22.814" end="1:23.155">wish</span> <span begin="1:23.155" end="1:23.513">that</span> <span begin="1:23.513" end="1:23.805">it</span> <span begin="1:23.805" end="1:24.128">could</span> <span begin="1:24.128" end="1:24.428">be</span> <span begin="1:24.428" end="1:25.050">like</span> <span begin="1:25.050" end="1:25.433">that</span><span ttm:role="x-translation" xml:lang="zh-CN">我多希望一切能永远如此</span></p><p begin="1:25.706" end="1:28.252" itunes:key="L19" ttm:agent="v1"><span begin="1:25.706" end="1:26.010">Why</span> <span begin="1:26.010" end="1:26.336">can&apos;t</span> <span begin="1:26.336" end="1:26.700">we</span> <span begin="1:26.700" end="1:26.978">be</span> <span begin="1:26.978" end="1:27.629">like</span> <span begin="1:27.629" end="1:27.988">that?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何我们不能像那样</span></p><p begin="1:28.252" end="1:33.465" itunes:key="L20" ttm:agent="v1"><span begin="1:28.252" end="1:28.572">&apos;Cause</span> <span begin="1:28.572" end="1:29.238">I&apos;m</span> <span begin="1:29.238" end="1:33.255">yours</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我属于你</span></p><p begin="1:33.465" end="1:37.648" itunes:key="L21" ttm:agent="v2"><span begin="1:33.465" end="1:33.890">When</span> <span begin="1:33.890" end="1:34.171">you&apos;re</span> <span begin="1:34.171" end="1:34.531">with</span> <span begin="1:34.531" end="1:35.144">him,</span> <span begin="1:35.144" end="1:35.444">do</span> <span begin="1:35.444" end="1:35.759">you</span> <span begin="1:35.759" end="1:36.044">call</span> <span begin="1:36.044" end="1:36.700">his</span> <span begin="1:36.700" end="1:37.228">name</span><span ttm:role="x-translation" xml:lang="zh-CN">当你和他在一起 你是否呼唤他的名字</span></p><p begin="1:37.648" end="1:40.229" itunes:key="L22" ttm:agent="v2"><span begin="1:37.648" end="1:38.026">Like</span> <span begin="1:38.026" end="1:38.352">you</span> <span begin="1:38.352" end="1:38.675">do</span> <span begin="1:38.675" end="1:38.998">when</span> <span begin="1:38.998" end="1:39.290">you&apos;re</span> <span begin="1:39.290" end="1:39.590">with</span> <span begin="1:39.590" end="1:40.229">me?</span><span ttm:role="x-translation" xml:lang="zh-CN">就像你和我在一起时那样</span></p><p begin="1:40.229" end="1:43.040" itunes:key="L23" ttm:agent="v2"><span begin="1:40.229" end="1:40.581">Does</span> <span begin="1:40.581" end="1:40.934">it</span> <span begin="1:40.934" end="1:41.194">feel</span> <span begin="1:41.194" end="1:41.804">the</span> <span begin="1:41.804" end="1:42.854">same?</span><span ttm:role="x-translation" xml:lang="zh-CN">感觉是否相同</span></p><p begin="1:43.040" end="1:48.548" itunes:key="L24" ttm:agent="v2"><span begin="1:43.040" end="1:43.250">Would</span> <span begin="1:43.250" end="1:43.468">you</span> <span begin="1:43.468" end="1:43.910">leave</span> <span begin="1:43.910" end="1:44.150">if</span> <span begin="1:44.150" end="1:44.467">I</span> <span begin="1:44.467" end="1:44.793">was</span> <span begin="1:44.793" end="1:45.739">ready</span> <span begin="1:45.739" end="1:46.061">to</span> <span begin="1:46.061" end="1:46.988">settle</span> <span begin="1:46.988" end="1:48.548">down?</span><span ttm:role="x-translation" xml:lang="zh-CN">如果我准备好安定下来 你会离开吗</span></p><p begin="1:48.548" end="1:54.434" itunes:key="L25" ttm:agent="v2"><span begin="1:48.548" end="1:48.698">Or</span> <span begin="1:48.698" end="1:48.988">would</span> <span begin="1:48.988" end="1:49.328">you</span> <span begin="1:49.328" end="1:49.688">play</span> <span begin="1:49.688" end="1:50.040">it</span> <span begin="1:50.040" end="1:51.528">safe</span> <span begin="1:51.528" end="1:52.178">and</span> <span begin="1:52.178" end="1:54.128">stay?</span><span ttm:role="x-translation" xml:lang="zh-CN">还是会选择稳妥 留下</span></p><p begin="1:54.434" end="1:57.665" itunes:key="L26" ttm:agent="v2"><span begin="1:54.434" end="1:54.617">Girl,</span> <span begin="1:54.617" end="1:54.779">you</span> <span begin="1:54.779" end="1:56.032">know</span> <span begin="1:56.032" end="1:57.237">this</span><span ttm:role="x-translation" xml:lang="zh-CN">女孩 你明白的</span></p><p begin="1:57.665" end="2:04.330" itunes:key="L27" ttm:agent="v2"><span begin="1:57.665" end="1:57.992">We</span> <span begin="1:57.992" end="1:58.315">got</span> <span begin="1:58.315" end="1:58.628">a</span> <span begin="1:58.628" end="1:59.140">love</span> <span begin="1:59.305" end="1:59.591">that</span> <span begin="1:59.591" end="1:59.875">is</span> <span begin="1:59.875" end="2:01.187">hope</span><span begin="2:01.187" end="2:03.235">less</span><span ttm:role="x-translation" xml:lang="zh-CN">我们拥有的是一份无望的爱</span></p><p begin="2:04.330" end="2:08.288" itunes:key="L28" ttm:agent="v1"><span begin="2:04.330" end="2:04.795">Why</span> <span begin="2:04.795" end="2:05.087">can&apos;t</span> <span begin="2:05.087" end="2:05.462">you</span> <span begin="2:05.462" end="2:06.100">hold</span> <span begin="2:06.100" end="2:06.497">me</span> <span begin="2:06.752" end="2:06.992">in</span> <span begin="2:06.992" end="2:07.607">the</span> <span begin="2:07.607" end="2:08.147">street?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何你不能在大街上拥抱我</span></p><p begin="2:08.288" end="2:14.059" itunes:key="L29" ttm:agent="v1"><span begin="2:08.288" end="2:08.588">Why</span> <span begin="2:08.588" end="2:08.911">can&apos;t</span> <span begin="2:08.911" end="2:09.223">I</span> <span begin="2:09.223" end="2:09.571">kiss</span> <span begin="2:09.571" end="2:09.901">you</span> <span begin="2:09.901" end="2:10.198">on</span> <span begin="2:10.198" end="2:10.381">the</span> <span begin="2:10.381" end="2:11.438">dance</span> <span begin="2:11.438" end="2:13.312">floor?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何我不能在舞池中亲吻你</span></p><p begin="2:14.059" end="2:17.293" itunes:key="L30" ttm:agent="v1"><span begin="2:14.059" end="2:14.431">I</span> <span begin="2:14.431" end="2:14.738">wish</span> <span begin="2:14.738" end="2:15.073">that</span> <span begin="2:15.073" end="2:15.361">it</span> <span begin="2:15.361" end="2:15.721">could</span> <span begin="2:15.721" end="2:16.009">be</span> <span begin="2:16.009" end="2:16.658">like</span> <span begin="2:16.658" end="2:17.036">that</span><span ttm:role="x-translation" xml:lang="zh-CN">我多希望一切能永远如此</span></p><p begin="2:17.293" end="2:19.848" itunes:key="L31" ttm:agent="v1"><span begin="2:17.293" end="2:17.596">Why</span> <span begin="2:17.596" end="2:17.918">can&apos;t</span> <span begin="2:17.918" end="2:18.267">we</span> <span begin="2:18.267" end="2:18.562">be</span> <span begin="2:18.562" end="2:19.171">like</span> <span begin="2:19.171" end="2:19.591">that?</span><span ttm:role="x-translation" xml:lang="zh-CN">为何我们不能像那样</span></p><p begin="2:19.848" end="2:25.105" itunes:key="L32" ttm:agent="v1"><span begin="2:19.848" end="2:20.131">&apos;Cause</span> <span begin="2:20.131" end="2:20.790">I&apos;m</span> <span begin="2:20.790" end="2:24.788">yours</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我属于你</span></p><p begin="2:25.105" end="2:29.079" itunes:key="L33" ttm:agent="v2"><span begin="2:25.105" end="2:25.240">And</span> <span begin="2:25.240" end="2:25.870">nobody</span> <span begin="2:25.870" end="2:26.536">knows</span> <span begin="2:26.721" end="2:26.886">I&apos;m</span> <span begin="2:26.886" end="2:27.044">in</span> <span begin="2:27.044" end="2:27.201">love</span> <span begin="2:27.201" end="2:27.359">with</span> <span begin="2:27.359" end="2:27.929">someone&apos;s</span> <span begin="2:27.929" end="2:28.881">baby</span><span ttm:role="x-translation" xml:lang="zh-CN">无人知晓我爱上了别人的爱人</span></p><p begin="2:29.079" end="2:31.643" itunes:key="L34" ttm:agent="v1"><span begin="2:29.079" end="2:29.250">I</span> <span begin="2:29.250" end="2:29.546">don&apos;t</span> <span begin="2:29.546" end="2:29.885">wanna</span> <span begin="2:29.885" end="2:30.203">hide</span> <span begin="2:30.203" end="2:30.511">us</span> <span begin="2:30.511" end="2:31.643">away</span><span ttm:role="x-translation" xml:lang="zh-CN">我不想再将我们隐藏</span></p><p begin="2:31.494" end="2:34.989" itunes:key="L35" ttm:agent="v2"><span begin="2:31.494" end="2:31.674">Tell</span> <span begin="2:31.674" end="2:31.847">the</span> <span begin="2:31.847" end="2:31.989">world</span> <span begin="2:31.989" end="2:32.289">about</span> <span begin="2:32.289" end="2:32.469">the</span> <span begin="2:32.469" end="2:32.739">love</span> <span begin="2:32.739" end="2:33.069">we&apos;re</span> <span begin="2:33.069" end="2:34.989">making</span><span ttm:role="x-translation" xml:lang="zh-CN">向世界宣告我们正在创造的爱</span></p><p begin="2:34.455" end="2:43.355" itunes:key="L36" ttm:agent="v1"><span begin="2:34.455" end="2:34.743">I&apos;m</span> <span begin="2:34.743" end="2:35.412">living</span> <span begin="2:35.412" end="2:35.683">for</span> <span 