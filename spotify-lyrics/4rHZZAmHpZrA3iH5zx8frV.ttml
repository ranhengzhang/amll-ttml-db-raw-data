translation" xml:lang="zh-CN">你只需坚强</span></p><p begin="1:00.730" end="1:03.060" itunes:key="L11" ttm:agent="v1"><span begin="1:00.730" end="1:00.840">&apos;Cau</span><span begin="1:00.840" end="1:00.890">se</span> <span begin="1:00.990" end="1:01.190">I</span> <span begin="1:01.190" end="1:01.390">don&apos;t</span> <span begin="1:01.390" end="1:01.560">want</span> <span begin="1:01.560" end="1:01.780">to</span> <span begin="1:01.780" end="1:02.120">lo</span><span begin="1:02.120" end="1:02.180">se</span> <span begin="1:02.180" end="1:02.250">you</span> <span begin="1:02.360" end="1:03.060">now</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我现在不想失去你</span></p><p begin="1:03.510" end="1:06.390" itunes:key="L12" ttm:agent="v1"><span begin="1:03.510" end="1:03.720">I&apos;m</span> <span begin="1:03.720" end="1:03.900">loo</span><span begin="1:03.900" end="1:04.120">king</span> <span begin="1:04.120" end="1:04.480">right</span> <span begin="1:04.480" end="1:04.590">at</span> <span begin="1:04.690" end="1:04.920">the</span> <span begin="1:04.920" end="1:05.280">o</span><span begin="1:05.280" end="1:05.380">ther</span> <span begin="1:05.490" end="1:05.670">hal</span><span begin="1:05.670" end="1:05.720">f</span> <span begin="1:05.720" end="1:05.780">of</span> <span begin="1:05.890" end="1:06.390">me</span><span ttm:role="x-translation" xml:lang="zh-CN">我正注视着我的另一半</span></p><p begin="1:07.030" end="1:09.360" itunes:key="L13" ttm:agent="v1"><span begin="1:07.030" end="1:07.120">The</span> <span begin="1:07.220" end="1:07.410">va</span><span begin="1:07.410" end="1:07.580">can</span><span begin="1:07.580" end="1:07.820">cy</span> <span begin="1:07.820" end="1:07.950">that</span> <span begin="1:07.950" end="1:08.210">sa</span><span begin="1:08.210" end="1:08.240">t</span> <span begin="1:08.240" end="1:08.390">in</span> <span begin="1:08.390" end="1:08.620">my</span> <span begin="1:08.620" end="1:09.360">heart</span><span ttm:role="x-translation" xml:lang="zh-CN">我心中曾