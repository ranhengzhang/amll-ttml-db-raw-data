.291" end="1:59.509">は</span><span begin="1:59.509" end="1:59.724">い</span><span begin="1:59.724" end="1:59.953">い</span><span begin="1:59.953" end="2:00.153">け</span><span begin="2:00.153" end="2:00.374">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">说是奇迹倒是好听</span><span ttm:role="x-roman">kiseki to i e ba ki koe ha ii kedo</span></p><p begin="2:00.605" end="2:03.935" itunes:key="L32" ttm:agent="v1"><span begin="2:00.605" end="2:00.825">そ</span><span begin="2:00.825" end="2:01.063">れ</span><span begin="2:01.063" end="2:01.279">は</span><span begin="2:01.279" end="2:01.541">き</span><span begin="2:01.541" end="2:01.621">っ</span><span begin="2:01.621" end="2:01.720">と</span><span begin="2:01.720" end="2:02.139">偶</span><span begin="2:02.139" end="2:02.606">然</span><span begin="2:02.606" end="2:02.789">に</span><span begin="2:02.789" end="2:03.057">す</span><span begin="2:03.057" end="2:03.278">ぎ</span><span begin="2:03.278" end="2:03.505">な</span><span begin="2:03.505" end="2:03.723">く</span><span begin="2:03.723" end="2:03.935">て</span><span ttm:role="x-translation" xml:lang="zh-CN">但肯定是一场偶然</span><span ttm:role="x-roman">sore ha kitto guuzen ni sugi naku te</span></p><p begin="2:04.170" end="2:07.506" itunes:key="L33" ttm:agent="v1"><span begin="2:04.170" end="2:04.508">や</span><span begin="2:04.508" end="2:04.587">っ</span><span begin="2:04.587" end="2:05.263">ぱ</span><span begin="2:05.263" end="2:05.503">り</span><span begin="2:05.503" end="2:05.721">意</span><span begin="2:05.721" end="2:05.943">味</span><span begin="2:05.943" end="2:06.181">な</span><span begin="2:06.181" end="2:06.357">ん</span><span begin="2:06.357" end="2:06.610">て</span><span begin="2:06.610" end="2:06.787">な</span><span begin="2:06.787" end="2:06.885">い</span><span begin="2:06.885" end="2:07.506">さ</span><span ttm:role="x-translation" xml:lang="zh-CN">根本没什么意义吧</span><span ttm:role="x-roman">yappari imi nante nai sa</span></p><p begin="2:07.673" end="2:14.560" itunes:key="L34" ttm:agent="v2"><span begin="2:07.673" end="2:07.932">で</span><span begin="2:07.932" end="2:08.229">も</span> <span begin="2:08.380" end="2:08.835">例</span><span begin="2:08.835" end="2:09.105">え</span><span begin="2:09.105" end="2:09.256">ば</span><span begin="2:09.256" end="2:09.726">君</span><span begin="2:09.726" end="2:10.071">に</span><span begin="2:10.071" end="2:10.154">い</span><span begin="2:10.154" end="2:10.410">じ</span><span begin="2:10.410" end="2:10.812">わ</span><span begin="2:10.812" end="2:11.264">る</span><span begin="2:11.264" end="2:11.401">を</span><span begin="2:11.401" end="2:11.731">す</span><span begin="2:11.731" end="2:12.618">る</span> <span begin="2:12.953" end="2:13.126">や</span><span begin="2:13.126" end="2:13.501">つ</span><span begin="2:13.501" end="2:14.560">が</span><span ttm:role="x-translation" xml:lang="zh-CN">但若有人欺负你</span><span ttm:role="x-roman">demo tato eba kimi ni iziwaru wo suru yatu ga</span></p><p begin="2:14.844" end="2:17.661" itunes:key="L35" ttm:agent="v2"><span begin="2:14.844" end="2:14.917">い</span><span begin="2:14.917" end="2:15.031">る</span><span begin="2:15.031" end="2:15.251">な</span><span begin="2:15.251" end="2:15.409">ら</span><span begin="2:15.409" end="2:15.717">そ</span><span begin="2:15.717" end="2:15.937">れ</span><span begin="2:15.937" end="2:16.174">は</span><span begin="2:16.174" end="2:16.611">君</span><span begin="2:16.611" end="2:16.824">が</span><span begin="2:16.824" end="2:17.109">と</span><span begin="2:17.109" end="2:17.269">っ</span><span begin="2:17.269" end="2:17.508">て</span><span begin="2:17.508" end="2:17.661">も</span><span ttm:role="x-translation" xml:lang="zh-CN">那就是在告诉你</span><span ttm:role="x-roman">iru nara sore ha kimi ga toxtu te mo</span></p><p begin="2:17.661" end="2:24.465" itunes:key="L36" ttm:agent="v2"><span begin="2:17.661" end="2:17.953">素</span><span begin="2:17.953" end="2:18.388">敵</span><span begin="2:18.388" end="2:18.559">な</span><span begin="2:18.559" end="2:19.057">人</span><span begin="2:19.057" end="2:19.556">だ</span><span begin="2:19.556" end="2:19.716">っ</span><span begin="2:19.716" end="2:20.145">て</span> <span begin="2:20.613" end="2:20.804">教</span><span begin="2:20.804" end="2:21.132">え</span><span begin="2:21.132" end="2:21.496">て</span><span begin="2:21.496" end="2:21.873">る</span><span begin="2:21.873" end="2:22.164">ん</span><span begin="2:22.164" end="2:22.399">だ</span><span begin="2:22.399" end="2:24.465">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">你是个超级大好人哦</span><span ttm:role="x-roman">suteki na hito datte osi e teru n da yo</span></p><p begin="2:24.701" end="2:26.147" itunes:key="L37" ttm:agent="v1"><span begin="2:24.701" end="2:25.281">そ</span><span begin="2:25.281" end="2:25.667">う</span><span begin="2:25.667" end="2:26.147">さ</span><span ttm:role="x-translation" xml:lang="zh-CN">是啊</span><span ttm:role="x-roman">sousa</span></p><p begin="2:26.147" end="2:27.948" itunes:key="L38" ttm:agent="v1"><span begin="2:26.147" end="2:26.604">神</span><span begin="2:26.604" end="2:26.939">の</span><span begin="2:26.939" end="2:27.060">ま</span><span begin="2:27.060" end="2:27.281">に</span><span begin="2:27.281" end="2:27.504">ま</span><span begin="2:27.504" end="2:27.948">に</span><span ttm:role="x-translation" xml:lang="zh-CN">随神之侧</span><span ttm:role="x-roman">kami no manimani</span></p><p begin="2:27.948" end="2:29.573" itunes:key="L39" ttm:agent="v1"><span begin="2:27.948" end="2:28.334">仰</span><span begin="2:28.334" end="2:28.713">せ</span><span begin="2:28.713" end="2:28.848">の</span><span begin="2:28.848" end="2:29.065">ま</span><span begin="2:29.065" end="2:29.286">ま</span><span begin="2:29.286" end="2:29.573">に</span><span ttm:role="x-translation" xml:lang="zh-CN">听神之命</span><span ttm:role="x-roman">oo se no mama ni</span></p><p begin="2:29.723" end="2:32.846" itunes:key="L40" ttm:agent="v1"><span begin="2:29.723" end="2:30.161">誰</span><span begin="2:30.161" end="2:30.424">だ</span><span begin="2:30.424" end="2:30.498">っ</span><span begin="2:30.498" end="2:30.604">て</span><span begin="2:30.604" end="2:30.827">地</span><span begin="2:30.827" end="2:31.273">球</span><span begin="2:31.273" end="2:31.503">を</span><span begin="2:31.503" end="2:31.881">愛</span><span begin="2:31.881" end="2:32.147">し</span><span begin="2:32.147" end="2:32.401">て</span><span begin="2:32.401" end="2:32.846">る</span><span ttm:role="x-translation" xml:lang="zh-CN">大家都深爱着地球</span><span ttm:role="x-roman">dare datte tikyuu wo ai si teru</span></p><p begin="2:33.278" end="2:35.022" itunes:key="L41" ttm:agent="v1"><span begin="2:33.278" end="2:33.733">僕</span><span begin="2:33.733" end="2:33.955">が</span><span begin="2:33.955" end="2:34.521">笑</span><span begin="2:34.521" end="2:34.600">っ</span><span begin="2:34.600" end="2:35.022">て</span><span ttm:role="x-translation" xml:lang="zh-CN">我欢笑</span><span ttm:role="x-roman">boku ga wara xtu te</span></p><p begin="2:35.022" end="2:36.833" itunes:key="L42" ttm:agent="v1"><span begin="2:35.022" end="2:35.506">君</span><span begin="2:35.506" end="2:35.844">も</span><span begin="2:35.844" end="2:36.166">笑</span><span begin="2:36.166" end="2:36.396">え</span><span begin="2:36.396" end="2:36.833">ば</span><span ttm:role="x-translation" xml:lang="zh-CN">如果你也欢笑</span><span ttm:role="x-roman">kun mo wara e ba</span></p><p begin="2:36.833" end="2:39.512" itunes:key="L43" ttm:agent="v1"><span begin="2:36.833" end="2:37.107">許</span><span begin="2:37.107" end="2:37.282">せ</span><span begin="2:37.282" end="2:37.511">な</span><span begin="2:37.511" end="2:37.720">い</span><span begin="2:37.720" end="2:37.949">こ</span><span begin="2:37.949" end="2:38.168">と</span><span begin="2:38.168" end="2:38.325">な</span><span begin="2:38.325" end="2:38.381">ん</span><span begin="2:38.381" end="2:38.618">て</span><span begin="2:38.618" end="2:38.837">な</span><span begin="2:38.837" end="2:39.061">い</span><span begin="2:39.061" end="2:39.512">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就没什么事情不可以原谅了</span><span ttm:role="x-roman">yuru se nai koto nante nai yo</span></p><p begin="2:39.666" end="2:40.298" itunes:key="L44" ttm:agent="v1"><span begin="2:39.666" end="2:39.971">そ</span><span begin="2:39.971" end="2:40.113">う</span><span begin="2:40.113" end="2:40.298">さ</span><span ttm:role="x-translation" xml:lang="zh-CN">是啊</span><span ttm:role="x-roman">sousa</span></p><p begin="2:40.298" end="2:42.132" itunes:key="L45" ttm:agent="v1"><span begin="2:40.298" end="2:40.775">男</span><span begin="2:40.775" end="2:41.105">も</span><span begin="2:41.105" end="2:41.667">女</span><span begin="2:41.667" end="2:42.132">も</span><span ttm:role="x-translation" xml:lang="zh-CN">无论男女</span><span ttm:role="x-roman">otoko mo onna mo</span></p><p begin="2:42.132" end="2:43.846" itunes:key="L46" ttm:agent="v1"><span begin="2:42.136" end="2:42.538">恋</span><span begin="2:42.538" end="2:42.940">し</span><span begin="2:42.940" end="2:43.075">か</span><span begin="2:43.075" end="2:43.284">る</span><span begin="2:43.284" end="2:43.468">べ</span><span begin="2:43.468" end="2:43.846">き</span><span ttm:role="x-translation" xml:lang="zh-CN">都当一场恋爱</span><span ttm:role="x-roman">koi sikarubeki</span></p><p begin="2:43.846" end="2:46.978" itunes:key="L47" ttm:agent="v1"><span begin="2:43.846" end="2:44.115">そ</span><span begin="2:44.115" end="2:44.195">ん</span><span begin="2:44.195" end="2:44.383">な</span><span begin="2:44.383" end="2:44.543">ふ</span><span begin="2:44.543" end="2:44.629">う</span><span begin="2:44.629" end="2:44.774">に</span><span begin="2:44.774" end="2:45.026">地</span><span begin="2:45.026" end="2:45.499">球</span><span begin="2:45.499" end="2:45.652">は</span><span begin="2:45.652" end="2:46.274">回</span><span begin="2:46.274" end="2:46.377">っ</span><span begin="2:46.377" end="2:46.606">て</span><span begin="2:46.606" end="2:46.978">る</span><span ttm:role="x-translation" xml:lang="zh-CN">地球就是这样转起来的</span><span ttm:role="x-roman">sonna huu ni tikyuu ha mawa xtu teru</span></p><p begin="2:47.493" end="2:51.058" itunes:key="L48" ttm:agent="v1"><span begin="2:47.493" end="2:47.730">ど</span><span begin="2:47.730" end="2:47.935">ろ</span><span begin="2:47.935" end="2:48.195">ん</span><span begin="2:48.195" end="2:48.413">こ</span><span begin="2:48.413" end="2:48.610">だ</span><span begin="2:48.610" end="2:48.839">け</span><span begin="2:48.839" end="2:49.057">ど</span> <span begin="2:49.213" end="2:49.743">歩</span><span begin="2:49.743" end="2:49.959">い</span><span begin="2:49.959" end="2:50.166">て</span><span begin="2:50.166" end="2:50.399">い</span><span begin="2:50.399" end="2:50.637">こ</span><span begin="2:50.637" end="2:51.058">う</span><span ttm:role="x-translation" xml:lang="zh-CN">即使满身污泥 也能前行无阻</span><span ttm:role="x-roman">doronko da kedo aru i te iko u</span></p><p begin="2:51.058" end="2:53.769" itunes:key="L49" ttm:agent="v1"><span begin="2:51.058" end="2:51.381">ま</span><span begin="2:51.381" end="2:51.499">だ</span><span begin="2:51.499" end="2:51.821">ま</span><span begin="2:51.821" end="2:51.901">だ</span><span begin="2:51.901" end="2:52.389">先</span><span begin="2:52.389" end="2:52.639">は</span><span begin="2:52.639" end="2:53.058">長</span><span begin="2:53.058" end="2:53.234">い</span><span begin="2:53.234" end="2:53.769">さ</span><span ttm:role="x-translation" xml:lang="zh-CN">未来还有很长的路要走</span><span ttm:role="x-roman">mada mada saki ha naga i sa</span></p><p begin="2:53.929" end="2:57.273" itunes:key="L50" ttm:agent="v2"><span begin="2:53.929" end="2:54.342">本</span><span begin="2:54.342" end="2:54.653">当</span><span begin="2:54.653" end="2:55.043">に</span><span begin="2:55.043" end="2:55.473">大</span><span begin="2:55.473" end="2:55.732">事</span><span begin="2:55.732" end="2:55.950">な</span><span begin="2:55.950" end="2:56.192">も</span><span begin="2:56.192" end="2:56.632">の</span><span begin="2:56.632" end="2:56.834">な</span><span begin="2:56.834" end="2:57.041">ん</span><span begin="2:57.041" end="2:57.273">て</span><span ttm:role="x-translation" xml:lang="zh-CN">其实珍贵的事情意外地</span><span ttm:role="x-roman">hontou ni daizi na mono nante</span></p><p begin="2:57.505" end="3:02.319" itunes:key="L51" ttm:agent="v2"><span begin="2:57.505" end="2:57.726">案</span><span begin="2:57.726" end="2:58.163">外</span><span begin="2:58.163" end="2:58.508">く</span><span begin="2:58.508" end="2:58.626">だ</span><span begin="2:58.626" end="2:58.844">ら</span><span begin="2:58.844" end="2:59.064">な</span><span begin="2:59.064" end="2:59.294">い</span><span begin="2:59.294" end="2:59.503">こ</span><span begin="2:59.503" end="2:59.732">と</span><span begin="2:59.732" end="3:00.174">の</span><span begin="3:00.174" end="3:00.616">中</span><span begin="3:00.616" end="3:01.063">に</span><span begin="3:01.063" end="3:01.283">あ</span><span begin="3:01.283" end="3:01.483">る</span><span begin="3:01.483" end="3:02.319">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就存在于无聊的琐事中</span><span ttm:role="x-roman">angai kudaranai koto no naka ni aru yo</span></p><p begin="3:01.708" end="3:04.445" itunes:key="L52" ttm:agent="v1"><span begin="3:01.708" end="3:01.945">と</span><span begin="3:01.945" end="3:02.167">き</span><span begin="3:02.167" end="3:02.389">に</span><span begin="3:02.389" end="3:02.607">は</span><span begin="3:02.607" end="3:02.755">み</span><span begin="3:02.755" end="3:02.835">ん</span><span begin="3:02.835" end="3:03.061">な</span><span begin="3:03.061" end="3:03.295">で</span><span begin="3:03.295" end="3:03.719">馬</span><span begin="3:03.719" end="3:03.859">鹿</span><span begin="3:03.859" end="3:04.175">騒</span><span begin="3:04.175" end="3:04.445">ぎ</span><span ttm:role="x-translation" xml:lang="zh-CN">有时候大家就来大闹一场</span><span ttm:role="x-roman">toki ni ha minna de bakasawa gi</span></p><p begin="3:04.594" end="3:10.597" itunes:key="L53" ttm:agent="v1"><span begin="3:04.594" end="3:05.269">裸</span><span begin="3:05.269" end="3:05.966">踊</span><span begin="3:05.966" end="3:06.404">り</span><span begin="3:06.404" end="3:07.055">で</span> <spa