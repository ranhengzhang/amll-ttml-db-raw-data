<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Diana Caroline Garnett</songwriter><songwriter>pftq</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="In Another Story"/><amll:meta key="artists" value="Autodidactic Studios"/><amll:meta key="artists" value="Diana Garnett"/><amll:meta key="artists" value="Lappy"/><amll:meta key="artists" value="Jon Babb"/><amll:meta key="artists" value="pftq"/><amll:meta key="artists" value="Waterflame"/><amll:meta key="album" value="In Another Story (From &quot;Millenium Idol&quot;)"/><amll:meta key="appleMusicId" value="1834726233"/><amll:meta key="ncmMusicId" value="2662122821"/><amll:meta key="ttmlAuthorGithub" value="42886855"/><amll:meta key="ttmlAuthorGithubLogin" value="ArSrNa"/></metadata></head><body dur="4:04.340"><div begin="14.381" end="4:04.340"><p begin="14.381" end="16.747" itunes:key="L1" ttm:agent="v1"><span begin="14.381" end="15.030">From</span> <span begin="15.030" end="15.187">the</span> <span begin="15.187" end="15.328">sha</span><span begin="15.328" end="16.747">dows</span><span ttm:role="x-translation" xml:lang="zh-CN">从阴影之中</span></p><p begin="17.314" end="19.383" itunes:key="L2" ttm:agent="v1"><span begin="17.314" end="17.544">A</span> <span begin="17.544" end="18.365">guiding</span> <span begin="18.365" end="19.383">voice</span><span ttm:role="x-translation" xml:lang="zh-CN">传来指引的声音</span></p><p begin="20.797" end="23.265" itunes:key="L3" ttm:agent="v1"><span begin="20.797" end="21.349">From</span> <span begin="21.349" end="21.557">the</span> <span begin="21.557" end="21.865">dark</span><span begin="21.865" end="23.265">ness</span><span ttm:role="x-translation" xml:lang="zh-CN">黑暗深处</span></p><p begin="24.034" end="26.744" itunes:key="L4" ttm:agent="v1"><span begin="24.034" end="24.221">Stars</span> <span begin="24.221" end="24.884">are</span> <span begin="24.884" end="26.744">born</span><span ttm:role="x-translation" xml:lang="zh-CN">万千星辰生起</span></p><p begin="27.158" end="30.087" itunes:key="L5" ttm:agent="v1"><span begin="27.158" end="27.773">Far</span> <span begin="27.773" end="27.974">be</span><span begin="27.974" end="28.377">yond</span> <span begin="28.377" end="28.760">the</span> <span begin="28.760" end="29.147">hea</span><span begin="29.147" end="30.087">vens</span><span ttm:role="x-translation" xml:lang="zh-CN">遥望苍穹</span></p><p begin="30.332" end="33.277" itunes:key="L6" ttm:agent="v1"><span begin="30.332" end="31.154">Sear</span><span begin="31.154" end="31.519">ching</span> <span begin="31.519" end="31.973">for</span> <span begin="31.973" end="32.395">my</span> <span begin="32.395" end="33.277">way</span><span ttm:role="x-translation" xml:lang="zh-CN">寻找属于我的前路</span></p><p begin="33.533" end="36.102" itunes:key="L7" ttm:agent="v1"><span begin="33.533" end="34.244">Strai</span><span begin="34.244" end="34.813">ning</span> <span begin="34.813" end="35.189">through</span> <span begin="35.189" end="35.607">dark</span><span begin="35.607" end="36.102">ness</span><span ttm:role="x-translation" xml:lang="zh-CN">穿过无尽黑暗</span></p><p begin="36.279" end="39.064" itunes:key="L8" ttm:agent="v1"><span begin="36.279" end="37.423">To</span> <span begin="37.423" end="39.064">see</span><span ttm:role="x-translation" xml:lang="zh-CN">去寻找</span></p><p begin="39.285" end="41.357" itunes:key="L9" ttm:agent="v1"><span begin="39.285" end="39.610">Break</span> <span begin="39.610" end="40.178">off</span> <span begin="40.178" end="40.359">those</span> <span begin="40.359" end="40.772">old</span> <span begin="40.772" end="41.357">chains</span><span ttm:role="x-translation" xml:lang="zh-CN">打破旧枷锁</span></p><p begin="41.568" end="43.733" itunes:key="L10" ttm:agent="v1"><span begin="41.568" end="42.523">Daring</span> <span begin="42.523" end="42.821">a</span> <span begin="42.821" end="43.209">first</span> <span begin="43.209" end="43.733">step</span><span ttm:role="x-translation" xml:lang="zh-CN">迈出勇敢的第一步</span></p><p begin="43.929" end="46.133" itunes:key="L11" ttm:agent="v1"><span begin="43.929" end="44.615">Finger</span><span begin="44.615" end="45.072">tips</span> <span begin="45.072" end="46.133">trembling</span><span ttm:role="x-translation" xml:lang="zh-CN">指尖颤抖</span></p><p begin="46.453" end="48.523" itunes:key="L12" ttm:agent="v1"><span begin="46.453" end="46.708">Out</span><span begin="46.708" end="47.429">stretched</span> <span begin="47.429" end="47.796">before</span> <span begin="47.796" end="48.523">me</span><span ttm:role="x-translation" xml:lang="zh-CN">伸向远处</span></p><p begin="48.709" end="51.146" itunes:key="L13" ttm:agent="v1"><span begin="48.709" end="49.522">Tracing</span> <span begin="49.522" end="49.919">the</span> <span begin="49.919" end="51.146">way</span><span ttm:role="x-translation" xml:lang="zh-CN">沿着足迹</span></p><p begin="51.146" end="54.412" itunes:key="L14" ttm:agent="v1"><span begin="51.146" end="51.895">Feeling</span> <span begin="51.895" end="52.346">a</span> <span begin="52.346" end="53.554">warm</span> <span begin="53.554" end="54.412">breeze</span><span ttm:role="x-translation" xml:lang="zh-CN">感受暖风吹拂</span></p><p begin="54.412" end="55.829" itunes:key="L15" ttm:agent="v1"><span begin="54.412" end="54.681">I&apos;ll</span> <span begin="54.681" end="55.075">break</span> <span begin="55.075" end="55.829">free</span><span ttm:role="x-translation" xml:lang="zh-CN">我将破茧而出</span></p><p begin="55.829" end="59.688" itunes:key="L16" ttm:agent="v1"><span begin="55.829" end="55.999">I&apos;ll</span> <span begin="55.999" end="56.365">stand</span> <span begin="56.365" end="56.797">firm</span> <span begin="56.797" end="57.222">for</span> <span begin="57.222" end="58.442">my</span> <span begin="58.442" end="59.688">dream</span><span ttm:role="x-translation" xml:lang="zh-CN">坚定不移为我的梦想前进</span></p><p begin="1:00.019" end="1:02.789" itunes:key="L17" ttm:agent="v1"><span begin="1:00.019" end="1:00.293">In</span> <span begin="1:00.293" end="1:01.142">another</span> <span begin="1:01.142" end="1:02.789">story</span><span ttm:role="x-translation" xml:lang="zh-CN">在另一段故事</span></p><p begin="1:03.194" end="1:06.872" itunes:key="L18" ttm:agent="v1"><span begin="1:03.194" end="1:03.389">In</span> <span begin="1:03.389" end="1:04.370">another</span> <span begin="1:04.370" end="1:04.783">life</span> <span begin="1:04.783" end="1:04.931">I</span> <span begin="1:04.931" end="1:05.356">could</span> <span begin="1:05.356" end="1:05.697">be</span> <span begin="1:05.697" end="1:06.872">free</span><span ttm:role="x-translation" xml:lang="zh-CN">另一种人生</span><span ttm:role="x-bg" begin="1:06.131" end="1:06.872"><span begin="1:06.131" end="1:06.341">(I</span> <span begin="1:06.341" end="1:06.555">could</span> <span begin="1:06.555" end="1:06.872">be)</span><span ttm:role="x-translation" xml:lang="zh-CN">我可以</span></span></p><p begin="1:06.872" end="1:09.215" itunes:key="L19" ttm:agent="v1"><span begin="1:06.872" end="1:07.039">I</span> <span begin="1:07.039" end="1:07.207">could</span> <span begin="1:07.207" end="1:07.394">soar</span> <span begin="1:07.394" end="1:07.632">to</span> <span begin="1:07.632" end="1:08.171">greater</span> <span begin="1:08.171" end="1:09.215">heights</span><span ttm:role="x-translation" xml:lang="zh-CN">翱翔更高的天空</span></p><p begin="1:09.470" end="1:11.964" itunes:key="L20" ttm:agent="v1"><span begin="1:09.470" end="1:09.656">Past</span> <span begin="1:09.656" end="1:09.942">the</span> <span begin="1:09.942" end="1:10.774">shadow&apos;s</span> <span begin="1:10.774" end="1:11.964">hold</span><span ttm:role="x-translation" xml:lang="zh-CN">越过阴影的束缚</span></p><p begin="1:12.117" end="1:15.758" itunes:key="L21" ttm:agent="v1"><span begin="1:12.117" end="1:12.737">Pave</span> <span begin="1:12.737" end="1:13.192">our</span> <span begin="1:13.192" end="1:13.568">way</span> <span begin="1:13.568" end="1:13.968">with</span> <span begin="1:13.968" end="1:14.536">dia</span><span begin="1:14.536" end="1:15.059">monds</span> <span begin="1:15.059" end="1:15.344">of</span> <span begin="1:15.344" end="1:15.758">light</span><span ttm:role="x-translation" xml:lang="zh-CN">铺下钻石般闪耀的路途</span></p><p begin="1:15.758" end="1:16.942" itunes:key="L22" ttm:agent="v1"><span begin="1:15.758" end="1:15.987">I&apos;ll</span> <span begin="1:15.987" end="1:16.158">take</span> <span begin="1:16.158" end="1:16.457">you</span> <span begin="1:16.457" end="1:16.942">anywhere</span><span ttm:role="x-translation" xml:lang="zh-CN">我会带你去往任何地方</span></p><p begin="1:16.942" end="1:18.920" itunes:key="L23" ttm:agent="v1"><span begin="1:16.942" end="1:17.137">With</span> <span begin="1:17.137" end="1:17.819">you,</span><span begin="1:17.819" end="1:18.211">I</span> <span begin="1:18.211" end="1:18.590">don&apos;t</span> <span begin="1:18.590" end="1:18.920">care</span><span ttm:role="x-translation" xml:lang="zh-CN">有你在身旁</span></p><p begin="1:18.920" end="1:20.824" itunes:key="L24" ttm:agent="v1"><span begin="1:18.920" end="1:19.123">We&apos;ll</span> <span begin="1:19.123" end="1:19.960">overcome</span> <span begin="1:19.960" end="1:20.377">this</span> <span begin="1:20.377" end="1:20.824">fate</span><span ttm:role="x-translation" xml:lang="zh-CN">磨难也无妨</span></p><p begin="1:20.824" end="1:22.368" itunes:key="L25" ttm:agent="v2"><span begin="1:20.824" end="1:21.197">Just</span> <span begin="1:21.197" end="1:21.386">come</span> <span begin="1:21.386" end="1:21.579">take</span> <span begin="1:21.579" end="1:21.817">my</span> <span begin="1:21.817" end="1:22.368">hand</span><span ttm:role="x-translation" xml:lang="zh-CN">来吧，握紧我的手</span></p><p begin="1:22.368" end="1:24.935" itunes:key="L26" ttm:agent="v1"><span begin="1:22.368" end="1:22.555">Do</span> <span begin="1:22.555" end="1:22.811">you</span> <span begin="1:22.811" end="1:23.209">dare</span> <span begin="1:23.209" end="1:23.594">to</span> <span begin="1:23.594" end="1:24.935">dream?</span><span ttm:role="x-translation" xml:lang="zh-CN">你敢去梦想吗？</span></p><p begin="1:25.486" end="1:27.567" itunes:key="L27" ttm:agent="v1"><span begin="1:25.486" end="1:25.662">Do</span> <span begin="1:25.662" end="1:25.865">you</span> <span begin="1:25.865" end="1:26.132">dare</span> <span begin="1:26.132" end="1:26.516">to</span> <span begin="1:26.516" end="1:27.567">believe?</span><span ttm:role="x-translation" xml:lang="zh-CN">你敢去相信吗？</span></p><p begin="1:39.931" end="1:42.486" itunes:key="L28" ttm:agent="v1"><span begin="1:39.931" end="1:40.283">Winding</span> <span begin="1:40.283" end="1:40.560">roads</span> <span begin="1:40.560" end="1:42.259">illuminated</span> <span begin="1:42.259" end="1:42.486">by</span><span ttm:role="x-translation" xml:lang="zh-CN">蜿蜒的小路被点亮</span></p><p begin="1:42.486" end="1:45.934" itunes:key="L29" ttm:agent="v1"><span begin="1:42.486" end="1:43.215">Il</span><span begin="1:43.215" end="1:43.853">lusions</span> <span begin="1:43.853" end="1:44.070">so</span> <span begin="1:44.070" end="1:44.552">thin,</span><span begin="1:44.552" end="1:45.099">so</span> <span begin="1:45.099" end="1:45.934">flimsy</span><span ttm:role="x-translation" xml:lang="zh-CN">如此虚幻，如此渺茫</span></p><p begin="1:45.997" end="1:47.502" itunes:key="L30" ttm:agent="v2"><span begin="1:45.997" end="1:46.266">Breath</span> <span begin="1:46.266" end="1:46.763">in,</span><span begin="1:46.763" end="1:46.913">stand</span> <span begin="1:46.913" end="1:47.502">up</span><span ttm:role="x-translation" xml:lang="zh-CN">深呼吸，站起来</span></p><p begin="1:47.214" end="1:48.504" itunes:key="L31" ttm:agent="v1"><span begin="1:47.214" end="1:47.392">Step</span> <span begin="1:47.392" end="1:48.504">forth</span><span ttm:role="x-translation" xml:lang="zh-CN">继续前行</span></p><p begin="1:48.504" end="1:50.008" itunes:key="L32" ttm:agent="v2"><span begin="1:48.504" end="1:48.680">Don&apos;t</span> <span begin="1:48.680" end="1:49.230">waver,</span><span begin="1:49.230" end="1:49.371">stay</span> <span begin="1:49.371" end="1:50.008">firm</span><span ttm:role="x-translation" xml:lang="zh-CN">别犹豫，要坚定</span></p><p begin="1:50.008" end="1:52.451" itunes:key="L33" ttm:agent="v1"><span begin="1:50.008" end="1:50.171">Maybe</span> <span begin="1:50.171" end="1:50.426">the</span> <span begin="1:50.426" end="1:51.279">future&apos;s</span> <span begin="1:51.279" end="1:51.739">blank</span> <span begin="1:51.739" end="1:51.920">for</span> <span begin="1:51.920" end="1:52.088">now</span> <span begin="1:52.088" end="1:52.451">but</span><span ttm:role="x-translation" xml:lang="zh-CN">也许未来现在还一片空白</span></p><p begin="1:52.451" end="1:53.821" itunes:key="L34" ttm:agent="v2"><span begin="1:52.451" end="1:52.638">Keep</span> <span begin="1:52.638" end="1:53.243">on,</span> <span begin="1:53.243" end="1:53.400">I</span> <span begin="1:53.400" end="1:53.821">know</span><span ttm:role="x-translation" xml:lang="zh-CN">继续，我知道</span></p><p begin="1:53.672" end="1:55.217" itunes:key="L35" ttm:agent="v1"><span begin="1:53.672" end="1:53.880">You&apos;ll</span> <span begin="1:53.880" end="1:55.217">see</span><span ttm:role="x-translation" xml:lang="zh-CN">你会看到</span></p><p begin="1:55.104" end="1:56.017" itunes:key="L36" ttm:agent="v2"><span begin="1:55.104" end="1:55.243">You</span> <span begin="1:55.243" end="1:55.399">and</span> <span begin="1:55.399" end="1:56.017">me</span><span ttm:role="x-translation" xml:lang="zh-CN">我和你</span></p><p begin="1:56.451" end="1:57.774" itunes:key="L37" ttm:agent="v1"><span begin="1:56.451" end="1:56.618">All</span> <span begin="1:56.618" end="1:56.804">that</span> <span begin="1:56.804" end="1:57.027">we</span> <span begin="1:57.027" end="1:57.457">need</span> <span begin="1:57.457" end="1:57.610">is</span> <span begin="1:57.610" end="1:57.774">just</span><span ttm:role="x-translation" xml:lang="zh-CN">我们所需要的只是</span></p><p begin="1:57.774" end="1:59.915" itunes:key="L38" ttm:agent="v1"><span begin="1:57.774" end="1:58.804">Another</span> <span begin="1:58.804" end="1:59.915">story</span><span ttm:role="x-translation" xml:lang="zh-CN">另一段故事</span></p><p begin="2:00.793" end="2:02.634" itunes:key="L39" ttm:agent="v1"><span begin="2:00.793" end="2:01.068">In</span> <span begin="2:01.068" end="2:01.975">another</span> <span begin="2:01.975" end="2:02.634">life</span><span ttm:role="x-translation" xml:lang="zh-CN">另一种人生</span></p><p begin="2:04.391" end="2:06.706" itunes:key="L40" ttm:agent="v1"><span begin="2:04.391" end="2:04.615">I</span> <span begin="2:04.615" end="2:04.789">could</span> <span begin="2:04.789" end="2:05.022">be</span> <span begin="2:05.022" end="2:05.219">the</span> <span begin="2:05.219" end="2:05.793">truest</span> <span begin="2:05.793" end="2:06.706">me</span><span ttm:role="x-translation" xml:lang="zh-CN">我可以做最真实的自己</span></p><p begin="2:07.210" end="2:09.439" itunes:key="L41" ttm:agent="v1"><span begin="2:07.210" end="2:07.383">I</span> <span begin="2:07.383" end="2:07.599">could</span> <span begin="2:07.599" end="2:08.021">be</span> <span begin="2:08.021" end="2:08.447">just</span> <span begin="2:08.447" end="2:09.439">me</span><span ttm:role="x-translation" xml:lang="zh-CN">做我自己</span></p><p begin="2:09.723" end="2:13.428" itunes:key="L42" ttm:agent="v1"><span begin="2:09.723" end="2:10.158">I</span> <span begin="2:10.158" end="2:10.386">could</span> <span begin="2:10.386" end="2:10.538">feel</span> <span begin="2:10.538" end="2:10.751">the</span> <span begin="2:10.751" end="2:11.237">grass</span> <span begin="2:11.237" end="2:11.559">be</span><span begin="2:11.559" end="2:12.234">neath</span> <span begin="2:12.234" end="2:12.622">my</span> <span begin="2:12.622" end="2:12.980">two</span> <span begin="2:12.980" end="2:13.428">feet</span><span ttm:role="x-translation" xml:lang="zh-CN">脚踩坚实的大地</span></p><p begin="2:13.428" end="2:15.317" itunes:key="L43" ttm:agent="v1"><span begin="2:13.428" end="2:13.690">Running,</span><span begin="2:13.690" end="2:13.866">the</span> <span begin="2:13.866" end="2:14.108">wind</span> <span begin="2:14.108" end="2:14.559">against</span> <span begin="2:14.559" end="2:14.749">my</span> <span begin="2:14.749" end="2:15.317">face</span><span ttm:role="x-translation" xml:lang="zh-CN">奔跑，感受风掠过脸颊的气息</span></p><p begin="2:15.317" end="2:17.069" itunes:key="L44" ttm:agent="v1"><span begin="2:15.317" end="2:15.624">Flushed</span> <span begin="2:15.624" end="2:15.942">cheeks,</span><span begin="2:15.942" end="2:16.760">stinging</span> <span begin="2:16.760" end="2:17.069">breath</span><span ttm:role="x-translation" xml:lang="zh-CN">双颊绯红，肺中刺痛</span></p><p begin="2:17.069" end="2:23.086" itunes:key="L45" ttm:agent="v1"><span begin="2:17.069" end="2:17.203">Can&apos;t</span> <span begin="2:17.203" end="2:17.414">stop</span> <span begin="2:17.414" end="2:17.877">for</span> <span begin="2:17.877" end="2:19.229">air,</span><span begin="2:19.229" end="2:20.912">I&apos;m</span> <span begin="2:20.912" end="2:23.086">free</span><span ttm:role="x-translation" xml:lang="zh-CN">但无需停下，我感到自由</span></p><p begin="2:23.086" end="2:24.616" itunes:key="L46" ttm:agent="v1"><span begin="2:23.086" end="2:23.240">Please</span> <span begin="2:23.240" end="2:23.456">don&apos;t</span> <span begin="2:23.456" end="2:23.634">stop</span> <span begin="2:23.634" end="2:23.896">me</span> <span begin="2:23.896" end="2:24.616">now</span><span ttm:role="x-translation" xml:lang="zh-CN">请不要阻止我</span></p><p begin="2:31.075" end="2:32.562" itunes:key="L47" ttm:agent="v1"><span begin="2:31.075" end="2:31.206">I</span> <span begin="2:31.206" end="2:31.348">know</span> <span begin="2:31.348" end="2:31.525">I&apos;ll</span> <span begin="2:31.525" end="2:31.695">stay</span> <span begin="2:31.695" end="2:32.562">firm</span><span ttm:role