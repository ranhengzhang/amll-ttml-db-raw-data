<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="en"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="希望有羽毛和翅膀"/><amll:meta key="musicName" value="翼の生えた希望"/><amll:meta key="musicName" value="희망은 날개 달린 것"/><amll:meta key="musicName" value="Hope Is the Thing With Feathers"/><amll:meta key="artists" value="HOYO-MiX"/><amll:meta key="artists" value="知更鸟"/><amll:meta key="artists" value="ロビン"/><amll:meta key="artists" value="로빈"/><amll:meta key="artists" value="Robin"/><amll:meta key="artists" value="知更鳥"/><amll:meta key="artists" value="Chevy"/><amll:meta key="album" value="崩坏星穹铁道-空气蛹 INSIDE"/><amll:meta key="album" value="空氣蛹"/><amll:meta key="album" value="INSIDE"/><amll:meta key="album" value="空气蛹 - EP"/><amll:meta key="album" value="空氣蛹 - EP"/><amll:meta key="album" value="INSIDE - EP"/><amll:meta key="ncmMusicId" value="2155423468"/><amll:meta key="qqMusicId" value="004ArOCZ13Lvqo"/><amll:meta key="qqMusicId" value="486451866"/><amll:meta key="spotifyId" value="5qUugiu7azqYib9CltE38F"/><amll:meta key="spotifyId" value="3qunIyd5S2uHBBOTY1lPN9"/><amll:meta key="spotifyId" value="0dCZCsCFG2ptrUJIdhLq9c"/><amll:meta key="spotifyId" value="3FUaNR2HD1XaeOmw4puhkz"/><amll:meta key="appleMusicId" value="1744862744"/><amll:meta key="appleMusicId" value="1744861544"/><amll:meta key="appleMusicId" value="1744865461"/><amll:meta key="appleMusicId" value="1744860814"/><amll:meta key="appleMusicId" value="1744859069"/><amll:meta key="isrc" value="QM6N22420271"/><amll:meta key="isrc" value="QM6N22421955"/><amll:meta key="isrc" value="QM6N22422282"/><amll:meta key="isrc" value="QM6N22422309"/><amll:meta key="isrc" value="QM6N22421995"/><amll:meta key="Arranger" value="王可鑫"/><amll:meta key="Composer" value="王可鑫"/><amll:meta key="Lead Vocals" value="Chevy"/><amll:meta key="Lyrics" value="Ruby Qu"/><amll:meta key="Mastering Engineer" value="宫奇"/><amll:meta key="Mixing Engineer" value="阿烈"/><amll:meta key="Performer" value="知更鸟"/><amll:meta key="Performer" value="HOYO-MiX"/><amll:meta key="Performer" value="王可鑫"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">随着命运的展开 就让我们一同迎战</text><text for="L2">而考验尚未结束 我们仍需直面黑暗</text><text for="L3">穿过绝望的阴影</text><text for="L4">在沉默中 我们共享希望</text><text for="L5">只为追逐我们宣告中的理想</text><text for="L6">我们曾尝试多看一眼</text><text for="L7">却被无知蒙蔽了视线</text><text for="L8">既然听不懂他们的注解</text><text for="L9">那就由我们找寻自己该走的路</text><text for="L10">请注意 命运的车轮正在转动</text><text for="L11">跨越平原 穿过深谷</text><text for="L12">向着黎明 这车轮行滚滚而行歌唱着</text><text for="L13">一个无尽的梦</text><text for="L14">请注意 轨道已然在运转</text><text for="L15">穿过阴霾藏匿的平原</text><text for="L16">我们奔跑 我们向前</text><text for="L17">面对恐惧和困境 我们依然坚守阵地</text><text for="L18">历久弥坚 胜利定会在望</text><text for="L19">我们已穿越风雨</text><text for="L20">只希望能沐浴在真理的光芒中</text><text for="L21">挣脱枷锁 重获新生</text><text for="L22">请注意 命运的车轮正在转动</text><text for="L23">跨越平原 穿过深谷</text><text for="L24">向着黎明 这车轮行滚滚而行歌唱着</text><text for="L25">一个无尽的梦</text><text for="L26">请注意 轨道已然在运转</text><text for="L27">穿过阴霾藏匿的平原</text><text for="L28">我们奔跑 我们向前</text><text for="L29">抬起头 跟着坚定的节奏</text><text for="L30">终点已近在咫尺</text><text for="L31">迈向我们的理想之地</text><text for="L32">让一切重见曙光</text><text for="L33">请注意 命运的车轮正在歌唱</text><text for="L34">他们保守着苦痛的秘密和私语</text><text for="L35">而我们终将迎来希望</text><text for="L36">挣脱束缚 我们在星空下追逐梦想</text><text for="L37">面对神灵 我们团结一致 奋勇向前</text></translation></translations><songwriters><songwriter>Ruby Qu</songwriter><songwriter>王可鑫</songwriter></songwriters><transliterations/></iTunesMetadata></metadata></head><body dur="3:43.600"><div begin="15.760" end="43.970" itu