an begin="49.122" end="49.362" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="49.362" end="49.632" xmlns="http://www.w3.org/ns/ttml">ka</span> <span begin="49.632" end="50.112" xmlns="http://www.w3.org/ns/ttml">na</span></text><text for="L9"><span begin="50.632" end="50.782" xmlns="http://www.w3.org/ns/ttml">wa</span> <span begin="50.782" end="50.922" xmlns="http://www.w3.org/ns/ttml">ka</span> <span begin="50.922" end="51.022" xmlns="http://www.w3.org/ns/ttml">t</span><span begin="51.022" end="51.232" xmlns="http://www.w3.org/ns/ttml">te</span> <span begin="51.232" end="51.362" xmlns="http://www.w3.org/ns/ttml">ta</span> <span begin="51.362" end="51.622" xmlns="http://www.w3.org/ns/ttml">yo</span> <span begin="51.722" end="52.302" xmlns="http://www.w3.org/ns/ttml">ko ko ro</span> <span begin="52.302" end="52.522" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="52.672" end="53.042" xmlns="http://www.w3.org/ns/ttml">o ku</span> <span begin="53.042" end="53.562" xmlns="http://www.w3.org/ns/ttml">so ko</span> <span begin="53.562" end="53.732" xmlns="http://www.w3.org/ns/ttml">de</span> <span begin="53.832" end="54.202" xmlns="http://www.w3.org/ns/ttml">wa</span></text><text for="L10"><span begin="54.492" end="55.122" xmlns="http://www.w3.org/ns/ttml">mo tto</span> <span begin="55.122" end="55.442" xmlns="http://www.w3.org/ns/ttml">mo</span> <span begin="55.442" end="55.932" xmlns="http://www.w3.org/ns/ttml">tsu ra</span> <span begin="55.932" end="56.012" xmlns="http://www.w3.org/ns/ttml">i</span> <span begin="56.012" end="56.382" xmlns="http://www.w3.org/ns/ttml">sen</span> <span begin="56.382" end="56.842" xmlns="http://www.w3.org/ns/ttml">ta ku</span> <span begin="56.842" end="56.992" xmlns="http://www.w3.org/ns/ttml">ga</span> <span begin="56.992" end="57.192" xmlns="http://www.w3.org/ns/ttml">be</span> <span begin="57.192" end="57.572" xmlns="http://www.w3.org/ns/ttml">su</span> <span begin="57.572" end="57.952" xmlns="http://www.w3.org/ns/ttml">