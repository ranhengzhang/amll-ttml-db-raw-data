<tt xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><amll:meta key="musicName" value="飴色"/><amll:meta key="artists" value="DOLLCHESTRA"/><amll:meta key="artists" value="村野さやか"/><amll:meta key="artists" value="村野沙耶香"/><amll:meta key="artists" value="Murano Sayaka"/><amll:meta key="artists" value="夕霧綴理"/><amll:meta key="artists" value="夕雾缀理"/><amll:meta key="artists" value="Yugiri Tsuzuri"/><amll:meta key="album" value="Take It Over"/><amll:meta key="ttmlAuthorGithub" value="86943191"/><amll:meta key="ttmlAuthorGithubLogin" value="bywhite0"/><amll:meta key="ncmMusicId" value="2104657102"/><amll:meta key="qqMusicId" value="452228180"/><amll:meta key="qqMusicId" value="004bQgJf3duAa1"/><amll:meta key="spotifyId" value="5wG3EbyjAxwuYDhiQSIfq1"/><amll:meta key="appleMusicId" value="1713350723"/><amll:meta key="isrc" value="JPI102203257"/></metadata></head><body dur="02:59.894"><div begin="00:00.926" end="02:59.894"><p begin="00:00.926" end="00:04.269" ttm:agent="v1" itunes:key="L1"><span begin="00:00.926" end="00:01.404">色</span><span begin="00:01.404" end="00:01.750">の</span><span begin="00:01.883" end="00:02.058">褪</span><span begin="00:02.058" end="00:02.361">せ</span><span begin="00:02.361" end="00:02.600">た</span><span begin="00:02.600" end="00:03.077">帰</span><span begin="00:03.077" end="00:03.409">り</span><span begin="00:03.549" end="00:04.269">道</span><span ttm:role="x-translation" xml:lang="zh-CN">归途中 风景失去色彩</span><span ttm:role="x-roman">i ro no a se ta ka e ri mi chi</span></p><p begin="00:04.726" end="00:08.149" ttm:agent="v1" itunes:key="L2"><span begin="00:04.726" end="00:05.168">頬</span><span begin="00:05.168" end="00:05.555">を</span><span begin="00:05.680" end="00:05.909">木</span><span begin="00:05.909" end="00:06.161">枯</span><span begin="00:06.161" end="00:06.391">ら</span><span begin="00:06.391" end="00:06.627">し</span><span begin="00:06.627" end="00:06.872">が</span><span begin="00:06.872" end="00:07.250">撫</span><span begin="00:07.353" end="00:07.609">で</span><span begin="00:07.609" end="00:08.149">る</span><span ttm:role="x-translation" xml:lang="zh-CN">前方是 习习秋风吹来</span><span ttm:role="x-roman">ho ho wo ko ga ra shi ga na de ru</span></p><p begin="00:08.524" end="00:11.746" ttm:agent="v1" itunes:key="L3"><span begin="00:08.524" end="00:09.027">何</span><span begin="00:09.027" end="00:09.346">も</span><span begin="00:09.490" end="00:09.957">話</span><span begin="00:09.957" end="00:10.210">さ</span><span begin="00:10.210" end="00:10.442">な</span><span begin="00:10.442" end="00:10.689">く</span><span begin="00:10.689" end="00:10.961">た</span><span begin="00:10.961" end="00:11.168">っ</span><span begin="00:11.168" end="00:11.746">て</span><span ttm:role="x-translation" xml:lang="zh-CN">既然我 没将话说出口</span><span ttm:role="x-roman">na ni mo ha na sa na ku ta tte</span></p><p begin="00:12.340" end="00:15.674" ttm:agent="v1" itunes:key="L4"><span begin="00:12.340" end="00:12.832">全</span><span begin="00:12.832" end="00:13.105">部</span> <span begin="00:13.311" end="00:13.533">分</span><span begin="00:13.533" end="00:13.789">か</span><span begin="00:13.789" end="00:13.959">る</span><span begin="00:13.959" end="00:14.224">は</span><span begin="00:14.224" end="00:14.505">ず</span><span begin="00:14.505" end="00:14.689">な</span><span begin="00:14.689" end="00:14.945">い</span><span begin="00:14.945" end="00:15.228">よ</span><span begin="00:15.228" end="00:15.674">ね</span><span ttm:role="x-translation" xml:lang="zh-CN">你肯定 无法完全明白</span><span ttm:role="x-roman">ze n bu wa ka ru ha zu na i yo ne</span></p><p begin="00:16.152" end="00:19.492" ttm:agent="v2" itunes:key="L5"><span begin="00:16.152" end="00:16.633">少</span><span begin="00:16.633" end="00:16.984">し</span><span begin="00:17.123" end="00:17.353">冷</span><span begin="00:17.353" end="00:17.602">え</span><span begin="00:17.602" end="00:17.841">た</span><span begin="00:17.841" end="00:18.078">手</span><span begin="00:18.078" end="00:18.264">の</span><span begin="00:18.264" end="00:18.667">ひ</span><span begin="00:18.781" end="00:19.023">ら</span><span begin="00:19.023" end="00:19.492">に</span><span ttm:role="x-translation" xml:lang="zh-CN">张开我 已冰凉的手掌</span><span ttm:role="x-roman">su ko shi hi e ta te no hi ra ni</span></p><p begin="00:19.951" end="00:23.332" ttm:agent="v2" itunes:key="L6"><span begin="00:19.951" end="00:20.441">君</span><span begin="00:20.441" end="00:20.836">と</span><span begin="00:20.931" end="00:21.141">の</span><span begin="00:21.141" end="00:21.403">時</span><span begin="00:21.403" end="00:21.873">間</span><span begin="00:21.873" end="00:22.110">を</span><span begin="00:22.110" end="00:22.570">乗</span><span begin="00:22.570" end="00:22.831">せ</span><span begin="00:22.831" end="00:23.332">る</span><span ttm:role="x-translation" xml:lang="zh-CN">承载着 与你相处时光</span><span ttm:role="x-roman">ki mi to no ji ka n wo no se ru</span></p><p begin="00:23.756" end="00:27.097" ttm:agent="v2" itunes:key="L7"><span begin="00:23.756" end="00:24.260">数</span><span begin="00:24.260" end="00:24.501">え</span><span begin="00:24.501" end="00:24.743">き</span><span begin="00:24.743" end="00:24.964">れ</span><span begin="00:24.964" end="00:25.131">な</span><span begin="00:25.131" end="00:25.363">い</span><span begin="00:25.450" end="00:25.685">ほ</span><span begin="00:25.685" end="00:25.914">ど</span><span begin="00:25.914" end="00:26.365">の</span><span begin="00:26.365" end="00:26.635">希</span><span begin="00:26.635" end="00:27.097">望</span><span ttm:role="x-translation" xml:lang="zh-CN">在其中 蕴含无限希望</span><span ttm:role="x-roman">ka zo e ki re na i ho do no ki bo u</span></p><p begin="00:27.586" end="00:30.959" ttm:agent="v2" itunes:key="L8"><span begin="00:27.586" end="00:27.810">ど</span><span begin="00:27.810" end="00:28.052">れ</span><span begin="00:28.052" end="00:28.551">も</span><span begin="00:28.551" end="00:28.996">が</span><span begin="00:28.996" end="00:29.732">温</span><span begin="00:29.732" end="00:29.939">か</span><span begin="00:29.939" end="00:30.095">い</span><span begin="00:30.095" end="00:30.214">ん</span><span begin="00:30.214" end="00:30.959">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">全都能 温暖我的心房</span><span ttm:role="x-roman">do re mo ga a ta ta ka i n da</span></p><p begin="00:31.399" end="00:35.132" ttm:agent="v1" itunes:key="L9"><span begin="00:31.399" end="00:32.828">明日</span><span begin="00:32.828" end="00:33.218">も</span> <span begin="00:33.494" end="00:33.760">そ</span><span begin="00:33.760" end="00:34.271">の</span><span begin="00:34.480" end="00:34.607">あ</span><span begin="00:34.607" end="00:34.737">と</span><span begin="00:34.737" end="00:35.132">も</span><span ttm:role="x-translation" xml:lang="zh-CN">而明天 或是未来某天</span><span ttm:role="x-roman">a shi ta mo so no a to mo</span></p><p begin="00:35.452" end="00:38.800" ttm:agent="v1" itunes:key="L10"><span begin="00:35.452" end="00:35.687">言</span><span begin="00:35.687" end="00:36.155">え</span><span begin="00:36.380" end="00:36.637">ず</span><span begin="00:36.637" end="00:36.889">に</span><span begin="00:36.889" end="00:37.109">終</span><span begin="00:37.109" end="00:37.354">わ</span><span begin="00:37.354" end="00:37.563">る</span><span begin="00:37.563" end="00:37.829">ん</span><span begin="00:37.829" end="00:38.067">だ</span><span begin="00:38.067" end="00:38.316">ろ</span><span begin="00:38.316" end="00:38.800">う</span><span ttm:role="x-translation" xml:lang="zh-CN">结果也 一定不会改变</span><span ttm:role="x-roman">i e zu ni o wa ru n da ro u</span></p><p begin="00:39.237" end="00:42.398" ttm:agent="v2" itunes:key="L11"><span begin="00:39.237" end="00:39.748">君</span><span begin="00:39.748" end="00:39.977">と</span><span begin="00:39.977" end="00:40.207">出</span><span begin="00:40.207" end="00:40.507">会</span><span begin="00:40.507" end="00:40.679">っ</span><span begin="00:40.679" end="00:41.146">た</span><span begin="00:41.146" end="00:41.630">こ</span><span begin="00:41.630" end="00:41.887">と</span><span begin="00:41.887" end="00:42.398">で</span><span ttm:role="x-translation" xml:lang="zh-CN">但与你 产生这段因缘</span><span ttm:role="x-roman">ki mi to de a tta ko to de</span></p><p begin="00:42.827" end="00:46.884" ttm:agent="v2" itunes:key="L12"><span begin="00:42.827" end="00:43.304">僕</span><span begin="00:43.304" end="00:43.508">の</span><span begin="00:43.508" end="00:44.009">今</span><span begin="00:44.009" end="00:44.493">が</span><span begin="00:44.493" end="00:44.725">在</span><span begin="00:44.725" end="00:44.946">る</span><span begin="00:44.946" end="00:46.884">と</span><span ttm:role="x-translation" xml:lang="zh-CN">成为我 如今生存信念</span><span ttm:role="x-roman">bo ku no i ma ga a ru to</span></p><p begin="00:48.304" end="00:52.379" ttm:agent="v1" itunes:key="L13"><span begin="00:48.304" end="00:48.778">伝</span><span begin="00:48.778" end="00:49.024">え</span><span begin="00:49.024" end="00:49.218">た</span><span begin="00:49.218" end="00:49.520">い</span><span begin="00:49.735" end="00:50.206">想</span><span begin="00:50.206" end="00:50.306">い</span><span begin="00:50.306" end="00:50.618">を</span> <span begin="00:50.618" end="00:50.739">背</span><span begin="00:50.739" end="00:51.023">負</span><span begin="00:51.023" end="00:51.168">っ</span><span begin="00:51.168" end="00:51.396">て</span><span begin="00:51.396" end="00:51.644">駆</span><span begin="00:51.644" end="00:51.882">け</span><span begin="00:51.882" end="00:52.012">出</span><span begin="00:52.012" end="00:52.119">し</span><span begin="00:52.119" end="00:52.379">た</span><span ttm:role="x-translation" xml:lang="zh-CN">背负心意 我开始向前奔跑</span><span ttm:role="x-roman">tsu ta e ta i o mo i wo se o tte ka ke da shi ta</span></p><p begin="00:52.591" end="00:55.710" ttm:agent="v1" itunes:key="L14"><span begin="00:52.591" end="00:52.836">落</span><span begin="00:52.836" end="00:53.064">ち</span><span begin="00:53.064" end="00:53.304">葉</span> <span begin="00:53.304" end="00:53.542">舞</span><span begin="00:53.542" end="00:53.790">い</span> <span begin="00:53.790" end="00:54.018">降</span><span begin="00:54.018" end="00:54.251">る</span><span begin="00:54.251" end="00:54.967">道</span><span begin="00:54.967" end="00:55.209">の</span><span begin="00:55.209" end="00:55.710">上</span><span ttm:role="x-translation" xml:lang="zh-CN">看着秋叶 飞舞落在下坡道</span><span ttm:role="x-roman">o chi ba ma i fu ru mi chi no u e</span></p><p begin="00:55.924" end="01:00.035" ttm:agent="v1" itunes:key="L15"><span begin="00:55.924" end="00:56.136">も</span><span begin="00:56.136" end="00:56.352">う</span><span begin="00:56.352" end="00:56.622">す</span><span begin="00:56.622" end="00:57.101">ぐ</span> <span begin="00:57.571" end="00:57.839">き</span><span begin="00:57.839" end="00:57.959">っ</span><span begin="00:57.959" end="00:58.312">と</span><span begin="00:58.312" end="00:58.987">話</span><span begin="00:58.987" end="00:59.264">せ</span><span begin="00:59.264" end="00:59.456">る</span><span begin="00:59.456" end="00:59.721">ん</span><span begin="00:59.721" end="01:00.035">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">不久之后 定能和你说明了</span><span ttm:role="x-roman">mo u su gu ki tto ha na se ru n da</span></p><p begin="01:00.200" end="01:04.274" ttm:agent="v2" itunes:key="L16"><span begin="01:00.200" end="01:00.430">で</span><span begin="01:00.430" end="01:00.682">も</span><span begin="01:00.682" end="01:01.160">困</span><span begin="01:01.160" end="01:01.573">ら</span><span begin="01:01.573" end="01:01.860">せ</span><span begin="01:01.860" end="01:02.092">て</span><span begin="01:02.092" end="01:02.600">し</span><span begin="01:02.600" end="01:02.821">ま</span><span begin="01:02.821" end="01:03.066">う</span><span begin="01:03.066" end="01:03.565">か</span><span begin="01:03.565" end="01:04.274">な</span><span ttm:role="x-translation" xml:lang="zh-CN">而那时你 是否会感到困扰</span><span ttm:role="x-roman">de mo ko ma ra se te shi ma u ka na</span></p><p begin="01:11.366" end="01:14.751" ttm:agent="v2" itunes:key="L17"><span begin="01:11.366" end="01:11.862">君</span><span begin="01:11.862" end="01:12.243">が</span><span begin="01:12.361" end="01:12.831">歩</span><span begin="01:12.831" end="01:13.069">く</span><span begin="01:13.069" end="01:13.524">並</span><span begin="01:13.524" end="01:13.922">木</span><span begin="01:14.014" end="01:14.751">道</span><span ttm:role="x-translation" xml:lang="zh-CN">看见你 在林荫道漫步</span><span ttm:role="x-roman">ki mi ga a ru ku na mi ki mi chi</span></p><p begin="01:15.200" end="01:18.539" ttm:agent="v2" itunes:key="L18"><span begin="01:15.200" end="01:15.673">風</span><span begin="01:15.673" end="01:16.063">景</span><span begin="01:16.156" end="01:16.381">に</span><span begin="01:16.381" end="01:16.877">僕</span><span begin="01:16.877" end="01:17.104">も</span><span begin="01:17.104" end="01:17.319">混</span><span begin="01:17.319" end="01:17.841">ざ</span><span begin="01:17.841" end="01:18.062">れ</span><span begin="01:18.062" end="01:18.539">ば</span><span ttm:role="x-translation" xml:lang="zh-CN">这风景 能否让我加入</span><span ttm:role="x-roman">fu u ke i ni bo ku mo ma za re ba</span></p><p begin="01:19.001" end="01:22.323" ttm:agent="v2" itunes:key="L19"><span begin="01:19.001" end="01:19.251">綺</span><span begin="01:19.251" end="01:19.720">麗</span><span begin="01:19.720" end="01:19.957">じゃ</span><span begin="01:19.957" end="01:20.199">な</span><span begin="01:20.199" end="01:20.544">く</span><span begin="01:20.679" end="01:20.919">な</span><span begin="01:20.919" end="01:21.139">る</span><span begin="01:21.139" end="01:21.626">け</span><span begin="01:21.626" end="01:21.853">れ</span><span begin="01:21.853" end="01:22.323">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">虽然会 破坏整幅绘图</span><span ttm:role="x-roman">ki re i ja na ku na ru ke re do</span></p><p begin="01:22.820" end="01:26.158" ttm:agent="v2" itunes:key="L20"><span begin="01:22.820" end="01:23.311">隣</span><span begin="01:23.311" end="01:23.739">に</span><span begin="01:23.739" end="01:24.260">居</span><span begin="01:24.260" end="01:24.492">た</span><span begin="01:24.492" end="01:24.736">い</span><span begin="01:24.736" end="01:24.972">よ</span> <span begin="01:24.972" end="01:25.435">今日</span><span begin="01:25.435" end="01:26.158">は</span><span ttm:role="x-translation" xml:lang="zh-CN">但我想 感受你的温度</span><span ttm:role="x-roman">to na ri ni i ta i yo kyo u wa</span></p><p begin="01:26.639" end="01:30.450" ttm:agent="v1" itunes:key="L21"><span begin="01:26.639" end="01:28.059">涙</span><span begin="01:28.059" end="01:28.549">も</span><span begin="01:28.742" end="01:29.862">喜</span><span begin="01:29.862" end="01:29.965">び</span><span begin="01:29.965" end="01:30.450">も</span><span ttm:role="x-translation" xml:lang="zh-CN">愿悲伤 亦或快乐烦恼</span><span ttm:role="x-roman">na mi da mo yo ro ko bi mo</span></p><p begin="01:30.659" end="01:34.116" ttm:agent="v1" itunes:key="L22"><span begin="01:30.659" end="01:31.635">悩</span><span begin="01:31.635" end="01:31.841">み</span><span begin="01:31.841" end="01:32.109">も</span><span begin="01:32.109" end="01:32.316">分</span><span begin="01:32.316" end="01:32.549">け</span><span begin="01:32.549" end="01:32.828">合</span><span begin="01:32.828" end="01:33.065">え</span><span begin="01:33.065" end="01:33.265">た</span><span begin="01:33.265" end="01:34.116">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">我都能 向你絮絮叨叨</span><span ttm:role="x-roman">na ya mi mo wa ke a e ta ra</span></p><p begin="01:34.485" end="01:37.610" ttm:agent="v1" itunes:key="L23"><span begin="01:34.485" end="01:35.182">幸</span><span begin="01:35.182" end="01:35.429">せ</span><span begin="01:35.429" end="01:35.916">だ</span><span begin="01:35.916" end="01:36.157">と</span><span begin="01:36.157" end="01:36.640">思</span><span begin="01:36.640" end="01:36.874">う</span><span begin="01:36.874" end="01:37.101">か</span><span begin="01:37.101" end="01:37.610">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">这就是 我幸福的美好</span><span ttm:role="x-roman">shi a wa se da to o mo u ka ra</span></p><p begin="01:38.028" end="01:41.637" ttm:agent="v1" itunes:key="L24"><span begin="01:38.028" end="01:38.547">君</span><span begin="01:38.547" end="01:38.786">の</span><span begin="01:38.786" end="01:39.018">名</span><span begin="01:39.018" end="01:39.698">前</span><span begin="01:39.698" end="01:39.943">を</span><span begin="01:39.943" end="01:40.170">呼</span><span begin="01:40.170" end="01:41.637">ぶ</span><span ttm:role="x-translation" xml:lang="zh-CN">于是我 呼唤你的来到</span><span ttm:role="x-roman">ki mi no na ma e wo yo bu</span></p><p begin="01:41.637" end="01:45.847" ttm:agent="v1" itunes:key="L25"><span begin="01:41.637" end="01:42.116">飾</span><span begin="01:42.116" end="01:42.327">ら</span><span begin="01:42.327" end="01:42.499">な</span><span begin="01:42.499" end="01:42.811">い</span><span begin="01:43.071" end="01:43.549">願</span><span begin="01:43.549" end="01:43.663">い</span><span begin="01:43.663" end="01:44.004">は</span> <span begin="01:44.004" end="01:44.487">結</span><span begin="01:44.487" end="01:44.969">局</span> <span begin="01:44.969" end="01:45.341">隠</span><span begin="01:45.341" end="01:45.454">し</span><span begin="01:45.454" end="01:45.847">た</span><span ttm:role="x-translation" xml:lang="zh-CN">朴素愿望 最后还是被隐藏</span><span ttm:role="x-roman">ka za ra na i ne ga i wa ke kkyo ku ka ku shi ta</span></p><p begin="01:45.917" end="01:49.181" ttm:agent="v2" itunes:key="L26"><span begin="01:45.917" end="01:46.403">並</span><span begin="01:46.403" end="01:46.632">ん</span><span begin="01:46.632" end="01:46.869">で</span><span begin="01:46.869" end="01:47.355">歩</span><span begin="01:47.355" end="01:47.555">く</span><span begin="01:47.555" end="01:48.297">道</span><span begin="01:48.297" end="01:48.530">は</span><span begin="01:48.530" end="01:48.773">未</span><span begin="01:48.773" end="01:49.181">来</span><span ttm:role="x-translation" xml:lang="zh-CN">只是并肩 迈向未来的方向</span><span ttm:role="x-roman">na ra n de a ru ku mi chi wa mi ra i</span></p><p begin="01:49.246" end="01:53.371" ttm:agent="v1" itunes:key="L27"><span begin="01:49.246" end="01:49.478">こ</span><span begin="01:49.478" end="01:49.689">う</span><span begin="01:49.689" end="01:49.930">し</span><span begin="01:49.930" end="01:50.459">て</span> <span begin="01:50.900" end="01:51.207">ず</span><span begin="01:51.207" end="01:51.288">っ</span><span begin="01:51.288" end="01:51.640">と</span><span begin="01:51.640" end="01:52.096">こ</span><span begin="01:52.096" end="01:52.338">の</span><span begin="01:52.338" end="01:52.560">時</span><span begin="01:52.560" end="01:53.072">間</span><span begin="01:53.072" end="01:53.371">が</span><span ttm:role="x-translation" xml:lang="zh-CN">祈愿这段 过于美好的时光</span><span ttm:role="x-roman">ko u shi te zu tto ko no ji ka n ga</span></p><p begin="01:53.547" end="01:57.583" ttm:agent="v1" itunes:key="L28"><span begin="01:53.547" end="01:54.027">続</span><span begin="01:54.027" end="01:54.245">け</span><span begin="01:54.245" end="01:54.499">ば</span><span begin="01:54.499" end="01:54.653">良</span><span begin="01:54.653" end="01:54.820">い</span><span begin="01:54.820" end="01:54.975">っ</span><span begin="01:54.975" end="01:55.199">て</span><span begin="01:55.199" end="01:55.891">思</span><span begin="01:55.891" end="01:56.129">う</span><span begin="01:56.129" end="01:56.362">け</span><span begin="01:56.362" end="01:56.872">れ</span><span begin="01:56.872" end="01:57.583">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">能够定格 成为永恒的日常</span><span ttm:role="x-roman">tsu zu ke ba i i tte o mo u ke re do</span></p><p begin="02:12.105" end="02:16.232" ttm:agent="v1" itunes:key="L29"><span begin="02:12.105" end="02:12.595">届</span><span begin="02:12.595" end="02:12.818">か</span><span begin="02:12.818" end="02:13.053">な</span><span begin="02:13.053" end="02:13.361">い</span><span begin="02:13.542" end="02:13.957">想</span><span begin="02:13.957" end="02:14.128">い</span><span begin="02:14.128" end="02:14.380">は</span> <span begin="02:14.482" end="02:14.983">自</span><span begin="02:14.983" end="02:15.451">分</span><span begin="02:15.451" end="02:15.648">の</span><span begin="02:15.648" end="02:15.784">せ</span><span begin="02:15.784" end="02:15.932">い</span><span begin="02:15.932" end="02:16.232">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">难表心意 只恨自己的懦弱</span><span ttm:role="x-roman">to do ka na i o mo i wa ji bu n no se i da</span></p><p begin="02:16.380" end="02:19.603" ttm:agent="v1" itunes:key="L30"><span begin="02:16.380" end="02:16.621">分</span><span begin="02:16.621" end="02:16.869">か</span><span begin="02:16.869" end="02:17.122">っ</span><span begin="02:17.122" end="02:17.343">て</span><span begin="02:17.343" end="02:17.588">い</span><span begin="02:17.588" end="02:17.820">て</span><span begin="02:17.820" end="02:18.063">も</span><span begin="02:18.063" end="02:18.319">踏</span><span begin="02:18.319" end="02:18.693">み</span><span begin="02:18.789" end="02:18.997">出</span><span begin="02:18.997" end="02:19.255">せ</span><span begin="02:19.255" end="02:19.354">な</span><span begin="02:19.354" end="02:19.603">い</span><span ttm:role="x-translation" xml:lang="zh-CN">错失机会 也不敢展露自我</span><span ttm:role="x-roman">wa ka tte i te mo fu mi da se na i</span></p><p begin="02:19.715" end="02:23.791" ttm:agent="v2" itunes:key="L31"><span begin="02:19.715" end="02:20.189">最</span><span begin="02:20.189" end="02:20.454">後</span><span begin="02:20.454" end="02:20.964">に</span> <span begin="02:21.383" end="02:21.663">ぎゅ</span><span begin="02:21.663" end="02:21.760">っ</span><span begin="02:21.760" end="02:22.000">と</span><span begin="02:22.113" end="02:22.582">手</span><span begin="02:22.582" end="02:22.835">を</span><span begin="02:22.835" end="02:23.366">握</span><span begin="02:23.366" end="02:23.539">っ</span><span begin="02:23.539" end="02:23.791">て</span><span ttm:role="x-translation" xml:lang="zh-CN">只能最后 将你的双手紧握</span><span ttm:role="x-roman">sa i go ni gi yu tto te wo ni gi tte</span></p><p begin="02:23.966" end="02:28.107" ttm:agent="v2" itunes:key="L32"><span begin="02:23.966" end="02:24.020">「</span><span begin="02:24.020" end="02:24.265">ま</span><span begin="02:24.265" end="02:24.479">た</span><span begin="02:24.479" end="02:25.200">明日</span><span begin="02:25.200" end="02:25.256">」</span> <span begin="02:25.436" end="02:25.933">精</span><span begin="02:25.933" end="02:26.381">一</span><span begin="02:26.381" end="02:26.886">杯</span><span begin="02:26.886" end="02:27.188">だ</span><span begin="02:27.188" end="02:27.367">っ</span><span begin="02:27.367" end="02:28.107">た</span><span ttm:role="x-translation" xml:lang="zh-CN">「明天再见」 拼尽全力地诉说</span><span ttm:role="x-roman">"ma ta a shi ta" se i i ppa i da tta</span></p><p begin="02:27.350" end="02:31.477" ttm:agent="v1" itunes:key="L33"><span begin="02:27.350" end="02:27.590">揺</span><span begin="02:27.590" end="02:27.804">ら</span><span begin="02:27.804" end="02:28.033">が</span><span begin="02:28.033" end="02:28.231">な</span><span begin="02:28.231" end="02:28.514">い</span><span begin="02:28.796" end="02:29.205">想</span><span begin="02:29.205" end="02:29.356">い</span><span begin="02:29.356" end="02:29.677">を</span> <span begin="02:29.677" end="02:29.800">背</span><span begin="02:29.800" end="02:30.052">負</span><span begin="02:30.052" end="02:30.202">っ</span><span begin="02:30.202" end="02:30.440">て</span><span begin="02:30.440" end="02:30.675">駆</span><span begin="02:30.675" end="02:30.914">け</span><span begin="02:30.914" end="02:31.075">出</span><span begin="02:31.075" end="02:31.165">し</span><span begin="02:31.165" end="02:31.477">た</span><span ttm:role="x-translation" xml:lang="zh-CN">坚定心意 我继续向前奔跑</span><span ttm:role="x-roman">yu ra ga na i o mo i wo se o tte ka ke da shi ta</span></p><p begin="02:31.644" end="02:34.718" ttm:agent="v1" itunes:key="L34"><span begin="02:31.644" end="02:31.880">落</span><span begin="02:31.880" end="02:32.100">ち</span><span begin="02:32.100" end="02:32.331">葉</span> <span begin="02:32.331" end="02:32.559">舞</span><span begin="02:32.559" end="02:32.825">い</span> <span begin="02:32.825" end="02:33.073">降</span><span begin="02:33.073" end="02:33.306">る</span><span begin="02:33.306" end="02:33.939">道</span><span begin="02:34.021" end="02:34.251">の</span><span begin="02:34.251" end="02:34.718">上</span><span ttm:role="x-translation" xml:lang="zh-CN">看着秋叶 飞舞落在下坡道</span><span ttm:role="x-roman">o chi ba ma i fu ru mi chi no u e</span></p><p begin="02:34.979" end="02:39.202" ttm:agent="v2" itunes:key="L35"><span begin="02:34.979" end="02:35.198">こ</span><span begin="02:35.198" end="02:35.406">の</span><span begin="02:35.406" end="02:36.145">先</span> <span begin="02:36.623" end="02:36.878">も</span><span begin="02:36.878" end="02:36.997">っ</span><span begin="02:36.997" end="02:37.346">と</span><span begin="02:37.346" end="02:38.023">返</span><span begin="02:38.023" end="02:38.306">し</span><span begin="02:38.306" end="02:38.454">た</span><span begin="02:38.454" end="02:38.583">い</span><span begin="02:38.583" end="02:38.797">ん</span><span begin="02:38.797" end="02:39.202">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">只愿未来 能给你更多信号</span><span ttm:role="x-roman">ko no sa ki mo tto ka e shi ta i n da</span></p><p begin="02:39.258" end="02:43.313" ttm:agent="v2" itunes:key="L36"><span begin="02:39.258" end="02:39.737">言</span><span begin="02:39.737" end="02:39.978">葉</span><span begin="02:39.978" end="02:40.171">で</span><span begin="02:40.171" end="02:40.532">は</span><span begin="02:40.676" end="02:40.925">足</span><span begin="02:40.925" end="02:41.154">り</span><span begin="02:41.154" end="02:41.623">な</span><span begin="02:41.623" end="02:41.864">い</span><span begin="02:41.864" end="02:42.085">け</span><span begin="02:42.085" end="02:42.544">ど</span><span begin="02:42.544" end="02:43.313">さ</span><span ttm:role="x-translation" xml:lang="zh-CN">仅靠言语 无法满足我需要</span><span ttm:role="x-roman">ko to ba de wa ta ri na i ke do sa</span></p><p begin="02:44.740" end="02:48.074" ttm:agent="v1" itunes:key="L37"><span begin="02:44.740" end="02:45.205">色</span><span begin="02:45.205" end="02:45.460">の</span><span begin="02:45.681" end="02:45.844">褪</span><span begin="02:45.844" end="02:46.132">せ</span><span begin="02:46.132" end="02:46.366">た</span><span begin="02:46.366" end="02:46.870">帰</span><span begin="02:46.870" end="02:47.333">り</span><span begin="02:47.333" end="02:48.074">道</span><span ttm:role="x-translation" xml:lang="zh-CN">归途中 风景失去色彩</span><span ttm:role="x-roman">i ro no a se ta ka e ri mi chi</span></p><p begin="02:48.557" end="02:51.896" ttm:agent="v1" itunes:key="L38"><span begin="02:48.557" end="02:49.022">頬</span><span begin="02:49.022" end="02:49.482">を</span><span begin="02:49.482" end="02:49.715">木</span><span begin="02:49.715" end="02:49.974">枯</span><span begin="02:49.974" end="02:50.188">ら</span><span begin="02:50.188" end="02:50.435">し</span><span begin="02:50.435" end="02:50.674">が</span><span begin="02:50.674" end="02:51.153">撫</span><span begin="02:51.153" end="02:51.396">で</span><span begin="02:51.396" end="02:51.896">る</span><span ttm:role="x-translation" xml:lang="zh-CN">前方是 习习秋风吹来</span><span ttm:role="x-roman">ho ho wo ko ga ra shi ga na de ru</span></p><p begin="02:52.371" end="02:55.576" ttm:agent="v2" itunes:key="L39"><span begin="02:52.371" end="02:52.836">伝</span><span begin="02:52.836" end="02:53.132">え</span><span begin="02:53.265" end="02:53.535">そ</span><span begin="02:53.535" end="02:53.784">び</span><span begin="02:53.784" end="02:54.005">れ</span><span begin="02:54.005" end="02:54.218">た</span><span begin="02:54.218" end="02:54.767">想</span><span begin="02:54.767" end="02:54.967">い</span><span begin="02:54.967" end="02:55.576">を</span><span ttm:role="x-translation" xml:lang="zh-CN">只可惜 未说出的心意</span><span ttm:role="x-roman">tsu ta e so bi re ta o mo i wo</span></p><p begin="02:56.127" end="02:59.894" ttm:agent="v2" itunes:key="L40"><span begin="02:56.127" end="02:56.650">運</span><span begin="02:56.650" end="02:56.992">ん</span><span begin="02:57.105" end="02:57.346">で</span><span begin="02:57.346" end="02:57.555">く</span><span begin="02:57.555" end="02:57.814">れ</span><span begin="02:57.814" end="02:58.054">た</span><span begin="02:58.054" end="02:58.295">ら</span><span begin="02:58.295" end="02:58.530">良</span><span begin="02:58.530" end="02:58.774">い</span><span begin="02:58.774" end="02:59.025">の</span><span begin="02:59.025" end="02:59.894">に</span><span ttm:role="x-translation" xml:lang="zh-CN">秋风也 不能为我传递</span><span ttm:role="x-roman">ha ko n de ku re ta ra i i no ni</span></p></div></body></tt>