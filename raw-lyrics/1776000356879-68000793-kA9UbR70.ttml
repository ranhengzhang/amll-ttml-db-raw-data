<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="en"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><amll:meta key="musicName" value="在银河中孤独摇摆"/><amll:meta key="musicName" value="在銀河中孤獨搖擺"/><amll:meta key="musicName" value="銀河を独り揺蕩う"/><amll:meta key="musicName" value="은하에서 외로이 흔들리며"/><amll:meta key="musicName" value="Sway to My Beat in Cosmos"/><amll:meta key="artists" value="HOYO-MiX"/><amll:meta key="artists" value="知更鸟"/><amll:meta key="artists" value="ロビン"/><amll:meta key="artists" value="로빈"/><amll:meta key="artists" value="Robin"/><amll:meta key="artists" value="Chevy"/><amll:meta key="album" value="崩坏星穹铁道-空气蛹 INSIDE"/><amll:meta key="album" value="INSIDE"/><amll:meta key="album" value="空气蛹 - EP"/><amll:meta key="album" value="空氣蛹 - EP"/><amll:meta key="album" value="INSIDE - EP"/><amll:meta key="ncmMusicId" value="2155423467"/><amll:meta key="qqMusicId" value="003Xspep2oKRxi"/><amll:meta key="qqMusicId" value="486451796"/><amll:meta key="spotifyId" value="04xQxw0nBksDN4DAZT3HgJ"/><amll:meta key="spotifyId" value="4IaSmODFFRYJcXdFzip1aA"/><amll:meta key="spotifyId" value="52crCdA866Orx72y7Na6VK"/><amll:meta key="spotifyId" value="2AnvQvVqWORCmgRzLR0sHe"/><amll:meta key="appleMusicId" value="1744862742"/><amll:meta key="appleMusicId" value="1744861539"/><amll:meta key="appleMusicId" value="1744865448"/><amll:meta key="appleMusicId" value="1744860810"/><amll:meta key="appleMusicId" value="1744859059"/><amll:meta key="isrc" value="QM6N22420269"/><amll:meta key="isrc" value="QM6N22421953"/><amll:meta key="isrc" value="QM6N22422280"/><amll:meta key="isrc" value="QM6N22422307"/><amll:meta key="isrc" value="QM6N22421993"/><amll:meta key="Arranger" value="王可鑫"/><amll:meta key="Composer" value="王可鑫"/><amll:meta key="Lead Vocals" value="Chevy"/><amll:meta key="Lyrics" value="黑金雨"/><amll:meta key="Lyrics" value="Ruby Qu"/><amll:meta key="Mastering Engineer" value="宫奇"/><amll:meta key="Mixing Engineer" value="阿烈"/><amll:meta key="Performer" value="知更鸟"/><amll:meta key="Performer" value="HOYO-MiX"/><amll:meta key="Performer" value="王可鑫"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><amll:meta key="ttmlAuthorGithub" value="50747104"/><amll:meta key="ttmlAuthorGithubLogin" value="Xionghaizi001"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">加快步伐，紧随这律动摇摆</text><text for="L2">高举双手，拥理想自我入怀</text><text for="L3">我们一起抵达未见之境</text><text for="L4">感受着心底火焰</text><text for="L5">你令我轻启心扉，交托信赖</text><text for="L6">加入我的梦境吧，大好时机已来</text><text for="L7">把一切都抛开 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(抛在脑后)</span></text><text for="L8">现在做好准备—— <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(准备好——)</span></text><text for="L9">跃升 闯入我的世界</text><text for="L10">更新你的定义</text><text for="L11">向你展示这里的超乎寻常</text><text for="L12">让你听见我的宣言</text><text for="L13">“从此，再无拘束”</text><text for="L14">高高跳起，用双脚叩出节拍</text><text for="L15">当你感受到律动，繁星已近在咫尺</text><text for="L16">我们一起触碰更高的天空</text><text for="L17">要向炽燃中飞跃</text><text for="L18">不在凡俗里沉沦</text><text for="L19">加入我的梦境吧，大好时机已来</text><text for="L20">把一切都抛开</text><text for="L21">现在做好准备</text><text for="L22">随我一起高唱</text><text for="L23">欢迎来到我的世界</text><text for="L24">更新你的定义</text><text for="L25">向你展示这里的超乎寻常</text><text for="L26">让你听见我的宣言</text><text for="L27">“从此，再无拘束”</text><text for="L28">欢迎来到我的世界 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(把一切都抛开)</span></text><text for="L29">更新你的定义</text><text for="L30">向你展示这里的超乎寻常</text><text for="L31">现在请静静地聆听</text><text for="L32">欢迎来到我的世界</text><text for="L33">更新你的定义</text><text for="L34">我们要向世人证明这里的超乎寻常</text><text for="L35">越过地平线</text><text for="L36">肩并着肩</text></translation></translations><songwriters><songwriter>黑金雨</songwriter><songwriter>Ruby Qu</songwriter><songwriter>王可鑫</songwriter></songwriters><transliterations/></iTunesMetadata></metadata></head><body dur="2:39.120"><div begin="10.360" end="19.270" itunes:songPart="Verse"><p begin="10.360" end="12.050" itunes:key="L1" ttm:agent="v1"><span begin="10.360" end="10.540">Men</span><span begin="10.540" end="10.660">d your</span> <span begin="10.660" end="10.880">pace</span> <span begin="10.880" end="11.020">s</span><span begin="11.020" end="11.220">way</span> <span begin="11.220" end="11.540">to</span> <span begin="11.540" end="11.730">the</span> <span begin="11.730" end="12.050">beat</span></p><p begin="12.130" end="14.450" itunes:key="L2" ttm:agent="v1"><span begin="12.130" end="12.440">Han</span><span begin="12.440" end="12.650">ds up</span> <span begin="12.790" end="12.980">Em</span><span begin="13.080" end="13.240">bra</span><span begin="13.240" end="13.380">ce</span> <span begin="13.380" end="13.520">who</span> <span begin="13.520" end="13.680">you</span> <span begin="13.680" end="13.960">wan</span><span begin="13.960" end="14.130">na</span> <span begin="14.130" end="14.450">be</span></p><p begin="15.190" end="19.270" itunes:key="L3" ttm:agent="v1"><span begin="15.190" end="15.500">We&apos;re</span> <span begin="15.500" end="15.710">rea</span><span begin="15.710" end="15.910">ching</span> <span begin="15.910" end="16.280">heigh</span><span begin="16.280" end="16.380">ts</span> <span begin="16.380" end="16.480">un</span><span begin="16.480" end="16.970">seen</span><span begin="16.970" end="17.100">,</span> <span begin="17.280" end="17.540">whoa</span><span begin="17.540" end="18.190">,</span> <span begin="18.190" end="18.420">whoa</span><span begin="18.420" end="18.570">-oh</span> <span begi