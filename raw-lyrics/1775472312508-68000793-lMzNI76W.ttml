<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="ja"><head><metadata><ttm:agent type="person" xml:id="v1"><ttm:name type="full">小豆沢 こはね</ttm:name></ttm:agent><ttm:agent type="person" xml:id="v2"><ttm:name type="full">白石 杏</ttm:name></ttm:agent><ttm:agent type="person" xml:id="v3"><ttm:name type="full">巡音 ルカ</ttm:name></ttm:agent><ttm:agent type="group" xml:id="v1000"><ttm:name type="full">巡音 ルカ</ttm:name><ttm:name type="full">小豆沢 こはね</ttm:name><ttm:name type="full">白石 杏</ttm:name></ttm:agent><ttm:agent type="group" xml:id="v2000"><ttm:name type="full">巡音 ルカ</ttm:name><ttm:name type="full">白石 杏</ttm:name></ttm:agent><ttm:agent type="group" xml:id="v3000"><ttm:name type="full">巡音 ルカ</ttm:name><ttm:name type="full">小豆沢 こはね</ttm:name></ttm:agent><amll:meta key="musicName" value="Just Be Friends (feat. 小豆沢こはね, 白石杏 &amp; 巡音ルカ)"/><amll:meta key="musicName" value="Just Be Friends"/><amll:meta key="musicName" value="只能做朋友"/><amll:meta key="artists" value="小豆沢こはね"/><amll:meta key="artists" value="小豆沢心羽"/><amll:meta key="artists" value="小豆澤心羽"/><amll:meta key="artists" value="Azusawa Kohane"/><amll:meta key="artists" value="白石杏"/><amll:meta key="artists" value="Shiraishi An"/><amll:meta key="artists" value="巡音ルカ"/><amll:meta key="artists" value="巡音流歌"/><amll:meta key="artists" value="Megurine Luka"/><amll:meta key="artists" value="Vivid BAD SQUAD"/><amll:meta key="artists" value="炫狂小队"/><amll:meta key="album" value="Vivid BAD SQUAD SEKAI ALBUM vol.1"/><amll:meta key="album" value="Vivid BAD SQUAD SEKAI ALBUM Vol. 1"/><amll:meta key="ncmMusicId" value="1952528401"/><amll:meta key="qqMusicId" value="0005LHa24EnXd6"/><amll:meta key="qqMusicId" value="357876399"/><amll:meta key="spotifyId" value="2hLkW5kXCiE6RLj1iqnaS6"/><amll:meta key="appleMusicId" value="1626455877"/><amll:meta key="isrc" value="JPX302137930"/><amll:meta key="Vocals" value="巡音ルカ"/><amll:meta key="Vocals" value="小豆沢こはね"/><amll:meta key="Vocals" value="白石杏"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="en"><text for="L5">It came to mind in the early morning yesterday</text><text for="L6">As if I gathered broken pieces of glass</text><text for="L7">What the heck is this?</text><text for="L8">A drop from a cut on my finger</text><text for="L9">Is this what we</text><text for="L10">Really hoped for?</text><text for="L11">I knew it at the bottom of my heart</text><text for="L12">That the hardest choice would be the best</text><text for="L13">My self-love refuses it</text><text for="L14">And repeats self-contradiction</text><text for="L15">When can I</text><text for="L16">Tell it to you?</text><text for="L17">In this slowly decaying world</text><text for="L18">I&apos;m struggling but it&apos;s the only way</text><text for="L19">Carving your faded smiles</text><text for="L20">I pulled out the plug</text><text for="L21">I screamed with my hoarse voice</text><text for="L22">Rebound and resonance echo in vain</text><text for="L23">Nothing is left behind at the end</text><text for="L24">Of the me that has been unchained</text><text for="L25">The coincidences that we&apos;d piled up</text><text for="L26">Degenerate into the dark and are broken in pieces</text><text for="L27">&quot;No matter what we do, life is just like that.&quot;</text><text for="L28">I mumbled as somebody&apos;s tears flow down the dried cheeks</text><text for="L33">Yesterday a tranquil night made me realize</text><text for="L34">It&apos;d be useless to pick up fallen petals</text><text for="L35">Because it&apos;d never bloom again</text><text for="L36">It&apos;s tiny but already dead on my palms</text><text for="L37">Our time</text><text for="L38">Stopped long ago</text><text for="L39">I remember the season we first met</text><text for="L40">And your graceful smile</text><text for="L41">Bringing up old issues</text><text for="L42">We hurt each other as badly as possible</text><text for="L43">Our hearts are</text><text for="L44">Full of thorns</text><text for="L45">With this continuous dull relationship</text><text for="L46">Grievously I can&apos;t change my mind</text><text for="L47">I still love you, I don&apos;t wanna be apart from you</text><text for="L48">But I have to tell you</text><text for="L49">It&apos;s raining heavily in my mind, I&apos;m stunned,</text><text for="L50">I&apos;m standing dead, my vision is blurry</text><text for="L51">Despite my determination,</text><text for="L52">The pain is still penetrating</text><text for="L53">The bond between us had come apart</text><text for="L54">And is dying away in everyday</text><text for="L55">Goodbye, my sweetheart, it&apos;s over</text><text for="L56">We had to leave without turning back</text><text for="L57">Just once, just once</text><text for="L58">If I could have my wish to come true</text><text for="L59">I&apos;d be born again and again</text><text for="L60">And go see you on those days</text><text for="L61">I screamed with my hoarse voice</text><text for="L62">Rebound and resonance echo in vain</text><text for="L63">Nothing is left behind at the end</text><text for="L64">Of the me that has been unchained</text><text for="L65">The bond between us had come apart</text><text for="L66">And is dying away in everyday</text><text for="L67">Goodbye, my sweetheart, it&apos;s over</text><text for="L68">We had to leave without turning back</text><text for="L69">It&apos;s all over</text></translation><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">保持朋友关系 这是我们唯一能做的</text><text for="L2">保持朋友关系 是时候说再见了</text><text for="L3">保持朋友关系 这是我们唯一能做的</text><text for="L4">保持朋友关系……</text><text for="L5">脑中浮现 昨天一大早</text><text for="L6">好像是在收拾打破的玻璃碎片的情景</text><text for="L7">这到底是什么情况？ 被割伤的手指滴下了血滴</text><text for="L9">我们真的干了</text><text for="L10">这种蠢事吗？</text><text for="L11">我很清楚 在心底深处</text><text for="L12">最难过的选择才是最佳答案</text><text for="L13">不断抗拒的是自我保护</text><text for="L14">和自我矛盾的无限循环</text><text for="L15">我什么时候</text><text for="L16">才说的出口呢？</text><text for="L17">慢慢腐朽的这个世界</text><text for="L18">不断挣扎的我只剩一条活路</text><text for="L19">将你褪色的微笑 刻划在我心中</text><text for="L20">然后拔掉忍耐的栓子</text><text for="L21">喊叫到声嘶力竭</text><text for="L22">反响 残响 空虚地响着</text><text for="L23">就算把锁给解开</text><text for="L24">也什么都不会留下</text><text for="L25">两人相遇的偶然</text><text for="L26">暗转 断线 无尽虚幻</text><text for="L27">“反正就是这样啦” 如此低语</text><text for="L28">流在毫无生气的脸庞上的 是谁的眼泪</text><text for="L29">这是我们唯一能做的</text><text for="L30">保持朋友关系 是时候说再见了</text><text for="L31">保持朋友关系 这是我们唯一能做的</text><text for="L32">保持朋友关系 保持朋友关系 保持朋友关系……</text><text for="L33">我才发现 在昨晚风雨停息过后</text><text for="L34">就算把掉在地上的花瓣给捡起来</text><text for="L35">它再也无法绽放</text><text for="L36">掌心这微小的死亡</text><text for="L37">让我们两人的时间</text><text for="L38">就此停滞</text><text for="L39">我想起了 我们初次相遇的季节</text><text for="L40">你那温柔笑着的脸庞</text><text for="L41">就把现在变成过去</text><text for="L42">两人遍体鳞伤</text><text for="L43">我们的内心已满是</text><text for="L44">荆棘般的尖刺</text><text for="L45">面对沉重苦闷的这段感情</text><text for="L46">令人悲伤的是我这不曾变过的心</text><text for="L47">明明是如此深爱 没办法轻易分开</text><text for="L48">但我不说出口不行</text><text for="L49">下在心里的倾盆大雨</text><text for="L50">呆然 竦然 让视线都模糊</text><text for="L51">虽说早已做好觉悟 那份痛楚</text><text for="L52">仍贯穿了我的身体</text><text for="L53">连结两人的羁绊</text><text for="L54">剪断 解开 消失在日常生活中</text><text for="L55">再见了曾深爱的人 到此为止了</text><text for="L56">别再回头就向前走吧</text><text for="L57">一次就好 一次就好</text><text for="L58">愿望可以实现的话</text><text for="L59">不管要转世几次</text><text for="L60">我都会去找寻那时候的你</text><text for="L61">喊叫到声嘶力竭</text><text for="L62">反响 残响 空虚地响着</text><text for="L63">就算把锁给解开</text><text for="L64">也什么都不会留下</text><text for="L65">连结两人的羁绊</text><text for="L66">剪断 解开 消失在日常生活中</text><text for="L67">再见了曾深爱的人 到此为止了</text><text for="L68">别再回头就向前走吧</text><text for="L69">就此划下句点了</text><text for="L70">保持朋友关系 是时候说再见了</text><text for="L71">保持朋友关系 这是我们唯一能做的</text><text for="L72">保持朋友关系 是时候说再见了</text><text for="L73">保持朋友关系</text><text for="L74">保持朋友关系 这是我们唯一能做的</text><text for="L75">保持朋友关系</text><text for="L76">保持朋友关系 是时候说再见了</text><text for="L77">保持朋友关系</text><text for="L78">保持朋友关系 这是我们唯一能做的</text><text for="L79">我们本该 早该如此</text><text for="L80">保持朋友关系 是时候说再见了</text><text for="L81">我们本该 做普通朋友</text><text for="L82">保持朋友关系</text></translation></translations><songwriters><songwriter>Dixie Flatline</songwriter></songwriters><transliterations><transliteration xml:lang="ja-Latn"><text for="L5"><span begin="35.630" end="35.760" xmlns="http://www.w3.org/ns/ttml">u</span> <span begin="35.760" end="35.920" xmlns="http://www.w3.org/ns/ttml">ka</span><span begin="35.920" end="36.040" xmlns="http://www.w3.org/ns/ttml">n</span> <span begin="36.040" end="36.230" xmlns="http://www.w3.org/ns/ttml">da</span><span begin="36.230" end="36.370" xmlns="http://www.w3.org/ns/ttml">n</span> <span begin="36.370" end="36.660" xmlns="http://www.w3.org/ns/ttml">da</span> <span begin="36.660" end="36.900" xmlns="http://www.w3.org/ns/ttml">ki</span> <span begin="36.900" end="37.290" xmlns="http://www.w3.org/ns/ttml">no u</span> <span begin="37.290" end="37.620" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="37.620" end="38.090" xmlns="http://www.w3.org/ns/ttml">a sa</span> <span begin="38.090" end="38.550" xmlns="http://www.w3.org/ns/ttml">ha ya</span> <span begin="38.550" end="38.850" xmlns="http://www.w3.org/ns/ttml">ku</span> <span begin="38.850" end="39.180" xmlns="http://www.w3.org/ns/ttml">ni</span></text><text for="L6"><span begin="39.490" end="39.730" xmlns="http://www.w3.org/ns/ttml">wa</span> <span begin="39.730" end="39.970" xmlns="http://www.w3.org/ns/ttml">re</span> <span begin="39.970" end="40.080" xmlns="http://www.w3.org/ns/ttml">ta</span> <span begin="40.080" end="40.410" 