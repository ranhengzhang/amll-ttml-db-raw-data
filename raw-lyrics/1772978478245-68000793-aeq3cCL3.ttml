<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="ja"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><amll:meta key="musicName" value="緋色月下、狂咲ノ絶　-1st Anniversary Remix-"/><amll:meta key="musicName" value="原曲：U.N.オーエンは彼女なのか？"/><amll:meta key="musicName" value="Hiirogekka, Kyousyounozetsu -1st Anniversary Remix-"/><amll:meta key="musicName" value="Hiirogekka, Kyousyounozetsu (1st Anniversary Remix)"/><amll:meta key="musicName" value="緋色月下、狂咲ノ絶 -1st Anniversary Remix-"/><amll:meta key="artists" value="EastNewSound"/><amll:meta key="artists" value="ENS"/><amll:meta key="artists" value="东方新声"/><amll:meta key="album" value="Sacred Factor"/><amll:meta key="ncmMusicId" value="722013"/><amll:meta key="spotifyId" value="54BCBHVE768LRKC8W9b8tb"/><amll:meta key="appleMusicId" value="1570066003"/><amll:meta key="isrc" value="JPW562101257"/><amll:meta key="Composer" value="ZUN"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="en"><text for="L1">Inside of me</text><text for="L2">Inside of me</text><text for="L3">Inside of me</text><text for="L4">Myself</text><text for="L5">There’s one to describe it</text><text for="L6">There’s one to describe it</text><text for="L7">One word</text><text for="L8">Endlessly</text><text for="L9">Endlessly</text><text for="L10">Endlessly</text><text for="L11">Endlessly</text><text for="L12">Ceaselessly</text><text for="L13">It repeats</text><text for="L14">It repeats</text><text for="L15">It repeats</text><text for="L16">It repeats</text><text for="L17">It repeats</text><text for="L18">It repeats</text><text for="L19">It repeats</text><text for="L20">It repeats</text><text for="L21">The screaming</text><text for="L22">The left arm I’ve caught with was sweet</text><text for="L23">The right arm I’ve swung with was sweet</text><text for="L24">It was sweet</text><text for="L25">It was sweet</text><text for="L26">Even if my mouth with a smile gets torn</text><text for="L27">That’s just fun, so fun</text><text for="L28">So fun</text><text for="L29">Like burning a brain</text><text for="L30">So fun</text><text for="L31">So fun</text><text for="L32">I’m shaking</text><text for="L33">I’m shaking</text><text for="L34">So fun</text><text for="L35">So fun</text><text for="L36">Red</text><text for="L37">Red</text><text for="L38">Red</text><text for="L39">Red</text><text for="L40">Red</text><text for="L41">Sweet</text><text for="L42">Sweet</text><text for="L43">Sweet</text><text for="L44">Sweet</text><text for="L45">Sweet</text><text for="L46">Sweet</text><text for="L47">Sweet</text><text for="L48">Sweet</text><text for="L49">Sweet</text><text for="L50">Young girl</text><text for="L51">You and I</text><text for="L52">Red</text><text for="L53">Red</text><text for="L54">Red</text><text for="L55">Red</text><text for="L56">Red</text><text for="L57">Sweet</text><text for="L58">Sweet</text><text for="L59">Sweet</text><text for="L60">Sweet</text><text for="L61">Red</text><text for="L62">Red</text><text for="L63">Red</text><text for="L64">Red</text><text for="L65">Red</text><text for="L66">You... So sweet!</text><text for="L67">Sweet</text><text for="L68">Red</text><text for="L69">Red</text><text for="L70">I’ll kill you!</text><text for="L71">My dewy eyes are deep crimson, I ruffle my sweetly colored skirt</text><text for="L72">My childish cheeks are flushed crimson, my legs collapse in tingly pain</text><text for="L73">You’re controlled by these sweet hallucinations, I play a tune that blooms from my five fingers</text><text for="L74">In the sound of the red black tea dripping, I gouge you deep when I toy with you <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(With you)</span></text><text for="L75">"Will my thoughts not reach you?"</text><text for="L76">"Who is reflected in your eyes?"</text><text for="L77">"Is my heart broken?"</text><text for="L78">"It won’t come back if it breaks?"</text><text for="L79">"Will deeply cut wounds never heal?"</text><text for="L80">"Will you tick away the time in that way?"</text><text for="L81">All of you, I want it, I want it so much I’m shaking <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Notice my feelings. Why won’t you notice my feelings?)</span></text><text for="L82">Shall I completely pierce through your sweet pulse and stop it? <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(I’m overflowing with insanity, how can I stop?)</span></text><text for="L83">It’s only me who will completely soil your skin and humiliate you <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Where will I make my way to when my feelings break down?)</span></text><text for="L84">I’m shaken when you adore me and pat me, so kill my urges <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(My love is overflowing, I can’t stop it...)</span></text><text for="L85">You make your throat hoarse screaming a timbre, the melody turns into a crimson rainbow</text><text for="L86">This hue from slaughtering you, what a sweet, deep color it releases!</text><text for="L87">You make your throat hoarse screaming a timbre, if it’s colored by the red rain</text><text for="L88">It’ll be the completion of the beautiful stage, and I’ll dance alone there <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Alone there)</span></text><text for="L89">"Did your wishes get ruined?"</text><text for="L90">"Have those thoughts been suppressed?"</text><text for="L91">"Has that hope been severed?"</text><text for="L92">"Have those pupils been set aflame?"</text><text for="L93">"Has that skin been defiled?"</text><text for="L94">"And then there were none?"</text><text for="L95">Your life is torn apart, you spit up something red and silver and they spray away <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(The true me is no longer anywhere…)</span></text><text for="L96">I scatter the flower of your life, blooming in rich colors, and turn you into my food <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(What transient life, so beautiful and lovely...)</span></text><text for="L97">If your life is you, then I’ll eat you up into flesh and blood <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(There is nothing for you to do but become mine forever and ever...)</span></text><text for="L98">I’ll offer up your limbs as sacrifice- Become the corpse at my feet <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Be by my side forever, because I won’t let you live anymore...)</span></text><text for="L99">Inside of me <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Notice my feelings…)</span></text><text for="L100">Inside of me</text><text for="L101">Inside of me</text><text for="L102">Myself</text><text for="L103">There’s one to describe it</text><text for="L104">There’s one to describe it</text><text for="L105">One word</text><text for="L106">Endlessly</text><text for="L107">Endlessly</text><text for="L108">Endlessly</text><text for="L109">Endlessly <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(I’m overflowing with insanity)</span></text><text for="L110">Ceaselessly</text><text for="L111">It repeats</text><text for="L112">It repeats</text><text for="L113">It repeats</text><text for="L114">It repeats</text><text for="L115">It repeats</text><text for="L116">It repeats</text><text for="L117">It repeats</text><text for="L118">It repeats</text><text for="L119">The screaming</text><text for="L120">The left arm I’ve caught with was sweet <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(When my feelings break down)</span></text><text for="L121">The right arm I’ve swung with was sweet</text><text for="L122">It was sweet</text><text for="L123">It was sweet</text><text for="L124">Even if my mouth with a smile gets torn</text><text for="L125">That’s just fun, so fun <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(My love is overflowing)</span></text><text for="L126">So fun</text><text for="L127">Like burning a brain</text><text for="L128">So fun</text><text for="L129">So fun</text><text for="L130">I’m shaking <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(I can’t stop it)</span></text><text for="L131">I’m shaking</text><text for="L132">So fun</text><text for="L133">So fun</text><text for="L134">Notice my feelings. Why won’t you notice my feelings?</text><text for="L135">I’m overflowing with insanity, how can I stop?</text><text for="L136">Where will I make my way to when my feelings break down?</text><text for="L137">My love is overflowing, I can’t stop it...</text><text for="L138">Red</text><text for="L139">Red</text><text for="L140">Red</text><text for="L141">Red</text><text for="L142">Red</text><text for="L143">Red</text><text for="L144">Sweet</text><text for="L145">Sweet</text><text for="L146">Sweet</text><text for="L147">Sweet</text><text for="L148">Sweet</text><text for="L149">Sweet</text><text for="L150">Sweet</text><text for="L151">Sweet</text><text for="L152">Sweet</text><text for="L153">Young girl</text><text for="L154">You and I</text><text for="L155">Red</text><text for="L156">Red</text><text for="L157">Red</text><text for="L158">Red</text><text for="L159">Red</text><text for="L160">Sweet</text><text for="L161">Sweet</text><text for="L162">Sweet</text><text for="L163">Sweet</text><text for="L164">Red</text><text for="L165">Red</text><text for="L166">Red</text><text for="L167">Red</text><text for="L168">Red</text><text for="L169">You... So sweet!</text><text for="L170">Sweet</text><text for="L171">Red</text><text for="L172">Red</text><text for="L173">I’ll kill you!</text><text for="L174">Your life is torn apart, you spit up something red and silver and they spray away <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(I want to stay like this, in my beautiful world...)</span></text><text for="L175">I scatter the flower of your life, blooming in rich colors, and turn you into my food <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(The memories dance, let me make you mine...)</span></text><text for="L176">If your life is you, then I’ll eat you up into flesh and blood <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(I’m sorry, but this is a final act of love...)</span></text><text for="L177">I’ll offer up your limbs as sacrifice- Become the corpse at my feet <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(Be by my side forever, I want to live with you...)</span></text></translation><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">我身体中的</text><text for="L2">我身体中的</text><text for="L3">我身体中的</text><text for="L4">我</text><text for="L5">要把这一个</text><text for="L6">要把这一个</text><text for="L7">单词</text><text for="L8">一次次地</text><text for="L9">一次次地</text><text for="L10">一次次地</text><text for="L11">一次次地</text><text for="L12">无休止地</text><text for="L13">重复</text><text for="L14">重复</text><text for="L15">重复</text><text for="L16">重复</text><text for="L17">重复</text><text for="L18">重复</text><text for="L19">重复</text><text for="L20">重复</text><text for="L21">歌唱</text><text for="L22">紧握的左手腥甜</text><text for="L23">挥舞的右手腥甜</text><text for="L24">腥甜</text><text for="L25">腥甜</text><text for="L26">笑著的嘴巴裂著</text><text for="L27">即使如此依然很快乐</text><text for="L28">好快乐</text><text for="L29">脑髓在燃烧</text><text for="L30">好快乐</text><text for="L31">好快乐</text><text for="L32">震动</text><text for="L33">震动</text><text for="L34">好快乐</text><text for="L35">好快乐</text><text for="L36">好红</text><text for="L37">好红</text><text for="L38">好红</text><text for="L39">好红</text><text for="L40">好红</text><text for="L41">好甜</text><text for="L42">好甜</text><text for="L43">好甜</text><text for="L44">好甜</text><text for="L45">好甜</text><text for="L46">好甜</text><text for="L47">好甜</text><text for="L48">好甜</text><text for="L49">好甜</text><text for="L50">天真的少女</text><text for="L51">我和你</text><text for="L52">好红</text><text for="L53">好红</text><text for="L54">好红</text><text for="L55">好红</text><text for="L56">好红</text><text for="L57">好甜</text><text for="L58">好甜</text><text for="L59">好甜</text><text for="L60">好甜</text><text for="L61">好红</text><text for="L62">好红</text><text for="L63">好红</text><text for="L64">好红</text><text for="L65">好红</text><text for="L66">你 好甜</text><text for="L67">好甜</text><text for="L68">好红</text><text for="L69">好红</text><text for="L70">让我杀了你！</text><text for="L71">深红的温润眼眸 艳色的裙尾摇摆</text><text for="L72">幼小的脸颊浸染朱红 疼痛撕裂了双腿</text><text for="L73">被甜美的幻视支配 伸展五指弹奏的旋律</text><text for="L74">赤色红茶滴下的声音 是我向深处剜心 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(剜心)</span></text><text for="L75">“这份思念无法传达吗？”</text><text for="L76">“那双眼眸映出的是谁？”</text><text for="L77">“心已毁坏了吗？”</text><text for="L78">“毁坏后无法恢复了吗？”</text><text for="L79">“受的伤害无法痊愈了吗？”</text><text for="L80">“这样做能刻画下时间吗？”</text><text for="L81">我想要你的全部 想到浑身颤抖 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(希望你察觉我的心情 为什麼没有察觉到呢？)</span></text><text for="L82">就让那甜美的心跳 竭尽气力就此停止吧 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(渐渐地被陷入疯狂 无论怎样也无法抑止)</span></text><text for="L83">尽情弄脏那片肌肤 污辱你的只有我 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(心情都被毁坏 接著该如何是好)</span></text><text for="L84">快点平息这份爱抚 和操弄你的冲动吧 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(爱就要满溢出来 无法停止……)</span></text><text for="L85">声嘶力竭歌唱的音色 旋律化作朱之虹</text><text for="L86">这一抹屠杀你的色彩 又甜又深的颜色</text><text for="L87">声嘶力竭歌唱的音色 赤色的雨四处飞溅</text><text for="L88">筑成华丽的舞台 我在上面独自起舞 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(起舞)</span></text><text for="L89">“希望破灭了吗？”</text><text for="L90">“思念断绝了吗？”</text><text for="L91">“希望磨灭了吗？”</text><text for="L92">“目光燃烧了吗？”</text><text for="L93">“肌肤污秽了吗？”</text><text for="L94">“大家都离开我了吗？”</text><text for="L95">就算把这具身体撕裂 只有赤银烟雾扩散 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(不存在真正的我 因为哪里都不存在)</span></text><text for="L96">让那具身体四分五裂 绽放鲜艳的色彩即我的粮食 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(真是虚幻的生命 美丽又可爱)</span></text><text for="L97">如果那具身体就是你 我会将肉都吃得干干净净 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(你只能永远 成为我的东西)</span></text><text for="L98">把四肢作为供物 让你成为我脚边的死尸 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(一直在我身边 再也不放你走……)</span></text><text for="L99">我身体中的 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(希望你察觉我的心情……)</span></text><text for="L100">我身体中的</text><text for="L101">我身体中的</text><text for="L102">我</text><text for="L103">要把这一个</text><text for="L104">要把这一个</text><text for="L105">单词</text><text for="L106">一次次地</text><text for="L107">一次次地</text><text for="L108">一次次地</text><text for="L109">一次次地 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(变得愈发疯狂……)</span></text><text for="L110">无休止地</text><text for="L111">重复</text><text for="L112">重复</text><text for="L113">重复</text><text for="L114">重复</text><text for="L115">重复</text><text for="L116">重复</text><text for="L117">重复</text><text for="L118">重复</text><text for="L119">歌唱</text><text for="L120">紧握的左手腥甜 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(心情都被毁坏……)</span></text><text for="L121">挥舞的右手腥甜</text><text for="L122">腥甜</text><text for="L123">腥甜</text><text for="L124">笑著的嘴巴裂著</text><text for="L125">即使如此依然很快乐 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(满怀着爱前行)</span></text><text for="L126">好快乐</text><text for="L127">脑髓在燃烧</text><text for="L128">好快乐</text><text for="L129">好快乐</text><text for="L130">震动 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(无法停止脚步)</span></text><text for="L131">震动</text><text for="L132">好快乐</text><text for="L133">好快乐</text><text for="L134">希望你察觉我的心情 为什麼没有察觉到呢？</text><text for="L135">渐渐地被陷入疯狂 无论怎样也无法抑止</text><text for="L136">心情都被毁坏 接著该如何是好</text><text for="L137">爱就要满溢出来 无法停止……</text><text for="L138">好红</text><text for="L139">好红</text><text for="L140">好红</text><text for="L141">好红</text><text for="L142">好红</text><text for="L143">好红</text><text for="L144">好甜</text><text for="L145">好甜</text><text for="L146">好甜</text><text for="L147">好甜</text><text for="L148">好甜</text><text for="L149">好甜</text><text for="L150">好甜</text><text for="L151">好甜</text><text for="L152">好甜</text><text for="L153">天真的少女</text><text for="L154">我和你</text><text for="L155">好红</text><text for="L156">好红</text><text for="L157">好红</text><text for="L158">好红</text><text for="L159">好红</text><text for="L160">好甜</text><text for="L161">好甜</text><text for="L162">好甜</text><text for="L163">好甜</text><text for="L164">好红</text><text for="L165">好红</text><text for="L166">好红</text><text for="L167">好红</text><text for="L168">好红</text><text for="L169">你 好甜</text><text for="L170">好甜</text><text for="L171">好红</text><text for="L172">好红</text><text for="L173">让我杀了你！</text><text for="L174">就算把这具身体撕裂 只有赤银烟雾扩散 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(只想永远这样，停留在我的美丽世界里……)</span></text><text for="L175">让那具身体四分五裂 绽放鲜艳的色彩即我的粮食 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(记忆在跳舞，让我将你据为己有……)</span></text><text for="L176">如果那具身体就是你 我会将肉都吃得干干净净 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(我很抱歉，但这是最后的爱了……)</span></text><text for="L177">把四肢作为供物 让你成为我脚边的死尸 <span xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg" xmlns="http://www.w3.org/ns/ttml">(永远陪在我身边，我想和你永远在一起……)</span></text></translation></translations><songwriters><songwriter>EastNewSound</songwriter></songwriters><transliterations><transliteration xml:lang="ja-Latn"><text for="L1"><span begin="1.600" end="1.970" xmlns="http://www.w3.org/ns/ttml">wa ta shi</span> <span begin="1.970" end="2.070" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="2.070" end="2.340" xmlns="http://www.w3.org/ns/ttml">na ka</span> <span begin="2.340" end="2.540" xmlns="http://www.w3.org/ns/ttml">no</span></text><text for="L2"><span begin="2.400" end="2.740" xmlns="http://www.w3.org/ns/ttml">wa ta shi</span> <span begin="2.740" end="2.840" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="2.840" end="3.110" xmlns="http://www.w3.org/ns/ttml">na ka</span> <span begin="3.110" end="3.280" xmlns="http://www.w3.org/ns/ttml">no</span></text><text for="L3"><span begin="3.200" end="3.520" xmlns="http://www.w3.org/ns/ttml">wa ta shi</span> <span begin="3.520" end="3.600" xmlns="http://www.w3.org/ns/ttml">no</span> <span begin="3.600" end="3.880" xmlns="http://www.w3.org/ns/ttml">na ka</span> <span begin="3.880" end="4.000" xmlns="http://www.w3.org/ns/ttml">no</span></text><text for="L4"><span begin="4.010" end="4.370" xmlns="http://www.w3.org/ns/ttml">wa ta shi</span> <span begin="4.370" end="4.470" xmlns="http://www.w3.org/ns/ttml">ga</span></text><text for="L5"><span begin="4.820" end="4.900" xmlns="http://www.w3.org/ns/ttml">hi</span> <span begin="4.900" end="5.050" xmlns="http://www.w3.org/ns/ttml">to</span> <span begin="5.050" end="5.230" xmlns="http://www.w3.org/ns/ttml">tsu</span> <span begin="5.230" end="5.320" xmlns="http://www.w3.org/ns/ttml">no</span></text><text for="L6"><span begin="5.140" end="5.250" xmlns="http://www.w3.org/ns/ttml">hi</span> <span begin="5.250" end="5.430" xmlns="http://www.w3.org/ns/ttml">to</span> <span begin="5.430" end="5.620" xmlns="http://www.w3.org/ns/ttml">tsu</span> <span begin="5.620" end="5.790" xmlns="http://www.w3.org/ns/ttml">no</span></text><text for="L7"><span begin="5.580" end="5.860" xmlns="http://www.w3.org/ns/ttml">tan</span> <span begin="5.860" end="5.990" xmlns="http://www.w3.org/ns/ttml">go</span> <span begin="5.990" end="6.190" xmlns="http://www.w3.org/ns/ttml">o</span></text><text for="L8"><span begin="6.410" end="6.660" xmlns="http://www.w3.org/ns/ttml">nan</span> <span begin="6.660" end="6.780" xmlns="http://www.w3.org/ns/ttml">do</span> <span begin="6.780" end="6.980" xmlns="http://www.w3.org/ns/ttml">mo</span></text><text for="L9"><span begin="6.780" end="7.010" xmlns="http://www.w3.org/ns/ttml">nan</span> <span begin="7.010" end="7.110" xmlns="http://www.w3.org/ns/ttml">do</span> <span begin="7.110" end="7.200" xmlns="http://www.w3.org/ns/ttml">mo</span></text><text for="