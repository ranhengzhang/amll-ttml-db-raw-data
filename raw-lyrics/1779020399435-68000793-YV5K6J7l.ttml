<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="en"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="Rubia"/><amll:meta key="musicName" value="崩坏3《渡尘》动画短片印象曲"/><amll:meta key="artists" value="HOYO-MiX"/><amll:meta key="artists" value="周深"/><amll:meta key="artists" value="Charlie"/><amll:meta key="album" value="Rubia"/><amll:meta key="album" value="Rubia (Honkai Impact 3rd Impressions)"/><amll:meta key="album" value="Rubia (Honkai Impact 3rd Impressions) - Single"/><amll:meta key="ncmMusicId" value="1815684465"/><amll:meta key="qqMusicId" value="296021954"/><amll:meta key="qqMusicId" value="001OPnK236dSE7"/><amll:meta key="spotifyId" value="1cyGvXPHdd5yG0Hrf9Ms8x"/><amll:meta key="appleMusicId" value="1666688997"/><amll:meta key="isrc" value="DGA072105996"/><amll:meta key="Arranger" value="宫奇 Gon"/><amll:meta key="Composer" value="蔡近翰"/><amll:meta key="Performer" value="周深"/><amll:meta key="Performer" value="HOYO-MiX"/><amll:meta key="Producer" value="蔡近翰"/><amll:meta key="Remixer" value="宫奇 Gon"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="ja"><text for="L1">咲き誇る命の花</text><text for="L2">遠くて近くに</text><text for="L3">君のことを待ち続け</text><text for="L4">拠り所へ導くよ</text><text for="L5">絶えることない雨の中</text><text for="L6">行き交う足跡も消え去る</text><text for="L7">この場所に居た君も</text><text for="L8">いずれは何処に往くのだろう</text><text for="L9">君のため息も呼吸も</text><text for="L10">風の吐息と共に私に触れる</text><text for="L11">まだまだ続く私たちの物語</text><text for="L12">次のページを描いていこう</text><text for="L13">咲き誇る命の花</text><text for="L14">遠くて近くに</text><text for="L15">君のことを待ち続け</text><text for="L16">拠り所へ導くよ</text><text for="L17">浮世の歳月が流れ</text><text for="L18">終わらない私の旅路</text><text for="L19">君を抱き締める</text><text for="L20">一枝のアカネを捧げるまで</text><text for="L21">川の流れを遡り</text><text for="L22">澪はやがて一つに繋がる</text><text for="L23">根源にたどり着いた頃には</text><text for="L24">迷いも戸惑いもなくなる</text><text for="L25">花吹雪が目に映り</text><text for="L26">挽歌が讚歌に変わる時</text><text for="L27">私の呼びがけに応えて</text><text for="L28">君と二重唱を奏でよう</text><text for="L29">咲き誇る命の花</text><text for="L30">遠くて近くに</text><text for="L31">君のことを待ち続け</text><text for="L32">拠り所へ導くよ</text><text for="L33">浮世の歳月が流れ</text><text for="L34">終わらない私の旅路</text><text for="L35">君を抱き締める</text><text for="L36">一枝のアカネを捧げるまで</text><text for="L37">咲き誇る命の花</text><text for="L38">遠くて近くに</text><text for="L39">君のことを待ち続け</text><text for="L40">拠り所へ導くよ</text><text for="L41">浮世の歳月が流れ</text><text for="L42">終わらない私の旅路</text><text for="L43">君を抱き締める</text><text for="L44">一枝のアカネを捧げるまで</text></translation><translation type="subtitle" xml:lang="ko"><text for="L1">생명은 꽂처럼</text><text for="L2">멀리 혹은 길가에 피어나</text><text for="L3">그 자람을 기다리며</text><text for="L4">돌아가는 길을 찾아</text><text for="L5">수 천 번외 비에 씻겨</text><text for="L6">오고 가는 발자국은 이미 사라졌네</text><text for="L7">이곳을 지나던 그대</text><text for="L8">어디에 속할 것인가</text><text for="L9">바람에 실린 마지막 울부짖음 속</text><text for="L10">당신의 한숨과 숨결이 느껴져</text><text for="L11">마지막 장의 이야기는 시작하지 않았기에</text><text for="L12">아직 모든 게 끝난 게 아니야</text><text for="L13">생명은 꽂처럼</text><text for="L14">멀리 혹은 길가에 피어나</text><text for="L15">그 자람을 기다리며</text><text for="L16">돌아가는 길을 찾아</text><text for="L17">시간은 세계를 가로지르고</text><text for="L18">내 여정은 끝니지 않겠지</text><text for="L19">당신의 품에 닿을 때까지</text><text for="L20">그대의 바보가 될게</text><text for="L21">개울을 거슬러 올라가다 보면</text><text for="L22">무수한 물길도 하나로 합쳐지겠지</text><text for="L23">뿌리를 쫒을 때</text><text for="L24">더는 길을 잃지 않아</text><text for="L25">꽂잎이 흩날리는 게 보인다면</text><text for="L26">슬픔의 소리가 송가가 될 때</text><text for="L27">내 목소리를 들어줘</text><text for="L28">당신과 함께 노래하고 싶어</text><text for="L29">생명은 꽂처럼</text><text for="L30">멀리 혹은 길가에 피어나</text><text for="L31">그 자람을 기다리며</text><text for="L32">돌아가는 길을 찾아</text><text for="L33">시간은 세계를 가로지르고</text><text for="L34">내 여정은 끝니지 않겠지</text><text for="L35">당신의 품에 닿을 때까지</text><text for="L36">그대의 바보가 될게</text><text for="L37">생명은 꽂처럼</text><text for="L38">멀리 혹은 길가에 피어나</text><text for="L39">그 자람을 기다리며</text><text for="L40">돌아가는 길을 찾아</text><text for="L41">시간은 세계를 가로지르고</text><text for="L42">내 여정은 끝니지 않겠지</text><text for="L43">당신의 품에 닿을 때까지</text><text for="L44">그대의 바보가 될게</text></translation><translation type="subtitle" xml:lang="zh-Hant"><text for="L1">生命如花朵綻放</text><text for="L2">或許遙遠，或許就在路邊</text><text for="L3">等待著那個人</text><text for="L4">找到回歸的路</text><text for="L5">雨水數千次的沖刷</text><text for="L6">已經分辨不清來往的腳印</text><text for="L7">曾經過此處的你</text><text for="L8">終將屬於哪裡</text><text for="L9">我察覺到你的嘆息與呼吸</text><text for="L10">在風最後的呼嘯之中</text><text for="L11">還未到將故事翻至末頁的時候</text><text for="L12">所以一切還未結束</text><text for="L13">生命如花朵綻放</text><text for="L14">或許遙遠，或許就在路邊</text><text for="L15">等待著那個人</text><text for="L16">找到回歸的路</text><text for="L17">時光流淌過天地間</text><text for="L18">我的旅程不會結束</text><text for="L19">直至能與你相擁</text><text for="L20">並獻上一株茜草</text><text for="L21">沿著溪流向上</text><text for="L22">無數水流終將合一</text><text for="L23">追溯著源頭</text><text for="L24">便可不再迷惘</text><text for="L25">你將看見花瓣紛飛</text><text for="L26">將悲傷之音轉而歌頌</text><text for="L27">請你聽見我的聲音</text><text for="L28">正渴望與你二重唱</text><text for="L29">生命如花朵綻放</text><text for="L30">或許遙遠，或許就在路邊</text><text for="L31">等待著那個人</text><text for="L32">找到回歸的路</text><text for="L33">時光流淌過天地間</text><text for="L34">我的旅程不會結束</text><text for="L35">直至能與你相擁</text><text for="L36">並獻上一株茜草</text><text for="L37">生命如花朵綻放</text><text for="L38">或許遙遠，或許就在路邊</text><text for="L39">等待著那個人</text><text for="L40">找到回歸的路</text><text for="L41">時光流淌過天地間</text><text for="L42">我的旅程不會結束</text><text for="L43">直至能與你相擁</text><text for="L44">並獻上一株茜草</text></translation><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">生命如花朵绽放</text><text for="L2">或许遥远，或许就在路边</text><text for="L3">等待着那个人</text><text for="L4">找到回家的路</text><text for="L5">雨水数千次的冲刷</text><text for="L6">已经分辨不清来往的脚印</text><text for="L7">曾经过此处的你</text><text for="L8">终将属于哪里</text><text for="L9">我察觉到你的叹息与呼吸</text><text for="L10">在风最后的呼啸之中</text><text for="L11">还未到将故事翻至末页的时候</text><text for="L12">所以一切还未结束</text><text for="L13">生命如花朵绽放</text><text for="L14">遥不可及，或触手可得</text><text for="L15">等待着那个人</text><text for="L16">找到回家的路</text><text for="L17">时光流淌过天地间</text><text for="L18">我的旅程不会结束</text><text for="L19">直至能与你相拥</text><text for="L20">并献上一株茜草</text><text for="L21">沿着溪流向上</text><text for="L22">无数水流终将合一</text><text for="L23">追溯着源头</text><text for="L24">便可不再迷惘</text><text for="L25">你将看见花瓣纷飞</text><text for="L26">当悲伤之音转而歌颂</text><text for="L27">请你听见我的声音</text><text for="L28">正渴望与你二重唱</text><text for="L29">生命如花朵绽放</text><text for="L30">或许遥远，或许就在路边</text><text for="L31">等待着那个人</text><text for="L32">找到回家的路</text><text for="L33">时光流淌过天地间</text><text for="L34">我的旅程不会结束</text><text for="L35">直至能与你相拥</text><text for="L36">并献上一株茜草</text><text for="L37">生命如花朵绽放</text><text for="L38">或许遥远，或许就在路边</text><text for="L39">等待着那个人</text><text for="L40">找到回家的路</text><text for="L41">时光流淌过天地间</text><text for="L42">我的旅程不会结束</text><text for="L43">直至能与你相拥</text><text for="L44">并献上一株茜草</text></translation></translations><songwriters><songwriter>蔡近翰</songwriter><songwriter>TetraCalyx</songwriter></songwriters><transliterations/></iTunesMetadata></metadata></head><body dur="3:05.090"><div begin="3.410" end="16.270" itunes:songPart="Verse"><p begin="3.410" end="6.390" itunes:key="L1" ttm:agent="v1"><span begin="3.410" end="3.990">Life</span> <span begin="4.480" end="5.110">bloom</span><span begin="5.110" end="5.270">s</span> <span begin="5.270" end="5.700">li</span><span begin="5.700" end="5.830">ke a</span> <span begin="5.830" end="6.030">f</span><span begin="6.030" end="6.390">lower</span></p><p begin="6.940" end="9.790" itunes:key="L2" ttm:agent="v1"><span begin="6.940" end="7.4