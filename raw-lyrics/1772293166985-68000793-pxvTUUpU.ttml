<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" itunes:timing="Word" xml:lang="en"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="The Song of You and Me (Bubbles Solo)"/><amll:meta key="musicName" value="The Song of You and Me (feat. Bubbles) (Acoustic Version)"/><amll:meta key="musicName" value="The Song of You and Me - Acoustic Version"/><amll:meta key="musicName" value="The Song of You and Me (feat. Bubbles) [Acoustic Version]"/><amll:meta key="artists" value="泡泡"/><amll:meta key="artists" value="Bubbles"/><amll:meta key="artists" value="伊野奏"/><amll:meta key="artists" value="inosoo"/><amll:meta key="artists" value="HoYoFair"/><amll:meta key="album" value="The Song of You and Me（泡泡独唱）"/><amll:meta key="album" value="Star Rail HoYoFair Music Selection #5 &quot;Astronuts&quot;"/><amll:meta key="ncmMusicId" value="3348966852"/><amll:meta key="qqMusicId" value="0008ABAz0cO1yc"/><amll:meta key="qqMusicId" value="640106078"/><amll:meta key="spotifyId" value="3VxVHwpbbdHOzQpV9CljtW"/><amll:meta key="BvId" value="BV1nwFrzAEq4"/><amll:meta key="appleMusicId" value="1875530187"/><amll:meta key="Guitar" value="李单阳"/><amll:meta key="Mix" value="VVK"/><amll:meta key="Producer" value="inosoo"/><amll:meta key="Producer" value="HoYoFair"/><amll:meta key="Vocals" value="伊野奏inosoo"/><amll:meta key="Vocals" value="HoYoFair"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="de"><text for="L1">Blätter werden fallen und Flüsse steigen</text><text for="L2">Minuten strecken sich in der Zeit zu Meilen</text><text for="L3">Wir werden uns vielleicht trennen, aber verstehst du nicht, es</text><text for="L4">Waren immer du und ich</text><text for="L5">Du bist einst mit mir gegangen</text><text for="L6">Mir immer einen Schritt voraus</text><text for="L7">Kiesel kickend auf deinem Weg</text><text for="L8">Etwas sanftes und tiefes summend</text><text for="L9">Ich bin jetzt etwas größer</text><text for="L10">Manchmal singe ich es laut</text><text for="L11">Dieses Lied von dir und mir</text><text for="L12">Der Sonnenuntergang schwindet und die Sterne steigen auf</text><text for="L13">Gedanken an dich ziehen durch den Himmel</text><text for="L14">Durch das Leben und alles, was wir gesehen haben sind es</text><text for="L15">Waren immer du und ich</text><text for="L16">Also hab keine Angst, wir werden einander finden</text><text for="L17">Am Ende oder am Anfang, wir werden beisammen sein</text><text for="L18">Die Zeit dreht sich unaufhörlich</text><text for="L19">Mein Liebster, ich werde dich finden, gesund und wohlbehalten</text><text for="L20">Durch alles, das noch sein wird gibt es</text><text for="L21">Etwas das so sein soll</text><text for="L22">Der Sonnenuntergang schwindet und die Sterne steigen auf</text><text for="L23">Gedanken an dich ziehen durch den Himmel</text><text for="L24">Durch das Leben und alles, was wir gesehen haben sind es</text><text for="L25">Waren immer du und ich</text></translation><translation type="subtitle" xml:lang="es"><text for="L1">Las hojas caerán, y los ríos subirán</text><text for="L2">Los minutos se extienden hasta volverse millas en el tiempo</text><text for="L3">Podemos separarnos, pero ¿no ves?</text><text for="L4">Siempre hemos sido tú y yo</text><text for="L5">Solías caminar conmigo</text><text for="L6">Siempre un paso por delante de mí</text><text for="L7">Pateando piedras al pasar</text><text for="L8">Tarareando algo suave y bajo</text><text for="L9">Ahora soy un poco más alta</text><text for="L10">A veces canto en voz alta</text><text for="L11">Esta canción tuya y mía</text><text for="L12">El sol se pone, las estrellas se elevan</text><text for="L13">Mis pensamientos sobre ti viajan por los cielos</text><text for="L14">A través de la vida y todo lo que hemos visto</text><text for="L15">Siempre hemos sido tú y yo</text><text for="L16">Así que no temas, nos encontraremos el uno al otro</text><text for="L17">Ya sea al final o al principio, estaremos juntos</text><text for="L18">El tiempo gira una y otra vez</text><text for="L19">Camarada, te encontraré, a salvo y en paz</text><text for="L20">A través de todo lo que aún está por venir</text><text for="L21">Hay algo destinado a ser</text><text for="L22">El sol se pone, las estrellas se elevan</text><text for="L23">Mis pensamientos sobre ti viajan por los cielos</text><text for="L24">A través de la vida y todo lo que hemos visto</text><text for="L25">Siempre hemos sido tú y yo</text></translation><translation type="subtitle" xml:lang="fr"><text for="L1">Les feuilles tombent, et les rivières montent</text><text for="L2">Les minutes s'étirent en distance</text><text for="L3">On peut se séparer, mais tu vois</text><text for="L4">C'est toujours toi et moi</text><text for="L5">Tu marchais avec moi</text><text for="L6">Toujours un pas devant</text><text for="L7">Donnant des coups de pied aux cailloux</text><text for="L8">Fredonnant quelque chose de doux</text><text for="L9">Je suis un peu plus grande maintenant</text><text for="L10">Parfois, je chante à voix haute</text><text for="L11">Cette chanson, qui n'appartient qu'à nous deux</text><text for="L12">Le crépuscule s'efface, et les étoiles se lèvent</text><text for="L13">Mes pensées envers toi, traversent les cieux</text><text for="L14">À travers la vie et tout ce qu'on a vu</text><text for="L15">C'est toujours toi et moi</text><text for="L16">N'aie pas peur,, on se retrouvera</text><text for="L17">À la fin ou au début,, on sera ensemble</text><text for="L18">Le temps tourne encore et encore</text><text for="L19">Mon amour, je te retrouverai,, sain et sauf</text><text for="L20">À travers tout l'avenir</text><text for="L21">Il y a quelque chose à venir</text><text for="L22">Le crépuscule s'efface, et les étoiles se lèvent</text><text for="L23">Mes pensées envers toi, traversent les cieux</text><text for="L24">À travers la vie et tout ce qu'on a vu</text><text for="L25">C'est toujours toi et moi</text></translation><translation type="subtitle" xml:lang="id"><text for="L1">Daun berguguran, air sungai meninggi</text><text for="L2">Detik demi detik membentang menjadi ribuan mil</text><text for="L3">Kita mungkin terpisah, tapi lihatlah</text><text for="L4">Kau dan aku selalu bersama</text><text for="L5">Dulu kau berjalan bersamaku</text><text for="L6">Selalu satu langkah di depanku</text><text for="L7">Menendang kerikil sepanjang jalan</text><text for="L8">Bersenandung lembut dan merdu</text><text for="L9">Kini aku sedikit lebih tinggi</text><text for="L10">Terkadang juga bernyanyi dengan lantang</text><text for="L11">Lagu tentang aku dan kau</text><text for="L12">Mentari terbenam, bintang-bintang terbit</text><text for="L13">Kerinduanku padamu melintasi langit</text><text for="L14">Mengalami kehidupan dan semua yang telah kita lalui</text><text for="L15">Kau dan aku selalu bersama</text><text for="L16">Jadi jangan takut, kita kan menemukan satu sama lain</text><text for="L17">Baik di akhir maupun awal, kita akan selalu bersama</text><text for="L18">Waktu terus berputar</text><text for="L19">Sayang, akan kutemukan dirimu, aman tenteram</text><text for="L20">Melintasi segala yang belum terjadi</text><text for="L21">Di sana adalah yang ditakdirkan</text><text for="L22">Mentari terbenam, bintang-bintang terbit</text><text for="L23">Kerinduanku padamu melintasi langit</text><text for="L24">Mengalami kehidupan dan semua yang telah kita lalui</text><text for="L25">Kau dan aku selalu bersama</text></translation><translation type="subtitle" xml:lang="ja"><text for="L1">葉が落ち 川は満ちて</text><text for="L2">時間はまるで 遠くへ続く道のよう</text><text for="L3">離れ離れになっても</text><text for="L4">私はあなたのそばにいる</text><text for="L5">あなたはいつも 私と一緒で</text><text for="L6">私よりほんの少し 前を歩いてた</text><text for="L7">小石を蹴って進み</text><text for="L8">優しい歌を歌ってた</text><text for="L9">いつしか私の背も伸びて</text><text for="L10">時には 声に出して歌うんだ</text><text for="L11">これは あなたと私の歌</text><text for="L12">日が沈んで 星が昇れば</text><text for="L13">あなたへの想いが 空にはじける</text><text for="L14">歩んだ道 目にしたすべての中で</text><text for="L15">私はあなたのそばにいる</text><text for="L16">恐れないで きっとまた会えるから</text><text for="L17">終わりだって 始まりだって 一緒だから</text><text for="L18">どんなに時が巡っても</text><text for="L19">大切なあなたを きっと見つけるから</text><text for="L20">これから起こる何もかも</text><text for="L21">その先で運命に辿り着く</text><text for="L22">日が沈んで 星が昇れば</text><text for="L23">あなたへの想いが 空にはじける</text><text for="L24">歩んだ道 目にしたすべての中で</text><text for="L25">私はあなたのそばにいる</text></translation><translation type="subtitle" xml:lang="ko"><text for="L1">낙엽이 떨어지고 강물이 차올라</text><text for="L2">매 순간은 시간 속에서 아득한 여정이 돼</text><text for="L3">우린 헤어질지도 몰라\N하지만 넌 알까</text><text for="L4">너와 난 언제나 함께야</text><text for="L5">넌 나와 함께 걷곤 했어</text><text for="L6">항상 나보다 한발 앞섰지</text><text for="L7">발로 작은 돌멩이를 차며</text><text for="L8">부드러운 멜로디를 흥얼거렸지</text><text for="L9">난 이제 조금 더 컸어</text><text for="L10">때로는 목청껏 노래를 부르기도 해</text><text for="L11">너와 나의 이 노래를</text><text for="L12">석양이 지고 별이 떠올라</text><text for="L13">널 향한 그리움이 하늘을 가로질러</text><text for="L14">인생을 살아가며 우리가 보는 모든 장면에서</text><text for="L15">너와 난 언제나 함께야</text><text for="L16">그러니 두려워 마, 우린 다시 서로를 찾을 거야</text><text for="L17">종착지에서든 출발점에서든\N우린 늘 함께할 거야</text><text for="L18">시간은 끊임없이 흘러가도</text><text for="L19">내 사랑, 널 꼭 찾을게, 몸조심하길</text><text for="L20">아직 오지 않은 미래를 뛰어넘어</text><text for="L21">그곳에 정해진 우리의 운명이 있어</text><text for="L22">석양이 지고 별이 떠올라</text><text for="L23">널 향한 그리움이 하늘을 가로질러</text><text for="L24">인생을 살아가며 우리가 보는 모든 장면에서</text><text for="L25">너와 난 언제나 함께야</text></translation><translation type="subtitle" xml:lang="pt"><text for="L1">As folhas caem, os rios se elevam</text><text for="L2">Minutos se estendem em milhas no tempo</text><text for="L3">Nós talvez nos separemos, mas você entende</text><text for="L4">Sempre fomos eu e você</text><text for="L5">Você já caminhou comigo</text><text for="L6">Sempre um passo à frente de mim</text><text for="L7">Chutando pedrinhas enquanto caminha para frente</text><text for="L8">Cantarolando suavemente uma melodia doce</text><text for="L9">Eu cresci um pouco agora</text><text for="L10">Às vezes também canta em voz alta</text><text for="L11">Esta canção que pertence a você e a mim</text><text for="L12">O pôr do sol se desfaz, e as estrelas surgem</text><text for="L13">Minha saudade de você atravessa o céu</text><text for="L14">Por toda a vida e por tudo o que vimos</text><text for="L15">Sempre fomos eu e você</text><text for="L16">Então não precisa ter medo, nós vamos nos encontrar</text><text for="L17">Seja no fim ou no começo, nós estaremos juntos</text><text for="L18">O tempo não para de girar</text><text for="L19">Querido, eu vou te encontrar, são e salvo</text><text for="L20">Em tudo o que ainda está por vir</text><text for="L21">Lá está algo que é para ser</text><text for="L22">O pôr do sol se desfaz, e as estrelas surgem</text><text for="L23">Minha saudade de você atravessa o céu</text><text for="L24">Por toda a vida e por tudo o que vimos</text><text for="L25">Sempre fomos eu e você</text></translation><translation type="subtitle" xml:lang="ru"><text for="L1">Падают листья, реки текут</text><text for="L2">Тонут минуты в мгновениях вечности</text><text for="L3">Мы можем расстаться, но понимаешь ли ты</text><text for="L4">Мы с тобой навсегда вместе</text><text for="L5">Вместе мы шли</text><text for="L6">Ты всегда на шаг впереди</text><text for="L7">Пиная камешки по пути</text><text for="L8">Тихо напеваешь мелодию</text><text for="L9">Я немного подросла</text><text for="L10">Иногда я пою во весь голос</text><text for="L11">Нашу с тобой песню</text><text for="L12">Солнце заходит, звёзды восходят</text><text for="L13">Тоска по тебе летит в небеса</text><text for="L14">И всю жизнь, что нам дана</text><text for="L15">Мы с тобой навсегда вместе</text><text for="L16">Не бойся, друг друга мы найдём</text><text for="L17">И в начале, и в конце мы всегда будем вдвоём</text><text for="L18">Время бежит не замедляясь</text><text for="L19">Знай, я всегда отыщу тебя</text><text for="L20">Это будущее ещё не наступило</text><text for="L21">Но оно нас обязательно ждёт</text><text for="L22">Солнце заходит, звёзды восходят</text><text for="L23">Тоска по тебе летит в небеса</text><text for="L24">И всю жизнь, что нам дана</text><text for="L25">Мы с тобой навсегда вместе</text></translation><translation type="subtitle" xml:lang="th"><text for="L1">ใบไม้ร่วงโรย สายน้ำเอ่อล้น</text><text for="L2">นาทีทอดยาวหลายไมล์ในห้วงเวลา</text><text for="L3">เราอาจแยกจากกัน แต่เธอเห็นไหม</text><text for="L4">เธอกับฉันจะอยู่ด้วยกันตลอดไป</text><text for="L5">เธอเคยร่วมเดินทางไปกับฉัน</text><text for="L6">มักจะเดินอยู่ข้างหน้าก้าวหนึ่งเสมอ</text><text for="L7">พลางเตะก้อนหินไปตามทาง</text><text for="L8">ฮัมเพลงเป็นทำนองแผ่วเบาอันนุ่มนวล</text><text for="L9">ตอนนี้ฉันสูงขึ้นมาหน่อยแล้ว</text><text for="L10">บางครั้งก็จะร้องออกมาดังๆ</text><text for="L11">ร้องเพลงของเธอกับฉัน</text><text for="L12">ดวงอาทิตย์ลับฟ้า ดวงดาวทะยานสู่นภา</text><text for="L13">ความคิดถึงเธอลอยข้ามท้องฟ้าไป</text><text for="L14">ประสบการณ์ชีวิตและทุกสิ่งที่เราได้พบเจอ</text><text for="L15">เธอกับฉันจะอยู่ด้วยกันตลอดไป</text><text for="L16">ดังนั้นไม่ต้องกลัว เราจะต้องได้พบกันอีก</text><text for="L17">ไม่ว่าจะเป็นจุดสิ้นสุดหรือจุดเริ่มต้น พวกเราจะได้อยู่ด้วยกัน</text><text for="L18">เวลาหมุนวนไป</text><text for="L19">ที่รัก ฉันจะตามหาเธอให้เจออย่างปลอดภัย</text><text for="L20">ข้ามผ่านอนาคตที่ยังไม่เกิดขึ้น</text><text for="L21">ที่นั่น มีชะตาที่ถูกกำหนดไว้แล้ว</text><text for="L22">ดวงอาทิตย์ลับฟ้า ดวงดาวทะยานสู่นภา</text><text for="L23">ความคิดถึงเธอลอยข้ามท้องฟ้าไป</text><text for="L24">ประสบการณ์ชีวิตและทุกสิ่งที่เราได้พบเจอ</text><text for="L25">เธอกับฉันจะอยู่ด้วยกันตลอดไป</text></translation><translation type="subtitle" xml:lang="vi"><text for="L1">Lá rơi rụng, dòng chảy dâng trào</text><text for="L2">Từng giây từng phút kéo dài thành chặng đường xa xăm</text><text for="L3">Chúng ta có thể sẽ chia xa, nhưng liệu bạn có hiểu được</text><text for="L4">Bạn và tôi luôn ở bên nhau</text><text for="L5">Ngày xưa bạn đã từng đồng hành cùng tôi</text><text for="L6">Luôn đi trước tôi một bước</text><text for="L7">Đá những viên sỏi nhỏ trong khi bước đi</text><text for="L8">Khẽ ngân nga một giai điệu dịu dàng</text><text for="L9">Giờ tôi đã cao hơn một chút</text><text for="L10">Thỉnh thoảng cũng sẽ hát vang lên</text><text for="L11">Bài hát này thuộc về bạn và tôi</text><text for="L12">Khi mặt trời lặn, những vì sao mọc lên</text><text for="L13">Nỗi nhớ về bạn bay vút qua bầu trời</text><text for="L14">Trải nghiệm cuộc sống và tất cả những gì chúng ta thấy</text><text for="L15">Bạn và tôi luôn ở bên nhau</text><text for="L16">Vì vậy đừng sợ hãi, chúng ta sẽ tìm thấy nhau</text><text for="L17">Dù ở điểm đến hay điểm khởi đầu, chúng ta sẽ luôn bên nhau</text><text for="L18">Thời gian không ngừng xoay vần</text><text for="L19">Bạn thân yêu, tôi sẽ tìm được bạn, bình an vô sự</text><text for="L20">Xuyên qua tương lai chưa xảy ra</text><text for="L21">Nơi đó có vận mệnh đã được định sẵn của chúng ta</text><text for="L22">Khi mặt trời lặn, những vì sao mọc lên</text><text for="L23">Nỗi nhớ về bạn bay vút qua bầu trời</text><text for="L24">Trải nghiệm cuộc sống và tất cả những gì chúng ta thấy</text><text for="L25">Bạn và tôi luôn ở bên nhau</text></translation><translation type="subtitle" xml:lang="zh-Hant"><text for="L1">落葉飄落，河流攀升</text><text for="L2">分秒在時光裡延伸成遙遠的里程</text><text for="L3">我們也許會分開，但你是否明白</text><text for="L4">你和我始終同在</text><text for="L5">你曾經與我同行</text><text for="L6">總是比我走得更前一步</text><text for="L7">踢著小石子向前走</text><text for="L8">輕聲哼唱著柔和的旋律</text><text for="L9">我現在長高了一點</text><text for="L10">有時也會放聲唱出</text><text for="L11">這首屬於你和我的歌</text><text for="L12">落日消逝，星辰升起</text><text for="L13">對你的思念穿越天空飄去</text><text for="L14">經歷人生和我們所見的一切</text><text for="L15">你和我始終同在</text><text for="L16">所以無需害怕，我們會找到彼此</text><text for="L17">無論在終點還是起點，我們都會在一起</text><text for="L18">時間不停旋轉</text><text for="L19">親愛的，我會找到你，平安無恙</text><text for="L20">穿越尚未發生的未來</text><text for="L21">那裡有你我註定的命運</text><text for="L22">落日消逝，星辰升起</text><text for="L23">對你的思念穿越天空飄去</text><text for="L24">經歷人生和我們所見的一切</text><text for="L25">你和我始終同在</text></translation><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">落叶飘落，河流攀升</text><text for="L2">分秒在时光里延伸成遥远的里程</text><text for="L3">我们也许会分开，但你是否明白</text><text for="L4">你和我始终同在</text><text for="L5">你曾经与我同行</text><text for="L6">总是比我走得更前一步</text><text for="L7">踢着小石子向前走</text><text for="L8">轻声哼唱着柔和的旋律</text><text for="L9">我现在长高了一点</text><text for="L10">有时也会放声唱出</text><text for="L11">这首属于你和我的歌</text><text for="L12">落日消逝，星辰升起</text><text for="L13">对你的思念穿越天空飘去</text><text for="L14">经历人生和我们所见的一切</text><text for="L15">你和我始终同在</text><text for="L16">所以无需害怕，我们会找到彼此</text><text for="L17">无论在终点还是起点，我们都会在一起</text><text for="L18">时间不停旋转</text><text for="L19">亲爱的，我会找到你，平安无恙</text><text for="L20">穿越尚未发生的未来</text><text for="L21">那里有你我注定的命运</text><text for="L22">落日消逝，星辰升起</text><text for="L23">对你的思念穿越天空飘去</text><text for="L24">经历人生和我们所见的一切</text><text for="L25">你和我始终同在</text></translation></translations><songwriters><songwriter>李单阳</songwriter><songwriter>伊野奏inosoo</songwriter><songwriter>HoYoFair</songwriter></songwriters><transliterations/></iTunesMetadata></metadata></head><body dur="1:46.270"><div begin="1.170" end="1:46.270"><p begin="1.170" end="4.550" itunes:key="L1" ttm:agent="v1"><span begin="1.170" end="1.460">Leaves</span> <span begin="1.460" end="1.750">will</span> <span begin="1.750" end="2.750">fall</span><span begin="2.750" end="2.755">,</span> <span begin="3.280" end="3.520">ri</span><span begin="3.520" end="3.820">vers</span> <span begin="3.820" end="4.550">climb</span></p><p begin="4.780" end="8.410" itunes:key="L2" ttm:agent="v1"><span begin="4.780" end="5.310">Mi</span><span begin="5.310" end="5.630">nute</span><span begin="5.630" end="5.920">s stretch</span> <span begin="5.920" end="6.860">to</span> <span begin="6.860" end="7.190">mi</span><span begin="7.190" end="7.430">les</span> <span begin="7.430" end="7.730">in</span> <span begin="7.730" end="8.410">time</span></p><p begin="8.410" end="11.760" itunes:key="L3" ttm:agent="v1"><span begin="8.410" end="8.670">We</span> <span begin="8.670" end="8.940">may</span> <span begin="8.940" end="9.930">part</span><span begin="9.930" end="9.935">,</span> <span begin="10.480" end="10.720">but don</span><span begin="10.720" end="11.050">&apos;t you</span> <span begin="11.050" end="11.760">see</span></p><p begin="11.980" end="17.380" itunes:key="L4" ttm:agent="v1"><span begin="11.980" end="12.510">I</span><span begin="12.510" end="12.820">t&apos;s</span> <span begin="12.820" end="13.150">al</span><span begin="13.150" end="13.740">ways</span> <span begin="13.740" end="14.030">you</span> <span begin="14.030" end="14.370">and</span> <span begin="14.370" end="17.380">me</span></p><p begin="19.770" end="22.530" itunes:key="L5" ttm:agent="v1"><span begin="19.770" end="20.930">You used to</span> <span begin="20.930" end="21.250">walk</span> <span begin="21.250" end="22.530">with me</span></p><p begin="22.780" end="26.670" itunes:key="L6" ttm:agent="v1"><span begin="22.780" end="23.060">Al</span><span begin="23.060" end="23.370">way</span><span begin="23.370" end="23.690">s a</span> <span begin="23.690" end="24.250">step</span> <span begin="24.250" end="24.560">a</span><span begin="24.560" end="24.850">head</span> <span begin="24.850" end="25.190">of</span> <span begin="25.190" end="26.670">me</span></p><p begin="26.970" end="29.720" itunes:key="L7" ttm:agent="v1"><span begin="26.970" end="28.190">Kicking</span> <span begin="28.190" end="28.480">pebble as</span> <span begin="28.480" end="28.760">you&apos;d</span> <span begin="28.760" end="29.720">go</span></p><p begin="29.980" en