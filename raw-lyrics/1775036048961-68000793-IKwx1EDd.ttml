<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" itunes:timing="Word" xml:lang="ja"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="扉をあけて"/><amll:meta key="musicName" value="打开心扉"/><amll:meta key="musicName" value="敞开心扉"/><amll:meta key="musicName" value="扉をあけて (打开心扉)"/><amll:meta key="musicName" value="扉をあけて (敞开心扉)"/><amll:meta key="musicName" value="Tobira wo Akete"/><amll:meta key="musicName" value="《魔卡少女樱》TV动画第35-46集片头曲"/><amll:meta key="musicName" value="TV动画《魔卡少女樱》OP2"/><amll:meta key="musicName" value="TV动画《魔卡少女樱》片头曲2"/><amll:meta key="musicName" value="TVアニメ「カードキャプターさくら」第2期オープニング主題歌"/><amll:meta key="musicName" value="TV动画《魔卡少女樱》OP2 ； TVアニメ「カードキャプターさくら」第2期オープニング主題歌"/><amll:meta key="artists" value="ANZA"/><amll:meta key="artists" value="アンザ"/><amll:meta key="artists" value="大山 アンザ"/><amll:meta key="album" value="カードキャプターさくら オリジナル・サウンドトラック3"/><amll:meta key="album" value="魔卡少女樱 原声带3"/><amll:meta key="album" value="扉をあけて"/><amll:meta key="album" value="打开心扉"/><amll:meta key="album" value="打开门扉"/><amll:meta key="ncmMusicId" value="28785362"/><amll:meta key="ncmMusicId" value="555959"/><amll:meta key="qqMusicId" value="001ycjmt2Ngqro"/><amll:meta key="qqMusicId" value="1876804"/><amll:meta key="qqMusicId" value="000sjEUD2wMqNt"/><amll:meta key="qqMusicId" value="1876747"/><amll:meta key="isrc" value="JPVI09907960"/><amll:meta key="Arranger" value="Seiji Kameda"/><amll:meta key="Arranger" value="亀田誠治"/><amll:meta key="Arranger" value="亀田诚治"/><amll:meta key="Lyrics" value="Kohmi Hirose"/><amll:meta key="Lyrics" value="広瀬香美"/><amll:meta key="Lyrics" value="ANZA"/><amll:meta key="Producer" value="Seiji Kameda"/><amll:meta key="Producer" value="亀田誠治"/><amll:meta key="Producer" value="亀田诚治"/><amll:meta key="Producer" value="kikuko"/><amll:meta key="Vocals" value="ANZA"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">一如既往 没关系 没问题 一切都好</text><text for="L2">连奇迹也能创造</text><text for="L3">出发吧 伸出手 抬起腿 向前走 展翅翱翔</text><text for="L4">一定会 有着什么 一定会在 某个地方 等待着相遇的那天</text><text for="L5">勇敢地 去做梦 去幻想 然后门扉将开启……</text><text for="L6">关键时刻 却总是哑口无言</text><text for="L7">想要倾诉 也想聆听你的声音</text><text for="L8">躁动的心啊 变得慌乱不已</text><text for="L9">飞机在蓝天留下轨迹</text><text for="L10">紧握的手中涌起力量</text><text for="L11">似乎哪里都能抵达</text><text for="L12">就让风指引我……</text><text for="L13">一如既往 没关系 没问题 一切都好</text><text for="L14">连奇迹也能创造</text><text for="L15">出发吧 伸出手 抬起腿 向前走 展翅翱翔</text><text for="L16">一定会 有着什么 一定会在 某个地方 等待着相遇的那天</text><text for="L17">勇敢地 去做梦 去幻想 然后门扉将开启……</text><text for="L18">即便是毫不起眼的小小石子</text><text for="L19">也能化作宝石 真是不可思议</text><text for="L20">只要和你一起 静静凝望……</text><text for="L21">万物皆闪耀</text><text for="L22">绝密心事 我最爱的 钟爱的 珍爱的</text><text for="L23">瞬间不断累积</text><text for="L24">化作了 即便是 微小的 细微的 小小的种子</text><text for="L25">一定在 我的心中 会有某处 巨大的花朵已开始绽放</text><text for="L26">勇敢地 去做梦 去幻想 然后世界将敞开</text><text for="L27">没关系 没问题 一如既往</text><text for="L28">连奇迹也能创造</text><text for="L29">出发吧 伸出手 抬起腿 向前走 展翅翱翔</text><text for="L30">一定会 有着什么 一定会在 某个地方 等待着相遇的那天</text><text for="L31">勇敢地 去做梦 去幻想 然后门扉将开启……</text></translation></translations><songwriters><songwriter>Kohmi Hirose</songwriter><songwriter>広瀬香美</songwriter><songwriter>ANZA</songwriter></songwriters><transliterations><transliteration xml:lang="ja-Latn"><text for="L1"><span begin="6.594" end="6.954" xmlns="http://www.w3.org/ns/ttml">i</span><span begin="6.954" end="7.094" xmlns="http://www.w3.org/ns/ttml">t&apos;s</span> <span begin="7.094" end="7.544" xmlns="http://www.w3.org/ns/ttml">all</span> <span begin="7.544" end="7.974" xmlns="http://www.w3.org/ns/ttml">right</span> <span begin="8.114" end="8.