<tt xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>TATSUNE</songwriter><songwriter>SHIBU</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="青春の輪郭"/><amll:meta key="artists" value="DOLLCHESTRA"/><amll:meta key="artists" value="村野さやか"/><amll:meta key="artists" value="村野沙耶香"/><amll:meta key="artists" value="Murano Sayaka"/><amll:meta key="artists" value="夕霧綴理"/><amll:meta key="artists" value="夕雾缀理"/><amll:meta key="artists" value="Yugiri Tsuzuri"/><amll:meta key="album" value="夏めきペイン"/><amll:meta key="ncmMusicId" value="2085769851"/><amll:meta key="qqMusicId" value="512505875"/><amll:meta key="qqMusicId" value="002wSSv80zZ3I0"/><amll:meta key="spotifyId" value="6BawKoAwu89Wd4t8Z8J5JW"/><amll:meta key="appleMusicId" value="1765301218"/><amll:meta key="isrc" value="JPI102301911"/><amll:meta key="ttmlAuthorGithub" value="86943191"/><amll:meta key="ttmlAuthorGithubLogin" value="bywhite0"/></metadata></head><body dur="04:11.875"><div begin="00:00.710" end="04:11.875"><p begin="00:00.710" end="00:07.878" ttm:agent="v1" itunes:key="L1"><span begin="00:00.710" end="00:02.449">Ah-</span> <span begin="00:02.597" end="00:02.928">腕</span><span begin="00:02.928" end="00:03.288">を</span><span begin="00:03.288" end="00:03.430">伸</span><span begin="00:03.430" end="00:03.610">ば</span><span begin="00:03.610" end="00:03.962">し</span><span begin="00:03.962" end="00:04.142">た</span><span begin="00:04.142" end="00:04.314">ら</span><span begin="00:04.314" end="00:04.801">届</span><span begin="00:04.801" end="00:04.945">き</span><span begin="00:04.945" end="00:05.139">そ</span><span begin="00:05.139" end="00:05.328">う</span><span begin="00:05.328" end="00:05.479">な</span><span begin="00:05.479" end="00:05.810">数</span><span begin="00:05.810" end="00:06.173">セン</span><span begin="00:06.173" end="00:06.347">チ</span><span begin="00:06.347" end="00:06.504">で</span><span begin="00:06.504" end="00:07.878">も</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊 哪怕伸出的手只差几厘米就能碰到</span><span ttm:role="x-roman">Ah- u de wo no ba shi ta ra to do ki so u na su u se n chi de mo</span></p><p begin="00:08.047" end="00:11.341" ttm:agent="v1" itunes:key="L2"><span begin="00:08.047" end="00:08.193">余</span><span begin="00:08.193" end="00:08.394">所</span><span begin="00:08.394" end="00:08.723">見</span><span begin="00:08.723" end="00:08.898">し</span><span begin="00:08.898" end="00:09.037">た</span><span begin="00:09.037" end="00:09.406">瞬</span><span begin="00:09.406" end="00:09.757">間</span> <span begin="00:09.757" end="00:10.263">遠</span><span begin="00:10.263" end="00:10.458">く</span><span begin="00:10.458" end="00:10.653">な</span><span begin="00:10.653" end="00:10.785">っ</span><span begin="00:10.785" end="00:11.037">て</span><span begin="00:11.037" end="00:11.145">し</span><span begin="00:11.145" end="00:11.243">ま</span><span begin="00:11.243" end="00:11.341">う</span><span ttm:role="x-translation" xml:lang="zh-CN">移开目光的瞬间你已经离我远去了</span><span ttm:role="x-roman">yo so mi shi ta shu n ka n to o ku na tte shi ma u</span></p><p begin="00:11.443" end="00:14.262" ttm:agent="v2" itunes:key="L3"><span begin="00:11.443" end="00:11.625">ペ</span><span begin="00:11.625" end="00:11.784">ダ</span><span begin="00:11.784" end="00:11.973">ル</span><span begin="00:11.973" end="00:12.304">を</span><span begin="00:12.304" end="00:12.646">強</span><span begin="00:12.646" end="00:12.901">く</span><span begin="00:12.995" end="00:13.163">踏</span><span begin="00:13.163" end="00:13.520">み</span><span begin="00:13.520" end="00:13.690">込</span><span begin="00:13.690" end="00:13.843">ん</span><span begin="00:13.843" end="00:13.996">で</span><span begin="00:13.996" end="00:14.262">も</span><span ttm:role="x-translation" xml:lang="zh-CN">不管自行车脚踏怎样用力地踩</span><span ttm:role="x-roman">pe da ru wo tsu yo ku fu mi ko n de mo</span></p><p begin="00:14.383" end="00:17.813" ttm:agent="v2" itunes:key="L4"><span begin="00:14.383" end="00:14.527">追</span><span begin="00:14.527" end="00:14.696">い</span><span begin="00:14.696" end="00:14.898">越</span><span begin="00:14.898" end="00:15.051">す</span><span begin="00:15.051" end="00:15.213">こ</span><span begin="00:15.213" end="00:15.352">と</span><span begin="00:15.352" end="00:15.725">は</span><span begin="00:15.725" end="00:15.890">出</span><span begin="00:15.890" end="00:16.234">来</span><span begin="00:16.234" end="00:16.384">ず</span><span begin="00:16.384" end="00:16.576">に</span><span begin="00:16.576" end="00:16.746">終</span><span begin="00:16.746" end="00:16.977">わ</span><span begin="00:16.977" end="00:17.095">っ</span><span begin="00:17.095" end="00:17.258">た</span><span begin="00:17.258" end="00:17.419">ん</span><span begin="00:17.419" end="00:17.813">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">却总是在追上之前就迎来结束</span><span ttm:role="x-roman">o i ko su ko to wa de ki zu ni o wa tta n da</span></p><p begin="00:18.112" end="00:22.923" ttm:agent="v1" itunes:key="L5"><span begin="00:18.112" end="00:19.493">Ah-</span> <span begin="00:19.667" end="00:19.974">眩</span><span begin="00:19.974" end="00:20.451">し</span><span begin="00:20.451" end="00:20.654">す</span><span begin="00:20.654" end="00:20.808">ぎ</span><span begin="00:20.808" end="00:21.125">て</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊 这过于耀眼而</span><span ttm:role="x-roman">Ah- ma bu shi su gi te</span></p><p begin="00:21.365" end="00:22.923" ttm:agent="v2" itunes:key="L6"><span begin="00:21.365" end="00:21.677">嫌</span><span begin="00:21.677" end="00:21.844">い</span><span begin="00:21.844" end="00:22.163">な</span><span begin="00:22.163" end="00:22.369">日</span><span begin="00:22.369" end="00:22.520">々</span><span begin="00:22.520" end="00:22.923">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">让我生厌的每一天</span><span ttm:role="x-roman">ki ra i na hi bi da</span></p><p begin="00:33.585" end="00:35.303" ttm:agent="v2" itunes:key="L7"><span begin="00:33.585" end="00:33.954">乾</span><span begin="00:33.954" end="00:34.134">い</span><span begin="00:34.134" end="00:34.296">た</span><span begin="00:34.296" end="00:34.637">空</span><span begin="00:34.637" end="00:34.825">気</span><span begin="00:34.825" end="00:35.303">が</span><span ttm:role="x-translation" xml:lang="zh-CN">干燥的空气</span><span ttm:role="x-roman">ka wa i ta ku u ki ga</span></p><p begin="00:36.009" end="00:38.904" ttm:agent="v2" itunes:key="L8"><span begin="00:36.009" end="00:36.158">吹</span><span begin="00:36.158" end="00:36.325">き</span><span begin="00:36.325" end="00:36.494">抜</span><span begin="00:36.494" end="00:37.030">け</span><span begin="00:37.030" end="00:37.226">る</span><span begin="00:37.226" end="00:37.894">校</span><span begin="00:37.894" end="00:38.563">庭</span><span begin="00:38.563" end="00:38.904">で</span><span ttm:role="x-translation" xml:lang="zh-CN">在校园之中吹过</span><span ttm:role="x-roman">fu ki nu ke ru ko u te i de</span></p><p begin="00:39.035" end="00:40.724" ttm:agent="v2" itunes:key="L9"><span begin="00:39.035" end="00:39.371">探</span><span begin="00:39.371" end="00:39.573">し</span><span begin="00:39.573" end="00:39.733">て</span><span begin="00:39.733" end="00:39.925">た</span><span begin="00:39.925" end="00:40.096">ん</span><span begin="00:40.096" end="00:40.257">だ</span><span begin="00:40.257" end="00:40.724">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">我仍在探寻</span><span ttm:role="x-roman">sa ga shi te ta n da yo</span></p><p begin="00:41.451" end="00:43.998" ttm:agent="v2" itunes:key="L10"><span begin="00:41.451" end="00:41.750">正</span><span begin="00:41.750" end="00:41.964">し</span><span begin="00:41.964" end="00:42.297">く</span><span begin="00:42.493" end="00:42.642">生</span><span begin="00:42.642" end="00:43.005">き</span><span begin="00:43.005" end="00:43.181">る</span><span begin="00:43.181" end="00:43.521">意</span><span begin="00:43.521" end="00:43.682">味</span><span begin="00:43.682" end="00:43.998">を</span><span ttm:role="x-translation" xml:lang="zh-CN">正确生活的意义</span><span ttm:role="x-roman">ta da shi ku i ki ru i mi wo</span></p><p begin="00:44.368" end="00:46.173" ttm:agent="v1" itunes:key="L11"><span begin="00:44.368" end="00:44.720">汗</span><span begin="00:44.720" end="00:44.871">ば</span><span begin="00:44.871" end="00:45.024">む</span><span begin="00:45.024" end="00:45.215">背</span><span begin="00:45.215" end="00:45.737">中</span><span begin="00:45.737" end="00:46.173">に</span><span ttm:role="x-translation" xml:lang="zh-CN">被汗浸湿的后背</span><span ttm:role="x-roman">a se ba mu se na ka ni</span></p><p begin="00:46.535" end="00:49.672" ttm:agent="v1" itunes:key="L12"><span begin="00:46.535" end="00:46.754">ス</span><span begin="00:46.754" end="00:46.928">プ</span><span begin="00:46.928" end="00:47.094">リ</span><span begin="00:47.094" end="00:47.278">ン</span><span begin="00:47.278" end="00:47.440">ク</span><span begin="00:47.440" end="00:47.776">ラー</span><span begin="00:47.951" end="00:48.119">の</span><span begin="00:48.119" end="00:48.626">水</span><span begin="00:48.626" end="00:48.956">浴</span><span begin="00:48.956" end="00:49.311">び</span><span begin="00:49.311" end="00:49.672">て</span><span ttm:role="x-translation" xml:lang="zh-CN">淋着花洒喷灌的水</span><span ttm:role="x-roman">su pu ri n ku raa no mi zu a bi te</span></p><p begin="00:49.672" end="00:51.583" ttm:agent="v1" itunes:key="L13"><span begin="00:49.672" end="00:49.989">大</span><span begin="00:49.989" end="00:50.314">声</span><span begin="00:50.314" end="00:50.464">で</span><span begin="00:50.464" end="00:50.799">叫</span><span begin="00:50.799" end="00:51.016">ん</span><span begin="00:51.016" end="00:51.194">だ</span><span begin="00:51.194" end="00:51.583">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">相信大声喊出</span><span ttm:role="x-roman">o o go e de sa ke n da ra</span></p><p begin="00:52.029" end="00:54.742" ttm:agent="v1" itunes:key="L14"><span begin="00:52.029" end="00:52.366">何</span><span begin="00:52.366" end="00:52.549">か</span><span begin="00:52.549" end="00:52.716">変</span><span begin="00:52.716" end="00:52.878">わ</span><span begin="00:52.878" end="00:53.218">る</span><span begin="00:53.375" end="00:53.532">と</span><span begin="00:53.532" end="00:53.895">信</span><span begin="00:53.895" end="00:54.087">じ</span><span begin="00:54.087" end="00:54.247">て</span><span begin="00:54.247" end="00:54.416">い</span><span begin="00:54.416" end="00:54.742">た</span><span ttm:role="x-translation" xml:lang="zh-CN">就能改变什么</span><span ttm:role="x-roman">na ni ka ka wa ru to shi n ji te i ta</span></p><p begin="00:54.742" end="00:56.464" ttm:agent="v2" itunes:key="L15"><span begin="00:54.742" end="00:55.082">青</span><span begin="00:55.082" end="00:55.426">春</span><span begin="00:55.426" end="00:55.627">は</span><span begin="00:55.627" end="00:55.785">ど</span><span begin="00:55.785" end="00:55.943">こ</span><span begin="00:55.943" end="00:56.464">へ</span><span ttm:role="x-translation" xml:lang="zh-CN">我的青春啊</span><span ttm:role="x-roman">se i shu n wa do ko e</span></p><p begin="00:57.478" end="00:59.928" ttm:agent="v2" itunes:key="L16"><span begin="00:57.478" end="00:57.851">隠</span><span begin="00:57.851" end="00:58.011">れ</span><span begin="00:58.011" end="00:58.163">て</span><span begin="00:58.163" end="00:58.340">し</span><span begin="00:58.340" end="00:58.510">ま</span><span begin="00:58.510" end="00:58.688">っ</span><span begin="00:58.688" end="00:59.061">た</span><span begin="00:59.360" end="00:59.529">の</span><span begin="00:59.529" end="00:59.928">か</span><span ttm:role="x-translation" xml:lang="zh-CN">你到底藏到哪儿去了</span><span ttm:role="x-roman">ka ku re te shi ma tta no ka</span></p><p begin="01:00.193" end="01:01.940" ttm:agent="v1" itunes:key="L17"><span begin="01:00.193" end="01:00.559">校</span><span begin="01:00.559" end="01:00.887">庭</span><span begin="01:00.887" end="01:01.054">の</span><span begin="01:01.054" end="01:01.392">外</span><span begin="01:01.392" end="01:01.940">は</span><span ttm:role="x-translation" xml:lang="zh-CN">离开了校园</span><span ttm:role="x-roman">ko u te i no so to wa</span></p><p begin="01:02.947" end="01:05.525" ttm:agent="v1" itunes:key="L18"><span begin="01:02.947" end="01:03.087">矢</span><span begin="01:03.087" end="01:03.630">印</span><span begin="01:03.630" end="01:03.798">が</span><span begin="01:03.798" end="01:03.938">無</span><span begin="01:03.938" end="01:04.121">く</span><span begin="01:04.121" end="01:04.535">て</span><span begin="01:04.790" end="01:05.387">怖</span><span begin="01:05.387" end="01:05.525">い</span><span ttm:role="x-translation" xml:lang="zh-CN">没有去寻找你的箭头 我好怕</span><span ttm:role="x-roman">ya ji ru shi ga na ku te ko wa i</span></p><p begin="01:05.650" end="01:07.370" ttm:agent="v2" itunes:key="L19"><span begin="01:05.650" end="01:05.838">そ</span><span begin="01:05.838" end="01:05.994">れ</span><span begin="01:05.994" end="01:06.169">で</span><span begin="01:06.169" end="01:06.329">も</span><span begin="01:06.329" end="01:06.733">掴</span><span begin="01:06.733" end="01:06.865">ん</span><span begin="01:06.865" end="01:07.370">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">于是我握紧了</span><span ttm:role="x-roman">so re de mo tsu ka n da</span></p><p begin="01:08.378" end="01:10.065" ttm:agent="v2" itunes:key="L20"><span begin="01:08.378" end="01:08.578">ハ</span><span begin="01:08.578" end="01:08.746">ン</span><span begin="01:08.746" end="01:08.909">ド</span><span begin="01:08.909" end="01:09.080">ル</span><span begin="01:09.080" end="01:09.252">の</span><span begin="01:09.252" end="01:09.413">向</span><span begin="01:09.413" end="01:09.577">き</span><span begin="01:09.577" end="01:10.065">は</span><span ttm:role="x-translation" xml:lang="zh-CN">向前的把手</span><span ttm:role="x-roman">ha n do ru no mu ki wa</span></p><p begin="01:10.273" end="01:12.061" ttm:agent="v2" itunes:key="L21"><span begin="01:10.273" end="01:10.620">た</span><span begin="01:10.620" end="01:10.949">だ</span><span begin="01:10.949" end="01:11.168">真</span><span begin="01:11.168" end="01:11.268">っ</span><span begin="01:11.268" end="01:11.466">直</span><span begin="01:11.466" end="01:11.639">ぐ</span><span begin="01:11.639" end="01:12.061">に</span><span ttm:role="x-translation" xml:lang="zh-CN">直直出发吧</span><span ttm:role="x-roman">ta da ma ssu gu ni</span></p><p begin="01:13.651" end="01:16.862" ttm:agent="v1" itunes:key="L22"><span begin="01:13.651" end="01:14.388">走</span><span begin="01:14.388" end="01:14.730">り</span><span begin="01:14.730" end="01:15.138">抜</span><span begin="01:15.386" end="01:16.084">け</span><span begin="01:16.084" end="01:16.862">る</span><span ttm:role="x-translation" xml:lang="zh-CN">一路奔去</span><span ttm:role="x-roman">ha shi ri nu ke ru</span></p><p begin="01:17.080" end="01:24.137" ttm:agent="v1" itunes:key="L23"><span begin="01:17.080" end="01:18.751">Ah-</span> <span begin="01:18.984" end="01:19.310">腕</span><span begin="01:19.310" end="01:19.639">を</span><span begin="01:19.639" end="01:19.812">伸</span><span begin="01:19.812" end="01:19.968">ば</span><span begin="01:19.968" end="01:20.308">し</span><span begin="01:20.308" end="01:20.488">た</span><span begin="01:20.488" end="01:20.668">ら</span><span begin="01:20.668" end="01:21.169">届</span><span begin="01:21.169" end="01:21.349">き</span><span begin="01:21.349" end="01:21.525">そ</span><span begin="01:21.525" end="01:21.707">う</span><span begin="01:21.707" end="01:21.856">な</span><span begin="01:21.856" end="01:22.197">数</span><span begin="01:22.197" end="01:22.542">セン</span><span begin="01:22.542" end="01:22.693">チ</span><span begin="01:22.693" end="01:22.876">で</span><span begin="01:22.876" end="01:24.137">も</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊 哪怕伸出的手只差几厘米就能碰到</span><span ttm:role="x-roman">Ah- u de wo no ba shi ta ra to do ki so u na su u se n chi de mo</span></p><p begin="01:24.447" end="01:27.825" ttm:agent="v1" itunes:key="L24"><span begin="01:24.447" end="01:24.582">余</span><span begin="01:24.582" end="01:24.786">所</span><span begin="01:24.786" end="01:25.075">見</span><span begin="01:25.075" end="01:25.245">し</span><span begin="01:25.245" end="01:25.407">た</span><span begin="01:25.407" end="01:25.753">瞬</span><span begin="01:25.753" end="01:26.121">間</span> <span begin="01:26.121" end="01:26.640">遠</span><span begin="01:26.640" end="01:26.819">く</span><span begin="01:26.819" end="01:27.027">な</span><span begin="01:27.027" end="01:27.165">っ</span><span begin="01:27.165" end="01:27.404">て</span><span begin="01:27.404" end="01:27.513">し</span><span begin="01:27.513" end="01:27.660">ま</span><span begin="01:27.660" end="01:27.825">う</span><span ttm:role="x-translation" xml:lang="zh-CN">移开目光的瞬间你已经离我远去了</span><span ttm:role="x-roman">yo so mi shi ta shu n ka n to o ku na tte shi ma u</span></p><p begin="01:27.825" end="01:30.656" ttm:agent="v2" itunes:key="L25"><span begin="01:27.825" end="01:27.992">ペ</span><span begin="01:27.992" end="01:28.160">ダ</span><span begin="01:28.160" end="01:28.312">ル</span><span begin="01:28.312" end="01:28.647">を</span><span begin="01:28.647" end="01:29.035">強</span><span begin="01:29.035" end="01:29.375">く</span><span begin="01:29.375" end="01:29.531">踏</span><span begin="01:29.531" end="01:29.870">み</span><span begin="01:29.870" end="01:30.044">込</span><span begin="01:30.044" end="01:30.203">ん</span><span begin="01:30.203" end="01:30.368">で</span><span begin="01:30.368" end="01:30.656">も</span><span ttm:role="x-translation" xml:lang="zh-CN">不管自行车脚踏怎样用力地踩</span><span ttm:role="x-roman">pe da ru wo tsu yo ku fu mi ko n de mo</span></p><p begin="01:30.734" end="01:34.157" ttm:agent="v1" itunes:key="L26"><span begin="01:30.734" end="01:30.913">追</span><span begin="01:30.913" end="01:31.061">い</span><span begin="01:31.061" end="01:31.268">越</span><span begin="01:31.268" end="01:31.413">す</span><span begin="01:31.413" end="01:31.589">こ</span><span begin="01:31.589" end="01:31.747">と</span><span begin="01:31.747" end="01:32.100">は</span><span begin="01:32.100" end="01:32.258">出</span><span begin="01:32.258" end="01:32.588">来</span><span begin="01:32.588" end="01:32.770">ず</span><span begin="01:32.770" end="01:32.932">終</span><span begin="01:32.932" end="01:33.110">わ</span><span begin="01:33.110" end="01:33.414">り</span><span begin="01:33.414" end="01:33.621">そ</span><span begin="01:33.621" end="01:33.800">う</span><span begin="01:33.800" end="01:34.157">で</span><span ttm:role="x-translation" xml:lang="zh-CN">却总是在追上之前就迎来结束</span><span ttm:role="x-roman">o i ko su ko to wa de ki zu o wa ri so u de</span></p><p begin="01:34.475" end="01:39.123" ttm:agent="v1" itunes:key="L27"><span begin="01:34.475" end="01:36.015">Ah-</span> <span begin="01:36.015" end="01:36.184">ぼ</span><span begin="01:36.184" end="01:36.359">く</span><span begin="01:36.359" end="01:36.869">の</span><span begin="01:36.869" end="01:37.208">今</span><span begin="01:37.208" end="01:37.518">を</span><span begin="01:37.518" end="01:37.717">邪</span><span begin="01:37.717" end="01:38.005">魔</span><span begin="01:38.005" end="01:38.199">さ</span><span begin="01:38.199" end="01:38.411">せ</span><span begin="01:38.411" end="01:38.573">る</span><span begin="01:38.573" end="01:38.733">も</span><span begin="01:38.733" end="01:38.905">ん</span><span begin="01:38.905" end="01:39.123">か</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊 我不会让我的现在任谁破坏</span><span ttm:role="x-roman">Ah- bo ku no i ma wo ja ma sa se ru mo n ka</span></p><p begin="01:39.245" end="01:44.700" ttm:agent="v1" itunes:key="L28"><span begin="01:39.245" end="01:39.596">崩</span><span begin="01:39.596" end="01:39.770">れ</span><span begin="01:39.770" end="01:39.930">か</span><span begin="01:39.930" end="01:40.089">け</span><span begin="01:40.089" end="01:40.268">の</span><span begin="01:40.268" end="01:40.578">髪</span><span begin="01:40.578" end="01:40.789">さ</span><span begin="01:40.789" end="01:40.962">え</span><span begin="01:40.962" end="01:41.125">も</span><span begin="01:41.125" end="01:41.605">美</span><span begin="01:41.605" end="01:41.741">し</span><span begin="01:41.741" end="01:41.874">い</span><span begin="01:41.874" end="01:41.992">ん</span><span begin="01:41.992" end="01:44.700">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">就连风中凌乱的头发也很美</span><span ttm:role="x-roman">ku zu re ka ke no ka mi sa e mo u tsu ku shi i n da</span></p><p begin="01:52.692" end="01:54.259" ttm:agent="v1" itunes:key="L29"><span begin="01:52.692" end="01:53.018">少</span><span begin="01:53.018" end="01:53.237">し</span><span begin="01:53.237" end="01:53.408">の</span><span begin="01:53.408" end="01:53.714">勇</span><span begin="01:53.714" end="01:53.909">気</span><span begin="01:53.909" end="01:54.259">が</span><span ttm:role="x-translation" xml:lang="zh-CN">因为言语中</span><span ttm:role="x-roman">su ko shi no yu u ki ga</span></p><p begin="01:55.094" end="01:58.025" ttm:agent="v1" itunes:key="L30"><span begin="01:55.094" end="01:55.437">言</span><span begin="01:55.437" end="01:55.610">葉</span><span begin="01:55.610" end="01:55.816">に</span><span begin="01:56.127" end="01:56.552">宿</span><span begin="01:56.552" end="01:56.815">っ</span><span begin="01:56.815" end="01:56.989">た</span><span begin="01:56.989" end="01:57.495">こ</span><span begin="01:57.495" end="01:57.662">と</span><span begin="01:57.662" end="01:58.025">で</span><span ttm:role="x-translation" xml:lang="zh-CN">带上了些许勇气</span><span ttm:role="x-roman">ko to ba ni ya do tta ko to de</span></p><p begin="01:58.145" end="01:59.703" ttm:agent="v1" itunes:key="L31"><span begin="01:58.145" end="01:58.518">忘</span><span begin="01:58.518" end="01:58.678">れ</span><span begin="01:58.678" end="01:58.856">て</span><span begin="01:58.856" end="01:59.030">た</span><span begin="01:59.030" end="01:59.192">ん</span><span begin="01:59.192" end="01:59.340">だ</span><span begin="01:59.340" end="01:59.703">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">便足以让我忘却</span><span ttm:role="x-roman">wa su re te ta n da yo</span></p><p begin="02:00.547" end="02:02.978" ttm:agent="v1" itunes:key="L32"><span begin="02:00.547" end="02:00.714">不</span><span begin="02:00.714" end="02:01.062">安</span><span begin="02:01.062" end="02:01.579">に</span><span begin="02:01.579" end="02:01.746">生</span><span begin="02:01.746" end="02:02.100">き</span><span begin="02:02.100" end="02:02.253">る</span><span begin="02:02.253" end="02:02.606">日</span><span begin="02:02.606" end="02:02.783">々</span><span begin="02:02.783" end="02:02.978">を</span><span ttm:role="x-translation" xml:lang="zh-CN">忘却那充满不安的往日</span><span ttm:role="x-roman">fu a n ni i ki ru hi bi wo</span></p><p begin="02:03.440" end="02:05.318" ttm:agent="v2" itunes:key="L33"><span begin="02:03.440" end="02:03.622">こ</span><span begin="02:03.622" end="02:03.806">れ</span><span begin="02:03.806" end="02:03.952">こ</span><span begin="02:03.952" end="02:04.136">そ</span><span begin="02:04.136" end="02:04.300">が</span><span begin="02:04.300" end="02:04.471">ア</span><span begin="02:04.471" end="02:04.652">イ</span><span begin="02:04.652" end="02:04.836">ロ</span><span begin="02:04.836" end="02:05.318">ニー</span><span ttm:role="x-translation" xml:lang="zh-CN">这就是所谓「讽刺」吧</span><span ttm:role="x-roman">ko re ko so ga a i ro nii</span></p><p begin="02:05.688" end="02:08.730" ttm:agent="v2" itunes:key="L34"><span begin="02:05.688" end="02:06.005">誰</span><span begin="02:06.005" end="02:06.178">か</span><span begin="02:06.178" end="02:06.333">と</span><span begin="02:06.333" end="02:06.514">自</span><span begin="02:06.514" end="02:06.876">分</span><span begin="02:07.034" end="02:07.544">比</span><span begin="02:07.544" end="02:07.720">べ</span><span begin="02:07.720" end="02:07.890">な</span><span begin="02:07.890" end="02:08.065">い</span><span begin="02:08.065" end="02:08.402">方</span><span begin="02:08.402" end="02:08.730">が</span><span ttm:role="x-translation" xml:lang="zh-CN">「不要拿别人跟自己比较</span><span ttm:role="x-roman">da re ka to ji bu n ku ra be na i ho u ga</span></p><p begin="02:08.730" end="02:10.746" ttm:agent="v2" itunes:key="L35"><span begin="02:08.730" end="02:09.076">楽</span><span begin="02:09.076" end="02:09.251">か</span><span begin="02:09.251" end="02:09.409">も</span><span begin="02:09.409" end="02:09.600">し</span><span begin="02:09.600" end="02:09.765">れ</span><span begin="02:09.765" end="02:10.104">な</span><span begin="02:10.104" end="02:10.282">い</span><span begin="02:10.282" end="02:10.746">と</span><span ttm:role="x-translation" xml:lang="zh-CN">或许这样还能更轻松些」</span><span ttm:role="x-roman">ra ku ka mo shi re na i to</span></p><p begin="02:11.133" end="02:13.805" ttm:agent="v2" itunes:key="L36"><span begin="02:11.133" end="02:11.465">認</span><span begin="02:11.465" end="02:11.640">め</span><span begin="02:11.640" end="02:11.809">る</span><span begin="02:11.809" end="02:11.981">な</span><span begin="02:11.981" end="02:12.280">ど</span><span begin="02:12.499" end="02:12.660">有</span><span begin="02:12.660" end="02:12.834">り</span><span begin="02:12.834" end="02:12.993">得</span><span begin="02:12.993" end="02:13.167">な</span><span begin="02:13.167" end="02:13.387">か</span><span begin="02:13.387" end="02:13.528">っ</span><span begin="02:13.528" end="02:13.805">た</span><span ttm:role="x-translation" xml:lang="zh-CN">我怎可能会承认这套说辞</span><span ttm:role="x-roman">mi to me ru na do a ri e na ka tta</span></p><p begin="02:13.805" end="02:15.404" ttm:agent="v1" itunes:key="L37"><span begin="02:13.805" end="02:14.181">青</span><span begin="02:14.181" end="02:14.527">春</span><span begin="02:14.527" end="02:14.722">が</span><span begin="02:14.722" end="02:15.046">何</span><span begin="02:15.046" end="02:15.404">か</span><span ttm:role="x-translation" xml:lang="zh-CN">青春究竟是什么</span><span ttm:role="x-roman">se i shu n ga na ni ka</span></p><p begin="02:16.585" end="02:19.002" ttm:agent="v1" itunes:key="L38"><span begin="02:16.585" end="02:16.918">今</span><span begin="02:16.918" end="02:17.099">で</span><span begin="02:17.099" end="02:17.260">も</span><span begin="02:17.260" end="02:17.431">分</span><span begin="02:17.431" end="02:17.609">か</span><span begin="02:17.609" end="02:17.760">ら</span><span begin="02:17.760" end="02:17.931">な</span><span begin="02:17.931" end="02:18.106">い</span><span begin="02:18.454" end="02:18.645">け</span><span begin="02:18.645" end="02:19.002">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">即便走到现在我仍然不知道</span><span ttm:role="x-roman">i ma de mo wa ka ra na i ke do</span></p><p begin="02:19.316" end="02:20.945" ttm:agent="v2" itunes:key="L39"><span begin="02:19.316" end="02:19.643">確</span><span begin="02:19.643" end="02:19.814">か</span><span begin="02:19.814" end="02:19.974">な</span><span begin="02:19.974" end="02:20.330">答</span><span begin="02:20.330" end="02:20.491">え</span><span begin="02:20.491" end="02:20.945">を</span><span ttm:role="x-translation" xml:lang="zh-CN">确切的答案</span><span ttm:role="x-roman">ta shi ka na ko ta e wo</span></p><p begin="02:22.009" end="02:24.596" ttm:agent="v2" itunes:key="L40"><span begin="02:22.009" end="02:22.198">知</span><span begin="02:22.198" end="02:22.366">り</span><span begin="02:22.366" end="02:22.554">た</span><span begin="02:22.554" end="02:22.720">く</span><span begin="02:22.720" end="02:22.882">な</span><span begin="02:22.882" end="02:23.052">い</span><span begin="02:23.052" end="02:23.230">と</span><span begin="02:23.230" end="02:23.647">も</span><span begin="02:23.908" end="02:24.448">思</span><span begin="02:24.448" end="02:24.596">う</span><span ttm:role="x-translation" xml:lang="zh-CN">也不想要知道</span><span ttm:role="x-roman">shi ri ta ku na i to mo o mo u</span></p><p begin="02:24.760" end="02:26.456" ttm:agent="v1" itunes:key="L41"><span begin="02:24.760" end="02:24.943">そ</span><span begin="02:24.943" end="02:25.104">れ</span><span begin="02:25.104" end="02:25.265">で</span><span begin="02:25.265" end="02:25.423">も</span><span begin="02:25.423" end="02:25.750">探</span><span begin="02:25.750" end="02:25.952">し</span><span begin="02:25.952" end="02:26.456">た</span><span ttm:role="x-translation" xml:lang="zh-CN">但也没有停下寻找的脚步</span><span ttm:role="x-roman">so re de mo sa ga shi ta</span></p><p begin="02:27.472" end="02:29.057" ttm:agent="v1" itunes:key="L42"><span begin="02:27.472" end="02:27.671">ハ</span><span begin="02:27.671" end="02:27.826">ン</span><span begin="02:27.826" end="02:28.000">ド</span><span begin="02:28.000" end="02:28.172">ル</span><span begin="02:28.172" end="02:28.349">の</span><span begin="02:28.349" end="02:28.515">向</span><span begin="02:28.515" end="02:28.673">き</span><span begin="02:28.673" end="02:29.057">は</span><span ttm:role="x-translation" xml:lang="zh-CN">把手的方向</span><span ttm:role="x-roman">ha n do ru no mu ki wa</span></p><p begin="02:29.354" end="02:31.345" ttm:agent="v1" itunes:key="L43"><span begin="02:29.354" end="02:29.707">今日</span><span begin="02:29.707" end="02:30.045">も</span><span begin="02:30.045" end="02:30.252">真</span><span begin="02:30.252" end="02:30.367">っ</span><span begin="02:30.367" end="02:30.536">直</span><span begin="02:30.536" end="02:30.712">ぐ</span><span begin="02:30.712" end="02:31.345">に</span><span ttm:role="x-translation" xml:lang="zh-CN">今天也是直直向前</span><span ttm:role="x-roman">kyo u mo ma ssu gu ni</span></p><p begin="02:32.765" end="02:35.932" ttm:agent="v2" itunes:key="L44"><span begin="02:32.765" end="02:33.463">速</span><span begin="02:33.463" end="02:33.771">度</span><span begin="02:33.771" end="02:34.195">上</span><span begin="02:34.481" end="02:35.164">げ</span><span begin="02:35.164" end="02:35.932">る</span><span ttm:role="x-translation" xml:lang="zh-CN">继续加速</span><span ttm:role="x-roman">so ku do a ge ru</span></p><p begin="02:36.184" end="02:43.253" ttm:agent="v1" itunes:key="L45"><span begin="02:36.184" end="02:37.846">Ah-</span> <span begin="02:38.114" end="02:38.416">胸</span><span begin="02:38.416" end="02:38.744">を</span><span begin="02:38.744" end="02:38.915">焦</span><span begin="02:38.915" end="02:39.098">が</span><span begin="02:39.098" end="02:39.427">す</span><span begin="02:39.427" end="02:39.590">ほ</span><span begin="02:39.590" end="02:39.767">ど</span><span begin="02:39.767" end="02:39.914">に</span><span begin="02:39.914" end="02:40.224">必</span><span begin="02:40.224" end="02:40.436">死</span><span begin="02:40.436" end="02:40.617">だ</span><span begin="02:40.617" end="02:40.792">っ</span><span begin="02:40.792" end="02:40.944">た</span><span begin="02:40.944" end="02:41.295">数</span><span begin="02:41.295" end="02:41.637">セン</span><span begin="02:41.637" end="02:41.801">チ</span><span begin="02:41.801" end="02:41.961">で</span><span begin="02:41.961" end="02:43.253">も</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊 哪怕只差了让心中充满焦急的几厘米</span><span ttm:role="x-roman">Ah- mu ne wo ko ga su ho do ni hi sshi da tta su u se n chi de mo</span></p><p begin="02:43.517" end="02:46.855" ttm:agent="v1" itunes:key="L46"><span begin="02:43.517" end="02:43.874">通</span><span begin="02:43.874" end="02:44.169">り</span><span begin="02:44.169" end="02:44.364">過</span><span begin="02:44.364" end="02:44.544">ぎ</span> <span begin="02:44.544" end="02:44.718">だ</span><span begin="02:44.718" end="02:44.884">ん</span><span begin="02:44.884" end="02:45.055">だ</span><span begin="02:45.055" end="02:45.224">ん</span><span begin="02:45.224" end="02:45.396">過</span><span begin="02:45.396" end="02:45.729">去</span><span begin="02:45.729" end="02:45.898">に</span><span begin="02:45.898" end="02:46.118">な</span><span begin="02:46.118" end="02:46.225">っ</span><span begin="02:46.225" end="02:46.492">て</span><span begin="02:46.492" end="02:46.606">し</span><span begin="02:46.606" end="02:46.721">ま</span><span begin="02:46.721" end="02:46.855">う</span><span 