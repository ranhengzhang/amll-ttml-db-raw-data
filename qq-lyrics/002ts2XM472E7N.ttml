appleMusicId" value="1715759782"/><amll:meta key="appleMusicId" value="1712547509"/><amll:meta key="appleMusicId" value="1677234270"/><amll:meta key="appleMusicId" value="1697238726"/><amll:meta key="isrc" value="USUG11901472"/><amll:meta key="ttmlAuthorGithub" value="50747104"/><amll:meta key="ttmlAuthorGithub" value="207428447"/><amll:meta key="ttmlAuthorGithub" value="250306205"/><amll:meta key="ttmlAuthorGithubLogin" value="Xionghaizi001"/><amll:meta key="ttmlAuthorGithubLogin" value="kid1412520"/><amll:meta key="ttmlAuthorGithubLogin" value="kid141252010"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Taylor Swift</songwriter><songwriter>Jack Antonoff</songwriter><songwriter>Annie Clark</songwriter></songwriters><audio lyricOffset="0.850" role="spatial"/><translations><translation xml:lang="zh-CN" type="subtitle"><text for="L3">脑海中的狂热幻想 深夜里的蠢蠢欲动</text><text for="L4">你知道 我能感同身受<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦 耶 你说得对 我心动了</span></text><text for="L5">坏坏的男孩 就像昂贵的玩具</text><text for="L6">你知道 我甘愿承担一切风险<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦 耶 你说得对 我心动了</span></text><text for="L7">我备受折磨 焦急地望向窗外</text><text for="L8">我总是期待着你的到来</text><text for="L9">魔鬼掷骰子 天使翻白眼</text><text for="L10">所有艰难险阻 只会让我对你的渴望更加强烈</text><text for="L11">你的身材 令我欲罢不能 患得患失</text><text for="L12">使我心生忧郁 这是 噢 喔哦</text><text for="L13">这是一个残酷的夏天</text><text for="L14">我告诉他们 没关系的</text><text for="L15">在脆弱不堪的幻梦中 没有是非之分 但是 噢 喔哦</text><text for="L16">你让我度过了一个残酷的夏天</text><text for="L17">你站在自动售货机前 低下了头</text><text for="L18">我还没有放弃<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦 耶 你说得对 我心动了</span></text><text for="L19">承认吧 在困难面前 我们真的经不起考验</text><text for="L20">我们没有倾尽全力<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦 耶 你说得对 我心动了</span></text><text for="L21">所以 关掉车灯 夏天就像一把利刃</text><text for="L22">我一直在等你的爱消失殆尽</text><text for="L23">魔鬼掷骰子 天使翻白眼</text><text for="L24">就算我受伤流血 也不会让你知道</text><text for="L25">哦 你的身材 令我欲罢不能 患得患失</text><text for="L26">使我心生忧郁 这是 噢 喔哦</text><text for="L27">这是一个残酷的夏天</text><text for="L28">我告诉他们 没关系的</text><text for="L29">在脆弱不堪的幻梦中 没有是非之分 但是 噢 喔哦</text><text for="L30">你让我度过了一个残酷的夏天</text><text for="L31">我在汽车的后座上酩酊大醉</text><text for="L32">从酒吧回家的路上 我哭得像个孩子<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦</span></text><text for="L33">嘴上说着 “我没事” 但并非如此</text><text for="L34">我不想遮遮掩掩 只为把你留在身边</text><text for="L35">我悄悄从花园大门溜了进去</text><text for="L36">那个夏天的每个夜晚 我的命运被彻底封印<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦</span></text><text for="L37">我嘶吼着 尽管于事无补</text><text for="L38">“我爱你 你肯定没听说过比这更糟糕的事吧”</text><text for="L39">他抬起头 露出魔鬼般的坏笑</text><text for="L40">你的身材 令我欲罢不能 患得患失</text><text for="L41">使我心生忧郁 这是 噢 喔哦</text><text for="L42">这是一个残酷的夏天</text><text for="L43">我告诉他们 没关系的</text><text for="L44">在脆弱不堪的幻梦中 没有是非之分 但是 噢 喔哦</text><text for="L45">你让我度过了一个残酷的夏天</text><text for="L46">我在汽车的后座上酩酊大醉</text><text for="L47">从酒吧回家的路上 我哭得像个孩子<span xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" ttm:role="x-bg">哦</span></text><text for="L48">嘴上说着 “我没事” 但并非如此</text><text for="L49">我不想遮遮掩掩 只为把你留在身边</text><text for="L50">我悄悄从花园大门溜了进去</text><text for="L51">那个夏天的每个夜晚 我的命运被彻底封印</text><text for="L52">我嘶吼着 尽管于事无补</text><text for="L53">“我爱你 你肯定没听说过比这更糟糕的事吧”</text></translation></translations><audio lyricOffset="0.850" role="spatial"/></iTunesMetadata></metadata></head><body dur="02:54.954"><div begin="00:00.927" end="00:05.610" itunes:song-part="Intro"><p begin="00:00.927" end="00:02.828" ttm:agent="v2" itunes:key="L1"><span begin="00:00.927" end="00:01.414">Yeah,</span> <span begin="00:02.351" end="00:02.828">yeah</span></p><p begin="00:03.758" end="00:05.610" 