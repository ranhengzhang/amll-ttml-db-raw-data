          <transliteration xml:lang="ja">
            <text for="L1">
              <span begin="00:00.980" end="00:01.280" xmlns="http://www.w3.org/ns/ttml">ゼイ</span>
              <span begin="00:01.280" end="00:01.280" xmlns="http://www.w3.org/ns/ttml"> </span>
              <span begin="00:01.280" end="00:01.660" xmlns="http://www.w3.org/ns/ttml">セイ</span>
              <span begin="00:01.660" end="00:01.660" xmlns="http://www.w3.org/ns/ttml"> </span>
              <span begin="00:01.660" end="00:01.920" xmlns="http://www.w3.org/ns/ttml">フラ</span>
              <span begin="00:01.920" end="00:02.000" xmlns="http://www.w3.org/ns/ttml">ワー</span>
