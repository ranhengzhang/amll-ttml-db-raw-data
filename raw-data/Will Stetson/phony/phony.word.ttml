              <span begin="00:02.450" end="00:02.610" xmlns="http://www.w3.org/ns/ttml">アンド</span>
              <span begin="00:02.610" end="00:02.610" xmlns="http://www.w3.org/ns/ttml"> </span>
              <span begin="00:02.610" end="00:02.740" xmlns="http://www.w3.org/ns/ttml">ゼア</span>
              <span begin="00:02.740" end="00:02.840" xmlns="http://www.w3.org/ns/ttml"> </span>
