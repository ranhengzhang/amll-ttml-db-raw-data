      <amll:meta key="musicName" value="恋人を射ち堕とした日" />
      <amll:meta key="musicName" value="恋人射杀的那一天" />
      <amll:meta key="musicName" value="射杀恋人之日" />
      <amll:meta key="musicName" value="Koibito wo Uchiotoshita Hi" />
      <amll:meta key="musicName" value="射杀恋人的那天" />
