      <iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal">
        <translations>
          <translation type="subtitle" xml:lang="zh-Hans">
            <text for="L1">已经再也回忆不起</text>
            <text for="L2">曾自由翱翔的天空之色</text>
            <text for="L3">于遥远的意识深处</text>
            <text for="L4">却仍梦见与你一同欢笑</text>
            <text for="L5">在失去一切之后</text>
            <text for="L6">仅剩紧握不放的梦之碎片</text>
            <text for="L7">纵然是双无法飞翔的翅膀</text>
            <text for="L8">我的这份思念</text>
            <text for="L9">也会在不见星光的夜中颤栗</text>
            <text for="L10">依然向着你飞去</text>
            <text for="L11">那即将消散却仍呼唤我的声音</text>
            <text for="L12">将回忆拉近身旁</text>
            <text for="L13">迈出沉重的步伐</text>
            <text for="L14">背负着磨损破碎的羽翼</text>
            <text for="L15">挣扎前行吧</text>
            <text for="L16">纵然是双无法飞翔的翅膀</text>
            <text for="L17">我的这份思念</text>
            <text for="L18">也会在不见星光的夜中颤栗</text>
            <text for="L19">依然向着你飞去</text>
            <text for="L20">那即将消散却仍呼唤我的声音</text>
            <text for="L21">即便分离也非独自一人 请坚信</text>
          </translation>
        </translations>
