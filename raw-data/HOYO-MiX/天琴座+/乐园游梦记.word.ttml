      <iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal">
        <translations>
          <translation type="subtitle" xml:lang="pt">
            <text for="L1">Quero ouvir a brisa do mar sozinha</text>
            <text for="L2">Quero ver as estrelas sozinha</text>
            <text for="L3">Vou escapar das correntes que me aprisionam com essa emoção</text>
            <text for="L4">Viajar pelas belas ilhas</text>
            <text for="L5">Fazer um pacto comigo mesma</text>
            <text for="L6">Nunca perder o foco</text>
            <text for="L7">Nada é impossível</text>
            <text for="L8">O prelúdio sob o reflexo dos pingos de chuva</text>
            <text for="L9">Cada passo com suas delicadas letras</text>
            <text for="L10">Buscando a nota perfeita</text>
            <text for="L11">Um dia vou reviver cada página da partitura</text>
            <text for="L12">Vou dar o meu melhor na minha parte do dueto</text>
            <text for="L13">Uma hora vou escutar</text>
            <text for="L14">As luzes rodopiantes</text>
            <text for="L15">Quem estará comigo?</text>
            <text for="L16">A cantar minha canção favorita</text>
            <text for="L17">Será você?</text>
            <text for="L18">Como brasas dançando nos céus</text>
            <text for="L19">Se deixe levar, não se abale</text>
            <text for="L20">Guarde os fragmentos de sonhos passados</text>
            <text for="L21">Supere todos os obstáculos</text>
            <text for="L22">E os caminhos das nuvens</text>
            <text for="L23">É um refúgio para a felicidade</text>
            <text for="L24">Veja as paisagens das notas musicais</text>
            <text for="L25">Você já sabe voar nos seus sonhos</text>
            <text for="L26">Aos poucos</text>
            <text for="L27">O cenário das ruas</text>
            <text for="L28">Se esforce para criar um paraíso fantástico</text>
            <text for="L29">E lindíssimo</text>
            <text for="L30">Venha pegar, pois é seu</text>
            <text for="L31">Anseio cantar suavemente para você</text>
            <text for="L32">Perto do seu ouvido</text>
            <text for="L33">O mundo lá fora é sempre o mesmo</text>
            <text for="L34">Nada mudou</text>
            <text for="L35">Cante com toda sua força</text>
            <text for="L36">Me mostre os seus aplausos</text>
            <text for="L37">As faíscas no Coração</text>
            <text for="L38">Estão queimando intensamente</text>
            <text for="L39">Ouça a melodia</text>
            <text for="L40">Veja, quem está brilhando intensamente?</text>
            <text for="L41">As ilusões desaparecem</text>
            <text for="L42">Se estiver cansado</text>
            <text for="L43">Vamos relembrar a jornada mágica que eu compus</text>
            <text for="L44">Aos poucos</text>
            <text for="L45">O cenário das ruas</text>
            <text for="L46">Cantando, dançando, falando</text>
            <text for="L47">Escrevendo cuidadosamente a sua jornada</text>
            <text for="L48">É tão emocionante de se ouvir!</text>
          </translation>
          <translation type="subtitle" xml:lang="id">
            <text for="L1">Ingin dengar angin laut sendirian</text>
            <text for="L2">Ingin lihat langit malam sendirian</text>
            <text for="L3">Keluar dari sangkarku dengan penuh semangat</text>
            <text for="L4">Jelajahi semua pulau yang indah</text>
            <text for="L5">Berjanji pada diri sendiri, hanya diri sendiri</text>
            <text for="L6">Untuk tidak pernah kehilangan arah</text>
            <text for="L7">Untuk menggapai segalanya</text>
            <text for="L8">Overturnya, bersembunyi di pantulan tetesan hujan</text>
            <text for="L9">Dengan setiap langkah diiringi lirik yang begitu lembut</text>
            <text for="L10">Mencari tinggi nada</text>
            <text for="L11">Suatu hari, aku akan hitung setiap halaman partitur itu lagi</text>
            <text for="L12">Latihan keras untuk bagian chorus tersebut</text>
            <text for="L13">Akhirnya aku akan mendengar</text>
            <text for="L14">Cahaya yang berputar</text>
            <text for="L15">Siapa yang berdiri di sampingku?</text>
            <text for="L16">Tawarkan lagu favorit pertamaku sebagai pertunjukan terakhirnya</text>
            <text for="L17">Apa itu kamu?</text>
            <text for="L18">Yang menari di langit seperti bara api</text>
            <text for="L19">Bebaslah, jangan gentar</text>
            <text for="L20">Kejarlah serpihan mimpi kemarin</text>
            <text for="L21">Lewati segala rintangan</text>
            <text for="L22">Jejak yang ditinggal awan</text>
            <text for="L23">Ialah tempat kebahagiaan</text>
            <text for="L24">Nikmati musiknya dan lihatlah</text>
            <text for="L25">Kamu sudah lama belajar terbang dalam mimpi</text>
            <text for="L26">Sedikit demi sedikit</text>
            <text for="L27">Pemandangan jalanan</text>
            <text for="L28">Menciptakan tempat yang kamu impikan</text>
            <text for="L29">Sungguh indah</text>
            <text for="L30">Sini, ini untukmu</text>
            <text for="L31">Aku ingin bernyanyi untukmu dengan lembut</text>
            <text for="L32">Dekat telingamu</text>
            <text for="L33">Pemandangan di luar masih sama</text>
            <text for="L34">Tak ada yang berubah</text>
            <text for="L35">Bernyanyilah dengan semangat</text>
            <text for="L36">Banjirilah aku dengan tepukan tangan</text>
            <text for="L37">Kembang api dalam hatiku</text>
            <text for="L38">Sedang menyala terang</text>
            <text for="L39">Dengarlah, melodi ini</text>
            <text for="L40">Lihatlah, yang bersinar terang</text>
            <text for="L41">Ilusi ini akan pudar</text>
            <text for="L42">Jika kamu merasa lelah</text>
            <text for="L43">Ingatlah perjalanan ajaib yang telah kuciptakan</text>
            <text for="L44">Sedikit demi sedikit</text>
            <text for="L45">Pemandangan jalanan</text>
            <text for="L46">Sambil bernyanyi dan menari</text>
            <text for="L47">Perjalanan ini pun diciptakan dengan tulus</text>
            <text for="L48">Sungguh mengharukan</text>
          </translation>
          <translation type="subtitle" xml:lang="ja">
            <text for="L1">ひとり海風を聴きながら 夜空を眺めるの</text>
            <text for="L2">ひとり海風を聴きながら 夜空を眺めるの</text>
            <text for="L3">心弾む逃避行</text>
            <text for="L4">美しい島々を渡る</text>
            <text for="L5">自分自身との約束</text>
            <text for="L6">前を向いてれば</text>
            <text for="L7">なんだってできる</text>
            <text for="L8">逆さまの 雨に隠れて プレリュード</text>
            <text for="L9">フレーズの上 一歩一歩 音程を探り</text>
            <text for="L10">フレーズの上 一歩一歩 音程を探り</text>
            <text for="L11">五線譜を数える日 待ちわびる</text>
            <text for="L12">まだ半分だけのアンサンブル</text>
            <text for="L13">いつか届くように</text>
            <text for="L14">廻るステージライト そばにいるのは誰？</text>
            <text for="L15">廻るステージライト そばにいるのは誰？</text>
            <text for="L16">フィナーレは私の大好きな歌…</text>
            <text for="L17">貴方なの？</text>
            <text for="L18">星の光のように</text>
            <text for="L19">安らかに舞う</text>
            <text for="L20">きのう見た夢の欠片を抱いて</text>
            <text for="L21">困難を超えるわ</text>
            <text for="L22">雲の軌跡は</text>
            <text for="L23">遊園地みたい</text>
            <text for="L24">音に乗って飛び回るの</text>
            <text for="L25">夢の中ならできるもの</text>
            <text for="L26">積み重なる</text>
            <text for="L27">街の景色</text>
            <text for="L28">夢見た場所を作りましょう とても</text>
            <text for="L29">素敵な…</text>
            <text for="L30">ほら 貴方にあげるわ</text>
            <text for="L31">貴方の耳元で</text>
            <text for="L32">そっと歌う</text>
            <text for="L33">外の世界は相変わらず</text>
            <text for="L34">同じまま？</text>
            <text for="L35">声高らかに歌う</text>
            <text for="L36">私を喝采で包んで</text>
            <text for="L37">心の火花が</text>
            <text for="L38">眩く爆ぜる</text>
            <text for="L39">聞いて メロディーを</text>
            <text for="L40">見て 誰かの輝きを</text>
            <text for="L41">幻がやがて消えても</text>
            <text for="L42">辛いときは</text>
            <text for="L43">どうかこの 魔法みたいな旅を思い出して</text>
            <text for="L44">積み重なる</text>
            <text for="L45">街の景色</text>
            <text for="L46">歌い 踊り 語り</text>
            <text for="L47">綴られた遊記</text>
            <text for="L48">なんて美しい</text>
          </translation>
          <translation type="subtitle" xml:lang="en">
            <text for="L1">Wanting to listen to the sea breeze alone</text>
            <text for="L2">Wanting to gaze at the night sky alone</text>
            <text for="L3">Escape my cage with that skip of my heart</text>
            <text for="L4">Travel across all the beautiful islands</text>
            <text for="L5">Make an oath to myself, only myself</text>
            <text for="L6">To never lose track</text>
            <text for="L7">To achieve everything</text>
            <text for="L8">The overture, hiding in the reflection of raindrops</text>
            <text for="L9">With each step cushioned by lyrics so delicate</text>
            <text for="L10">Finding the pitch</text>
            <text for="L11">One day, I&apos;ll count each page on that music sheet again</text>
            <text for="L12">Practising my half of that chorus</text>
            <text for="L13">I&apos;ll eventually hear</text>
            <text for="L14">The spinning lights</text>
            <text for="L15">Who stands beside me?</text>
            <text for="L16">Offering my first, favorite song as their grand finale</text>
            <text for="L17">You?</text>
            <text for="L18">Like dancing embers in the sky</text>
            <text for="L19">Be carefree, don&apos;t flinch</text>
            <text for="L20">Catch the shards of yesterday&apos;s dream</text>
            <text for="L21">Break through all barriers</text>
            <text for="L22">And the tracks left by clouds</text>
            <text for="L23">Is a haven for joy</text>
            <text for="L24">Ride the music and see</text>
            <text for="L25">You&apos;ve long since learned to fly in dreams</text>
            <text for="L26">Bit by bit</text>
            <text for="L27">The scenery of the streets</text>
            <text for="L28">Create the haven of your dreams</text>
            <text for="L29">Beauty</text>
            <text for="L30">Come. This is for you</text>
            <text for="L31">I yearn to sing for you softly</text>
            <text for="L32">Close to your ear</text>
            <text for="L33">The world outside is the same as always</text>
            <text for="L34">Nothing has changed</text>
            <text for="L35">Raise your voice and sing</text>
            <text for="L36">Shower me in applause</text>
            <text for="L37">The sparks in my heart</text>
            <text for="L38">Are burning brightly</text>
            <text for="L39">Listen to the melody</text>
            <text for="L40">See who&apos;s shining bright</text>
            <text for="L41">The illusion will fade</text>
            <text for="L42">If you feel tired</text>
            <text for="L43">Relive the magical journey I composed</text>
            <text for="L44">Bit by bit</text>
            <text for="L45">The scenery of the streets</text>
            <text for="L46">Singing, dancing, speaking</text>
            <text for="L47">Carefully inscribing the journey</text>
            <text for="L48">So moving to hear</text>
          </translation>
          <translation type="subtitle" xml:lang="es">
            <text for="L1">Quiero escuchar la brisa marina a solas</text>
            <text for="L2">quiero contemplar el cielo nocturno a solas</text>
            <text for="L3">con un latido escapar de mis ataduras</text>
            <text for="L4">Quiero viajar por islas hermosas</text>
            <text for="L5">y hacerme una promesa a mí misma</text>
            <text for="L6">para nunca desviarme de mi camino</text>
            <text for="L7">No hay nada que me detenga</text>
            <text for="L8">Una obertura se esconde entre reflejos de gotas de lluvia</text>
            <text for="L9">caminando paso a paso sobre delicadas melodías</text>
            <text for="L10">mientras busco el tono adecuado</text>
            <text for="L11">Algún día contaré las páginas de esta partitura</text>
            <text for="L12">y practicaré mi mitad de los coros</text>
            <text for="L13">Al final escucharé</text>
            <text for="L14">las vertiginosas luces</text>
            <text for="L15">¿Quién está a mi lado?</text>
            <text for="L16">Ofreceré mi primera melodía, mi favorita, como gran final</text>
            <text for="L17">¿Eres tú?</text>
            <text for="L18">Como lumbres en el cielo</text>
            <text for="L19">sé libre y alza el vuelo</text>
            <text for="L20">Atesora los fragmentos de sueños pasados</text>
            <text for="L21">no permitas que ninguna barrera te detenga</text>
            <text for="L22">El rastro que dejan tras de sí las nubes</text>
            <text for="L23">es un paraíso de alegría</text>
            <text for="L24">Viaja a lomos de la música y observa</text>
            <text for="L25">hace tiempo que aprendiste a volar en sueños</text>
            <text for="L26">Poco a poco</text>
            <text for="L27">la ciudad se revela bajo tus pies</text>
            <text for="L28">mientras lucha por crear en tus sueños un edén</text>
            <text for="L29">Es verdaderamente hermoso</text>
            <text for="L30">Ten, esto es para ti</text>
            <text for="L31">Deseo cantar suavemente para ti</text>
            <text for="L32">cerca de tu oído</text>
            <text for="L33">Fuera reina el mismo paisaje de siempre</text>
            <text for="L34">¿Acaso nada ha cambiado?</text>
            <text for="L35">Alza tu voz y entona tu canción</text>
            <text for="L36">Déjame bañarme en el aplauso de la multitud</text>
            <text for="L37">El corazón es como un haz de fuegos artificiales</text>
            <text for="L38">que prenden como un torrente</text>
            <text for="L39">Escucha esta melodía</text>
            <text for="L40">¡mira quién brilla!</text>
            <text for="L41">Las alucinaciones se desvanecen</text>
            <text for="L42">Si el cansancio te vence</text>
            <text for="L43">revive este viaje mágico que he compuesto</text>
            <text for="L44">Nota a nota</text>
            <text for="L45">la ciudad se revela bajo tus pies</text>
            <text for="L46">mientras canta, baila y charla</text>
            <text for="L47">narrando con detalle tu viaje</text>
            <text for="L48">¡Es pura melodía!</text>
          </translation>
          <translation type="subtitle" xml:lang="fr">
            <text for="L1">Vouloir écouter seule la brise marine</text>
            <text for="L2">et contempler seule le ciel nocturne.</text>
            <text for="L3">Briser mes chaînes avec un cœur battant</text>
            <text for="L4">et voyager à travers toutes les belles îles.</text>
            <text for="L5">Me faire une promesse à moi-même</text>
            <text for="L6">de ne jamais perdre le fil,</text>
            <text for="L7">de tout réussir.</text>
            <text for="L8">Le prélude, se cacher dans le reflet des gouttes de pluie,</text>
            <text for="L9">marcher sur les paroles d&apos;une musique délicate,</text>
            <text for="L10">à la recherche du ton juste.</text>
            <text for="L11">La partition, je compterai à nouveau ses notes un jour.</text>
            <text for="L12">Je répète ma moitié de ce refrain,</text>
            <text for="L13">et je finirai par entendre.</text>
            <text for="L14">Sous les lumières tournoyantes,</text>
            <text for="L15">qui se tient à mes côtés ?</text>
            <text for="L16">Pour le grand final, j&apos;offre ma première chanson préférée.</text>
            <text for="L17">Est-ce que c&apos;est toi ?</text>
            <text for="L18">Comme des braises dansant dans le ciel,</text>
            <text for="L19">laisse-toi porter, ne flanche pas.</text>
            <text for="L20">Attraper les éclats du rêve d&apos;hier,</text>
            <text for="L21">et franchir les obstacles.</text>
            <text for="L22">Les traces laissées par les nuages</text>
            <text for="L23">sont un havre de joie.</text>
            <text for="L24">Promène-toi en rythme,</text>
            <text for="L25">tu as depuis longtemps appris à voler dans tes rêves.</text>
            <text for="L26">Accumuler petit à petit</text>
            <text for="L27">le scénario des rues,</text>
            <text for="L28">et s&apos;efforcer de créer un pays des rêves fantastique.</text>
            <text for="L29">C&apos;est magnifique.</text>
            <text for="L30">Viens, c&apos;est pour toi.</text>
            <text for="L31">J&apos;ai envie de chanter doucement pour toi,</text>
            <text for="L32">près de l&apos;oreille.</text>
            <text for="L33">Le monde extérieur est-il toujours le même,</text>
            <text for="L34">sans aucun changement ?</text>
            <text for="L35">Élève ta voix et chante.</text>
            <text for="L36">Qu&apos;on m&apos;applaudisse.</text>
            <text for="L37">Les étincelles dans mon cœur</text>
            <text for="L38">brûlent vivement.</text>
            <text for="L39">Écoute la mélodie.</text>
            <text for="L40">Regarde qui brille de tous ses feux.</text>
            <text for="L41">L&apos;illusion s&apos;estompera.</text>
            <text for="L42">Si tu sens la fatigue,</text>
            <text for="L43">remémore-toi le voyage magique que j&apos;ai composé.</text>
            <text for="L44">Accumuler petit à petit</text>
            <text for="L45">le scénario des rues,</text>
            <text for="L46">chanter, danser, parler,</text>
            <text for="L47">consigner soigneusement son voyage,</text>
            <text for="L48">c&apos;est si mélodieux.</text>
          </translation>
          <translation type="subtitle" xml:lang="th">
            <text for="L1">ฟังเสียงลมทะเลเพียงลำพัง</text>
            <text for="L2">มองดูท้องฟ้ายามค่ำคืนเพียงลำพัง</text>
            <text for="L3">หลุดพ้นจากพันธนาการด้วยหัวใจที่เต้นแรง</text>
            <text for="L4">เดินทางรอบเกาะที่งดงาม</text>
            <text for="L5">และเอ่ยสัญญากับตัวเอง</text>
            <text for="L6">ว่าจะไม่มีวันหลงทาง</text>
            <text for="L7">และจะทำทุกอย่างให้สำเร็จ</text>
            <text for="L8">อารัมภบท หลบใต้เงาของสายฝน</text>
            <text for="L9">ทุกย่างก้าวบรรเลงด้วยท่วงทำนองที่ประณีต</text>
            <text for="L10">ค้นหาตัวโน้ตว่าจะสูงสักแค่ไหน</text>
            <text for="L11">และสักวันหนึ่ง ฉันจะนับมันดูอีกครั้ง</text>
            <text for="L12">บทเพลงครึ่งท่อนที่ฝึกฝนอยู่นั้น</text>
            <text for="L13">สักวันหนึ่งจะได้ยินเสียงของมัน</text>
            <text for="L14">แสงไฟที่วนเวียน</text>
            <text for="L15">ใครจะอยู่เคียงข้าง</text>
            <text for="L16">และส่งมอบเพลงโปรดมาให้ฉัน</text>
            <text for="L17">ใช่เธอรึเปล่า</text>
            <text for="L18">ราวกับประกายไฟบนฟากฟ้า</text>
            <text for="L19">ทำตามหัวใจและไม่หลบเลี่ยง</text>
            <text for="L20">คว้าชิ้นส่วนของความฝันในวันวาน</text>
            <text for="L21">และฝ่าฟันทุกอุปสรรคที่ขัดขวาง</text>
            <text for="L22">ร่องรอยของก้อนเมฆ</text>
            <text for="L23">คือปลายทางของความสุข</text>
            <text for="L24">โลดแล่นไปบนบันไดเสียง</text>
            <text for="L25">ได้เรียนรู้การโผบินในห้วงฝัน</text>
            <text for="L26">ทิวทัศน์ตามทาง</text>
            <text for="L27">ค่อยๆ ก่อตัวขึ้นมา</text>
            <text for="L28">พยายามสร้างแดนมหัศจรรย์ในจินตนาการ</text>
            <text for="L29">มันช่างงดงาม</text>
            <text for="L30">มาสิ ฉันจะมอบให้เธอ</text>
            <text for="L31">หวังว่าจะได้ร้องเพลงให้เธอฟัง</text>
            <text for="L32">อย่างเบาๆ ข้างหูของเธอ</text>
            <text for="L33">ทิวทัศน์ด้านนอกไม่เปลี่ยนแปลง</text>
            <text for="L34">ไม่เคยเลย</text>
            <text for="L35">ร้องเพลงออกมาให้เต็มที่</text>
            <text for="L36">และปรบมือให้ฉันสิ</text>
            <text for="L37">ประกายไฟในก้นบึ้งของหัวใจ</text>
            <text for="L38">กำลังเอ่อล้นขึ้นมา</text>
            <text for="L39">ฟังเสียงท่วงทำนองที่ดังขึ้น</text>
            <text for="L40">ดูสิว่า ใครกำลังเปล่งประกาย</text>
            <text for="L41">ภาพลวงตาจะหายไป</text>
            <text for="L42">ถ้ารู้สึกเหนื่อยล้า</text>
            <text for="L43">ก็ให้นึกถึงการเดินทางสุดอัศจรรย์ที่ฉันเขียนขึ้นมา</text>
            <text for="L44">ทิวทัศน์ตามทาง</text>
            <text for="L45">ค่อยๆ ก่อตัวขึ้นมา</text>
            <text for="L46">ขับร้องและเต้นรำ</text>
            <text for="L47">บรรจงขีดเขียนเรื่องราวของการเดินทาง</text>
            <text for="L48">ช่างไพเราะจับใจ</text>
          </translation>
          <translation type="subtitle" xml:lang="ru">
            <text for="L1">Хочу слушать морской бриз в тишине,</text>
            <text for="L2">смотреть на ночное небо в одиночестве.</text>
            <text for="L3">С трепетом в сердце сбежать от оков,</text>
            <text for="L4">увидеть прекрасные острова.</text>
            <text for="L5">Дать себе обещание:</text>
            <text for="L6">не сбиться с пути,</text>
            <text for="L7">сделать всё, о чём мечтала!</text>
            <text for="L8">В начале я скрылась в отражениях дождя,</text>
            <text for="L9">шаг за шагом шла под звуки нежной мелодии.</text>
            <text for="L10">Искала ноты, тянулась к их высоте.</text>
            <text for="L11">Однажды я вернусь к этим страницам,</text>
            <text for="L12">закончу свою часть</text>
            <text for="L13">и услышу его.</text>
            <text for="L14">Огни кружатся вокруг...</text>
            <text for="L15">Кто со мной?</text>
            <text for="L16">Финалом станет песня, которую я любила больше всех.</text>
            <text for="L17">Это ты?</text>
            <text for="L18">Как искры в ночном небе,</text>
            <text for="L19">свободные, смелые,</text>
            <text for="L20">мы бережно собираем осколки вчерашних грёз,</text>
            <text for="L21">преодолевая все преграды.</text>
            <text for="L22">Следы в облаках</text>
            <text for="L23">ведут нас к радости,</text>
            <text for="L24">музыка поднимает нас выше.</text>
            <text for="L25">Во снах мы давно научились летать.</text>
            <text for="L26">Шаг за шагом</text>
            <text for="L27">я создаю свой сказочный мир,</text>
            <text for="L28">преображаю улицы в мечту!</text>
            <text for="L29">Как это прекрасно!</text>
            <text for="L30">Это тебе.</text>
            <text for="L31">Я хочу спеть тебе так тихо,</text>
            <text for="L32">совсем близко, почти на ухо.</text>
            <text for="L33">Мир снаружи всё тот же.</text>
            <text for="L34">Ничего не изменилось,</text>
            <text for="L35">но мой голос звучит свободно.</text>
            <text for="L36">Аплодисменты греют душу.</text>
            <text for="L37">Искры в сердце пылают</text>
            <text for="L38">всё ярче и ярче.</text>
            <text for="L39">Слушай, мелодия оживает.</text>
            <text for="L40">Смотри, кто сияет в её свете.</text>
            <text for="L41">Иллюзии исчезнут,</text>
            <text for="L42">но если ты устанешь,</text>
            <text for="L43">просто вспомни наше волшебное путешествие.</text>
            <text for="L44">Шаг за шагом</text>
            <text for="L45">я собираю пейзажи.</text>
            <text for="L46">Пою, танцую, рассказываю,</text>
            <text for="L47">заполняю страницы своей истории.</text>
            <text for="L48">И каждое слово звучит как песня.</text>
          </translation>
          <translation type="subtitle" xml:lang="vi">
            <text for="L1">Muốn một mình lắng nghe gió biển</text>
            <text for="L2">Muốn một mình ngắm bầu trời đêm</text>
            <text for="L3">Mang theo sự rung động đó thoát khỏi ràng buộc</text>
            <text for="L4">Đi ngao du khắp các hòn đảo xinh đẹp</text>
            <text for="L5">Đã hứa với chính mình như thế</text>
            <text for="L6">Không bao giờ sai nhịp</text>
            <text for="L7">Sẽ làm được tất cả</text>
            <text for="L8">Khúc dạo đầu, trốn vào chiếc bóng của giọt mưa</text>
            <text for="L9">Mỗi bước chân giẫm lên từng lời nhạc tinh tế</text>
            <text for="L10">Tìm nốt nhạc có quãng cao bao nhiêu</text>
            <text for="L11">Nhạc phổ, chờ đến ngày nào đó rồi đếm sau</text>
            <text for="L12">Luyện tập nửa đoạn hợp tấu đó</text>
            <text for="L13">Rồi sẽ có thể nghe thấy</text>
            <text for="L14">Ánh đèn xoay chuyển</text>
            <text for="L15">Ai bên cạnh mình</text>
            <text for="L16">Cuối cùng dâng tặng bài hát thuở ban đầu mình thích nhất</text>
            <text for="L17">Là bạn à?</text>
            <text for="L18">Như ngọn lửa trên trời</text>
            <text for="L19">Tự do, không né tránh</text>
            <text for="L20">Bắt lấy những mảnh vỡ giấc mộng ngày hôm qua</text>
            <text for="L21">Vượt qua hiểm trở</text>
            <text for="L22">Quỹ tích của vầng mây</text>
            <text for="L23">Là thiên đường vui chơi</text>
            <text for="L24">Du ngoạn trên những nốt nhạc</text>
            <text for="L25">Trong giấc mơ đã học được cách bay</text>
            <text for="L26">Tích lũy từng chút một</text>
            <text for="L27">Phong cảnh dọc đường</text>
            <text for="L28">Nỗ lực tạo ra tiên cảnh trong ảo tưởng</text>
            <text for="L29">Đẹp quá</text>
            <text for="L30">Đây, tôi tặng bạn</text>
            <text for="L31">Mong có thể nhẹ nhàng hát cho bạn nghe</text>
            <text for="L32">Ghé sát vào tai</text>
            <text for="L33">Phong cảnh bên ngoài cửa vẫn như xưa</text>
            <text for="L34">Vẫn không thay đổi sao</text>
            <text for="L35">Hát hết mình</text>
            <text for="L36">Không ngừng vỗ tay cho tôi</text>
            <text for="L37">Ngọn lửa trong tận cùng trái tim</text>
            <text for="L38">Đang dâng trào</text>
            <text for="L39">Hãy nghe giai điệu vang lên</text>
            <text for="L40">Hãy xem ai đang tỏa sáng</text>
            <text for="L41">Ảo giác rồi sẽ biến mất</text>
            <text for="L42">Nếu cảm thấy mệt</text>
            <text for="L43">Vậy thì hãy hồi tưởng hành trình phép thuật khi tôi sáng tác bản nhạc</text>
            <text for="L44">Tích lũy từng chút một</text>
            <text for="L45">Phong cảnh dọc đường</text>
            <text for="L46">Vừa hát vừa nhảy vừa nói</text>
            <text for="L47">Cẩn thận biên soạn quá trình du ngoạn</text>
            <text for="L48">Hay quá</text>
          </translation>
          <translation type="subtitle" xml:lang="de">
            <text for="L1">Ich möchte allein die Meeresbrise anhören</text>
            <text for="L2">und möchte allein den Sternenhimmel sehen</text>
            <text for="L3">Entfliehe meinem Käfig, wenn mein Herz einen Sprung macht</text>
            <text for="L4">und bereise all die wunderschönen Inseln</text>
            <text for="L5">Leiste einen Schwur an mich selbst, nur für mich:</text>
            <text for="L6">Ich werde nichts aus den Augen verlieren</text>
            <text for="L7">Ich werde immer alles erreichen</text>
            <text for="L8">Eine Ouvertüre, die sich im Spiegelbild des Regens versteckt</text>
            <text for="L9">Jeder Schritt wird von sanften Versen begleitet</text>
            <text for="L10">um den richtigen Ton zu finden</text>
            <text for="L11">Eines Tages werde ich wieder die Seiten des Notenblatts zählen</text>
            <text for="L12">und meine Hälfte des Refrains proben</text>
            <text for="L13">bis ich endlich höre</text>
            <text for="L14">Wirbelnde Lichter</text>
            <text for="L15">wer wird neben mir stehen?</text>
            <text for="L16">Biete mein erstes Lieblingslied als ihr großes Finale</text>
            <text for="L17">Bist du da?</text>
            <text for="L18">Wie Glut, die am Firmament tanzt</text>
            <text for="L19">Sei sorgenlos, weiche nicht zurück</text>
            <text for="L20">Ergreife die Scherben des gestrigen Traums</text>
            <text for="L21">und durchbrich alle Schranken</text>
            <text for="L22">Die Fährten der Wolken</text>
            <text for="L23">sind ein Paradies der Freude</text>
            <text for="L24">Folge der Musik und du wirst sehen</text>
            <text for="L25">dass du im Traum bereits gelernt hast, wie man fliegt</text>
            <text for="L26">Schritt für Schritt</text>
            <text for="L27">Die Straßenkulisse</text>
            <text for="L28">schafft das Paradies deiner Träume</text>
            <text for="L29">So schön</text>
            <text for="L30">Komm, das ist für dich</text>
            <text for="L31">Ich möchte sanft für dich singen</text>
            <text for="L32">Ganz nah an deinem Ohr</text>
            <text for="L33">Die Außenwelt ist so wie immer</text>
            <text for="L34">nichts hat sich verändert</text>
            <text for="L35">Erhebe deine Stimme und sing</text>
            <text for="L36">Überschütte mich mit Applaus</text>
            <text for="L37">Die Funken in meinem Herzen</text>
            <text for="L38">brennen so hell</text>
            <text for="L39">Lausche der Melodie</text>
            <text for="L40">Sieh, wer da glänzt</text>
            <text for="L41">Die Illusion wird schwinden</text>
            <text for="L42">Wenn du müde bist</text>
            <text for="L43">erlebe die magische Reise aus meiner Feder erneut</text>
            <text for="L44">Schritt für Schritt</text>
            <text for="L45">Die Straßenkulisse</text>
            <text for="L46">singt, tanzt, redet</text>
            <text for="L47">und schreibt die Reise sorgfältig nieder</text>
            <text for="L48">So melodisch</text>
          </translation>
          <translation type="subtitle" xml:lang="ko">
            <text for="L1">홀로 바닷바람의 소리를 듣고 싶어</text>
            <text for="L2">홀로 밤하늘을 올려다보고 싶어</text>
            <text for="L3">그 두근거림을 간직한 채 속박으로부터 달아나</text>
            <text for="L4">아름다운 섬들을 둘러볼 거야</text>
            <text for="L5">그것이 나 자신과의 약속</text>
            <text for="L6">그냥 하는 말이 아니야</text>
            <text for="L7">뭐든 해낼 수 있어</text>
            <text for="L8">서곡, 빗물에 비친 그림자에 숨어</text>
            <text for="L9">걸음마다 섬세한 멜로디를 밟으며</text>
            <text for="L10">음정이 몇 도인지 확인해</text>
            <text for="L11">리라의 악보는 나중에 다시 세자</text>
            <text for="L12">열심히 연습한 반쪽짜리 합주곡</text>
            <text for="L13">언젠가는 들을 수 있겠지</text>
            <text for="L14">회전하는 불빛</text>
            <text for="L15">누가 내 곁에서</text>
            <text for="L16">내가 가장 좋아했던 노래로 피날레를 장식해 줄까</text>
            <text for="L17">혹시 너야?</text>
            <text for="L18">하늘을 수놓은 별빛처럼</text>
            <text for="L19">마음이 가는 대로</text>
            <text for="L20">어젯밤 꾼 달콤한 꿈의 조각을 싣고</text>
            <text for="L21">장벽을 부숴</text>
            <text for="L22">구름의 궤적은</text>
            <text for="L23">놀이동산이야</text>
            <text for="L24">음계를 타고 바라봐</text>
            <text for="L25">꿈속에선 일찍이 나는 법을 배웠기에</text>
            <text for="L26">조금씩 쌓인</text>
            <text for="L27">거리의 풍경</text>
            <text for="L28">환상 속 선경을 만들어가</text>
            <text for="L29">아름다워</text>
            <text for="L30">이제 너에게 선물할게</text>
            <text for="L31">너의 귓가에 속삭이듯</text>
            <text for="L32">노래할래</text>
            <text for="L33">바깥 풍경은 여전히</text>
            <text for="L34">그대로일까</text>
            <text for="L35">온 힘을 다해 노래할래</text>
            <text for="L36">날 위해 몇 번이고 박수를 쳐 줘</text>
            <text for="L37">마음속의 불꽃이</text>
            <text for="L38">피어올라</text>
            <text for="L39">들어봐 이 멜로디</text>
            <text for="L40">봐봐 누가 반짝이는지</text>
            <text for="L41">환상은 언젠가 사라지지만</text>
            <text for="L42">지치는 순간이 오면</text>
            <text for="L43">내가 그린 마법 같은 여정을 떠올릴 거야</text>
            <text for="L44">조금씩 쌓인</text>
            <text for="L45">거리의 풍경</text>
            <text for="L46">노래하고 춤추고 속삭이며</text>
            <text for="L47">써 내려간 나의 유람기</text>
            <text for="L48">너무 아름다워</text>
          </translation>
